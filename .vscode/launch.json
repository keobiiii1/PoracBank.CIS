    "version": "0.2.0",
    "configurations": [
        {
            "name": "CIS.API",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/CIS.API/CIS.API.csproj",
            "launchProfile": "http",
            "preLaunchTask": "build: CIS.API"
        },
        {
            "name": "CIS.Client",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/CIS/CIS.Client.csproj",
            "launchProfile": "https",
            "preLaunchTask": "build: CIS.Client"
        }
    ],
    "compounds": [
        {
            "name": "CIS.API + CIS.Client",
            "configurations": ["CIS.API", "CIS.Client"],
            "stopAll": true
        }
    ]
}
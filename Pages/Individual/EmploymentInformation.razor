@using CIS.Client.Services
@inject IndividualService IndividualService

<EditForm Model="Model" OnValidSubmit="HandleNext">
    <DataAnnotationsValidator />
    <div class="card shadow-sm p-4">
        <h5>Step 4: Employment Details</h5>
        <div class="row g-3 mt-2">
            <div class="col-md-6">
                <label>Employment Status</label>
                <InputSelect @bind-Value="Model.EmploymentStatus" class="form-select">
                    @foreach (var val in Enum.GetValues<EmploymentStatus>())
                    {
                        <option value="@val">@val</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-6">
                <label>Type of Employment</label>
                <InputSelect @bind-Value="Model.TypeOfEmployment" class="form-select">
                    @foreach (var val in Enum.GetValues<TypeOfEmployment>())
                    {
                        <option value="@val">@val</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-12">
                <label>Employer Name / Business Name</label>
                <InputText @bind-Value="Model.NameOfEmployer" class="form-control" />
            </div>
            <div class="col-md-6">
                <label>Nature of Work</label>
                <InputText @bind-Value="Model.NatureOfWork" class="form-control" />
            </div>
            <div class="col-md-6">
                <label>Average Monthly Income</label>
                <InputSelect @bind-Value="Model.AverageMonthlyIncome" class="form-select">
                    @foreach (var val in Enum.GetValues<AverageMonthlyIncome>())
                    {
                        <option value="@val">@val</option>
                    }
                </InputSelect>
            </div>
        </div>
        <div class="d-flex justify-content-between mt-5">
            <button type="button" class="btn btn-outline-secondary" @onclick="OnBack">Back</button>
            <button type="submit" class="btn btn-primary px-5">Save & Next</button>
        </div>
    </div>
</EditForm>

@code {
    [Parameter] public IndividualEmploymentDTO.PageModel Model { get; set; } = new();
    [Parameter] public long CustomerId { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private async Task HandleNext()
    {
        Model.CustomerID = CustomerId;
        await IndividualService.UpsertEmploymentAsync(Model);
        await OnNext.InvokeAsync();
    }
}
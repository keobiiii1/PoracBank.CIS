@using CIS.Client.Services
@inject IndividualService IndividualService

<EditForm Model="Model" OnValidSubmit="HandleNext">
    <div class="card shadow-sm p-4">
        <h5>Step 5: Family Background</h5>
        <div class="row g-3 mt-2">
            <h6>Spouse Information (If Applicable)</h6>
            <div class="col-md-6"><label>First Name</label><InputText @bind-Value="Model.SpouseGivenName" class="form-control" /></div>
            <div class="col-md-6"><label>Last Name</label><InputText @bind-Value="Model.SpouseLastName" class="form-control" /></div>

            <h6 class="mt-4">Mother's Maiden Name</h6>
            <div class="col-md-6"><label>First Name</label><InputText @bind-Value="Model.MotherMaidenGivenName" class="form-control" /></div>
            <div class="col-md-6"><label>Last Name</label><InputText @bind-Value="Model.MotherMaidenLastName" class="form-control" /></div>
        </div>
        <div class="d-flex justify-content-between mt-5">
            <button type="button" class="btn btn-outline-secondary" @onclick="OnBack">Back</button>
            <button type="submit" class="btn btn-primary px-5">Save & Next</button>
        </div>
    </div>
</EditForm>

@code {
    [Parameter] public IndividualFamilyDTO.PageModel Model { get; set; } = new();
    [Parameter] public long CustomerId { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private async Task HandleNext()
    {
        Model.CustomerID = CustomerId;
        await IndividualService.UpsertFamilyAsync(Model);
        await OnNext.InvokeAsync();
    }
}
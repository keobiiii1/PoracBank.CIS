@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="pb-app-shell">

    @* ── Top Bar ── *@
    <header class="pb-topbar">
        <div class="pb-topbar-inner">
            <div class="pb-topbar-brand">
                <img src="images/poracbank.png" alt="Porac Bank" class="pb-logo" />
            </div>
            @* <div class="pb-topbar-right">
                <span class="pb-connectivity @(isOnline ? "online" : "offline")">
                    <i class="bi @(isOnline ? "bi-wifi" : "bi-wifi-off")"></i>
                    <span class="pb-conn-label">@(isOnline ? "Online" : "Offline")</span>
                </span>
            </div> *@
        </div>
    </header>

    @* ── Page Body ── *@
    <main class="pb-main" role="main">
        <div class="pb-content-wrap">
            @Body
        </div>
    </main>

</div>

@code {
    private bool isOnline = true;
    private DotNetObjectReference<MainLayout>? objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isOnline = await JSRuntime.InvokeAsync<bool>("connectivityStatus.checkStatus");
            objRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("connectivityStatus.registerHandler", objRef);
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void UpdateStatus(bool status)
    {
        isOnline = status;
        StateHasChanged();
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }
}

@inherits LayoutComponentBase

<div class="min-vh-100" style="background-color: #f8fafc;">
    <div class="container-fluid px-3 px-sm-4 py-3 py-sm-4">
        <div class="mx-auto" style="max-width: 1200px;">
            <div class="d-flex d-sm-none align-items-center justify-content-between mb-3">
                <h1 class="h5 fw-bold text-primary mb-0">
                    <i class="bi bi-bank2 me-2"></i>CIS
                </h1>
                <span class="badge bg-light text-dark px-3 py-2 rounded-pill">
                    <i class="bi bi-wifi"></i> PWA
                </span>
            </div>

            @Body
        </div>
    </div>
</div>

<style>
    .min-vh-100 {
        min-height: 100vh;
    }

    .btn, .nav-button, .type-selector, .form-check-input {
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
    }

    input, select, textarea {
        font-size: 16px !important;
    }

    .smooth-scroll {
        -webkit-overflow-scrolling: touch;
    }

    @@media (max-width: 576px) {
        .container-fluid {
            padding-left: 12px !important;
            padding-right: 12px !important;
        }
    }
</style>
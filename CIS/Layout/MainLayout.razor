@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="min-vh-100" style="background-color: #f3f4f6;">
    <div class="container-fluid px-3 px-sm-4 py-3 py-sm-4">
        <div class="mx-auto" style="max-width: 1200px;">
            
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div class="d-flex align-items-center">
                    <img src="images/poracbank.png" alt="Porac Bank" style="height: 40px; width: auto;" /> 
                </div>
                
@*                 <span class="badge @(isOnline ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") px-3 py-2 rounded-pill shadow-sm border">
                    <i class="bi @(isOnline ? "bi-wifi" : "bi-wifi-off") me-1"></i> 
                    @(isOnline ? "Online" : "Offline")
                </span> *@
            </div>

            <hr class="mb-4" style="opacity: 0.1;" />

            <main role="main">
                @Body
            </main>
        </div>
    </div>
</div>

@code {
    private bool isOnline = true;
    private DotNetObjectReference<MainLayout>? objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initial check from the window.connectivityStatus in index.html
            isOnline = await JSRuntime.InvokeAsync<bool>("connectivityStatus.checkStatus");
            
            // Register listener for real-time updates
            objRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("connectivityStatus.registerHandler", objRef);
            
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void UpdateStatus(bool status)
    {
        isOnline = status;
        StateHasChanged();
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }
}
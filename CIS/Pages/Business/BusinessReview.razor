@using CIS.Assets.DTO
@using CIS.Assets.Enum

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-primary text-white py-3">
        <h5 class="mb-0"><i class="bi bi-eye-fill me-2"></i> REGISTRATION SUMMARY</h5>
    </div>
    <div class="card-body p-4">
        <div class="review-section mb-4">
            <h6 class="text-primary fw-bold border-bottom pb-2 mb-3">CORPORATE IDENTITY</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="small text-muted d-block">NAME</label>
                    <strong>@BusinessModel.NameOfBusiness</strong>
                </div>
                <div class="col-md-3">
                    <label class="small text-muted d-block">TIN</label>
                    <strong>@BusinessModel.TaxIdentificationNumber</strong>
                </div>
                <div class="col-md-3">
                    <label class="small text-muted d-block">REG. DATE</label>
                    <strong>@BusinessModel.DateOfRegistration?.ToString("MM/dd/yyyy")</strong>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="review-section h-100">
                    <h6 class="text-primary fw-bold border-bottom pb-2 mb-3">SIGNATURE PREVIEW</h6>
                    @if (!string.IsNullOrEmpty(AcknowledgementModel.SignatureData))
                    {
                        <img src="@AcknowledgementModel.SignatureData" class="img-fluid border bg-white p-2" style="max-height: 100px;" />
                    }
                    else
                    {
                        <span class="text-danger small">No signature captured.</span>
                    }
                </div>
            </div>
            <div class="col-md-6">
                <div class="review-section h-100">
                    <h6 class="text-primary fw-bold border-bottom pb-2 mb-3">BANK REVIEW STATUS</h6>
                    <div class="small">
                        <div>Verified By: <strong>@BankReviewModel.VerifiedBy</strong></div>
                        <div>Approved By: <strong>@BankReviewModel.ApprovedBy</strong></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between mb-5">
    <button type="button" class="btn btn-outline-secondary px-5" @onclick="OnBack" disabled="@IsSubmitting">Back</button>

    <button type="button" class="btn btn-success px-5 fw-bold" @onclick="SubmitAsync" disabled="@IsSubmitting">
        @if (IsSubmitting)
        {
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            <text>Loading...</text>
        }
        else
        {
            <text>FINALIZE REGISTRATION</text>
        }
    </button>
</div>

<style>
    .review-section {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
        border-left: 4px solid #0d6efd;
    }
</style>

@code {
    [Parameter] public BusinessInfoDTO.PageModel BusinessModel { get; set; } = new();
    [Parameter] public AddressDTO.PageModel AddressModel { get; set; } = new();
    [Parameter] public BeneficiaryDTO.PageModel BeneficiaryModel { get; set; } = new();
    [Parameter] public ClientAcknowledgementDTO.PageModel AcknowledgementModel { get; set; } = new();
    [Parameter] public BankReviewDTO.PageModel BankReviewModel { get; set; } = new();
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }

    private bool IsSubmitting { get; set; } = false;

    private async Task SubmitAsync()
    {
        if (IsSubmitting) return;

        IsSubmitting = true;

        try
        {
            await OnSubmit.InvokeAsync();
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
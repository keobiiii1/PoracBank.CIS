@using CIS.Assets.DTO
@using CIS.Assets.Enum
@using System.ComponentModel

<EditForm Model="BusinessModel" OnValidSubmit="Next">
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Step 2: Account and Contact Information</h5>
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Purpose of Account</label>
                    <InputSelect @bind-Value="BusinessModel.AccountPurpose" class="form-select">
                        @foreach (var val in GetFilteredPurposes())
                        {
                            <option value="@val.ToString()">@GetDescription(val)</option>
                        }
                    </InputSelect>
                </div>

                @if (BusinessModel.AccountPurpose == PurposeOfAccount.Others)
                {
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Specify Purpose</label>
                        <InputText @bind-Value="BusinessModel.AccountPurposeOther" class="form-control" />
                    </div>
                }

                <div class="col-12">
                    <label class="form-label fw-bold">Products to be Availed</label>
                    <div class="d-flex flex-wrap gap-4 mt-2">
                        @foreach (var product in productOptions)
                        {
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="@product"
                                       checked="@selectedProducts.Contains(product)"
                                       @onchange="(e) => ToggleProduct(product, e)" />
                                <label class="form-check-label" for="@product">@product</label>
                            </div>
                        }
                    </div>
                </div>

                @if (selectedProducts.Contains("Others"))
                {
                    <div class="col-12 mt-2">
                        <label class="form-label fw-bold">Please Specify Other Products</label>
                        <InputText @bind-Value="BusinessModel.ProductsAvailedOther" class="form-control" placeholder="Specify here..." />
                    </div>
                }

                <div class="col-md-6 mt-3">
                    <label class="form-label fw-bold">Average Annual Income</label>
                    <InputSelect @bind-Value="BusinessModel.AverageAnnualIncome" class="form-select">
                        @foreach (var val in Enum.GetValues<AverageAnnualIncome>())
                        {
                            <option value="@val">@val</option>
                        }
                    </InputSelect>
                </div>

                <div class="col-md-6 mt-3">
                    <label class="form-label fw-bold">Size of Business</label>
                    <InputSelect @bind-Value="BusinessModel.SizeOfBusiness" class="form-select">
                        @foreach (var val in Enum.GetValues<SizeOfBusiness>())
                        {
                            <option value="@val">@val</option>
                        }
                    </InputSelect>
                </div>

                <div class="col-12"><hr /></div>
                <h6 class="fw-bold mb-3 text-primary">Contact Information</h6>

                <div class="col-md-4">
                    <label class="form-label">Phone Number</label>
                    <InputText @bind-Value="BusinessModel.OfficePhoneNo" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Email Address</label>
                    <InputText @bind-Value="BusinessModel.EmailAddress" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Contact Person</label>
                    <InputText @bind-Value="BusinessModel.ContactPerson" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between mb-5">
        <button type="button" class="btn btn-outline-secondary px-5" @onclick="OnBack">Back</button>
        <button type="submit" class="btn btn-primary px-5">Save & Next</button>
    </div>
</EditForm>

@code {
    [Parameter] public BusinessInfoDTO.PageModel BusinessModel { get; set; } = new();
    [Parameter] public AddressDTO.PageModel AddressModel { get; set; } = new();
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private List<string> productOptions = new() { "Savings", "Current", "TD", "Loan", "Sale Of ROPA", "Others" };
    private List<string> selectedProducts = new();

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(BusinessModel.ProductsAvailed))
            selectedProducts = BusinessModel.ProductsAvailed.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
    }

    private List<PurposeOfAccount> GetFilteredPurposes() => new() { PurposeOfAccount.None, PurposeOfAccount.BusinessPurposes, PurposeOfAccount.Others };

    private string GetDescription(PurposeOfAccount val)
    {
        var field = val.GetType().GetField(val.ToString());
        var attr = (DescriptionAttribute)Attribute.GetCustomAttribute(field!, typeof(DescriptionAttribute));
        return attr?.Description ?? val.ToString();
    }

    private void ToggleProduct(string product, ChangeEventArgs e)
    {
        var isChecked = (bool)e.Value!;
        if (isChecked) { if (!selectedProducts.Contains(product)) selectedProducts.Add(product); }
        else { selectedProducts.Remove(product); }
        BusinessModel.ProductsAvailed = string.Join(",", selectedProducts);
    }

    private async Task Next()
    {
        BusinessModel.ProductsAvailed = string.Join(",", selectedProducts);

        if (!selectedProducts.Contains("Others"))
        {
            BusinessModel.ProductsAvailedOther = null;
        }

        await OnNext.InvokeAsync();
    }
}
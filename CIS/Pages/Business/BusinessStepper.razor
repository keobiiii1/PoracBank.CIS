@page "/cis/business"
@namespace CIS.Client.Pages.Business
@using CIS.Assets.DTO
@using CIS.Assets.Enum
@using CIS.Client.Services
@inject BusinessService BusinessService
@inject RegistrationStorageService Storage
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Business Account Registration</h2>
        <span class="badge bg-primary px-3 py-2">Step @CurrentStep of 7</span>
    </div>

    @* Progress Bar *@
    <div class="progress mb-4 shadow-sm" style="height: 12px; border-radius: 10px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated"
             style="width: @(CurrentStep * 16.66)%; border-radius: 10px;"></div>
    </div>

    @if (CurrentStep == 1)
    {
        <BusinessInformation BusinessModel="businessModel" AddressModel="addressModel" OnNext="HandleNext" />
    }
    else if (CurrentStep == 2)
    {
        <AccountContact BusinessModel="businessModel" AddressModel="addressModel" OnNext="HandleNext" OnBack="PrevStep" />
    }
    else if (CurrentStep == 3)
    {
        <BeneficiaryInfo BeneficiaryModel="beneficiaryModel" OnNext="HandleNext" OnBack="PrevStep" />
    }
    else if (CurrentStep == 4)
    {
        <ClientAcknowlegdement AcknowledgementModel="ackModel" OnNext="HandleNext" OnBack="PrevStep" />
    }
    else if (CurrentStep == 5)
    {
        <BankReviewInfo ReviewModel="bankReviewModel" OnNext="HandleNext" OnBack="PrevStep" />
    }
    else if (CurrentStep == 6)
    {
        <BusinessReview BusinessModel="businessModel"
                        AddressModel="addressModel"
                        BeneficiaryModel="beneficiaryModel"
                        AcknowledgementModel="ackModel"
                        BankReviewModel="bankReviewModel"
                        OnBack="PrevStep"
                        OnSubmit="HandleSubmit" />
    }
    else if (CurrentStep == 7)
    {
        <RegistrationSuccess CustomerName="@businessModel.NameOfBusiness"
                             CustomerId="businessModel.CustomerID"
                             RegistrationType="Business"
                             OnReset="ResetStepper" />
    }
</div>

@code {
    private int CurrentStep = 1;

    private BusinessInfoDTO.PageModel businessModel = new();
    private AccountPurposeDTO.PageModel accpurpModel = new();
    private AddressDTO.PageModel addressModel = new();
    private ContactDTO.PageModel contactModel = new();
    private BeneficiaryDTO.PageModel beneficiaryModel = new();
    private ClientAcknowlegdementDTO.PageModel ackModel = new();
    private BankReviewDTO.PageModel bankReviewModel = new();

    protected override async Task OnInitializedAsync()
    {
        var draft = await Storage.GetDraftAsync();
        if (draft != null)
        {
            businessModel = draft.Business ?? new();
            accpurpModel = draft.AccountPurpose ?? new();
            addressModel = draft.Address ?? new();
            contactModel = draft.Contact ?? new();
            beneficiaryModel = draft.Beneficiary ?? new();
            ackModel = draft.Acknowledgement ?? new();
            bankReviewModel = draft.Review ?? new();
            CurrentStep = draft.CurrentStep;
        }
    }

    private async Task HandleNext()
    {
        CurrentStep++;
        await Storage.SaveBusinessDraftAsync(businessModel, accpurpModel, addressModel, contactModel, beneficiaryModel, ackModel, bankReviewModel, CurrentStep);
        StateHasChanged();
        await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    private void PrevStep()
    {
        if (CurrentStep > 1) { CurrentStep--; StateHasChanged(); }
    }

    private async Task HandleSubmit()
    {
        var products = businessModel.ProductsAvailed?.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList() ?? new();

        var fullRequest = new BusinessRegistrationRequest
        {
            Business = businessModel,
            Address = addressModel,
            Beneficiary = beneficiaryModel,
            Acknowledgement = ackModel,
            BankReview = bankReviewModel,
            AccountPurpose = new AccountPurposeDTO.PageModel
            {
                PurposeOfAccount = businessModel.AccountPurpose,
                PurposeOfAccountOther = businessModel.AccountPurposeOther,
                ProductSavings = products.Contains("Savings"),
                ProductCurrent = products.Contains("Current"),
                ProductTimeDeposit = products.Contains("TD"),
                ProductLoan = products.Contains("Loan"),
                ProductSaleOfROPA = products.Contains("Sale Of ROPA"),
                ProductOthers = products.Contains("Others")
            },
            Contact = new ContactDTO.PageModel { EmailAddress = businessModel.EmailAddress, MobilePhoneNumber = businessModel.OfficePhoneNo }
        };

        var generatedId = await BusinessService.FinalizeRegistrationAsync(fullRequest);

        if (generatedId > 0)
        {
            businessModel.CustomerID = generatedId;
            await Storage.ClearDraftAsync();
            CurrentStep = 7;
            StateHasChanged();
        }
    }

    private async Task ResetStepper()
    {
        await Storage.ClearDraftAsync();
        CurrentStep = 1;
        businessModel = new();
        addressModel = new();
        beneficiaryModel = new();
        ackModel = new();
        bankReviewModel = new();
        StateHasChanged();
        Nav.NavigateTo("/");
    }
}
@page "/cis/business"
@namespace CIS.Client.Pages.Business
@using CIS.Assets.DTO
@using CIS.Assets.Enum
@using CIS.Client.Services
@inject BusinessService BusinessService

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Business Account Registration</h2>
        <span class="badge bg-primary">Step @CurrentStep of 6</span>
    </div>

    @* Progress Bar *@
    <div class="progress mb-4" style="height: 10px;">
        <div class="progress-bar" style="width: @(CurrentStep * 16.66)%"></div>
    </div>

    @if (CurrentStep == 1)
    {
        <BusinessInformation BusinessModel="businessModel" AddressModel="addressModel" OnNext="HandleNext" />
    }
    else if (CurrentStep == 2)
    {
        <AccountContact BusinessModel="businessModel" AddressModel="addressModel" OnNext="HandleNext" OnBack="PrevStep" />
    }
    else if (CurrentStep == 3)
    {
        <BeneficiaryInfo BeneficiaryModel="beneficiaryModel"
                         CustomerID="businessModel.CustomerID"
                         OnNext="HandleNext"
                         OnBack="PrevStep" />
    }
    else if (CurrentStep == 4)
    {
        <ClientAcknowlegdement CustomerID="businessModel.CustomerID"
                               OnNext="HandleNext"
                               OnBack="PrevStep" />
    }
    @* --- Future Steps Placeholder --- *@
    else if (CurrentStep > 4 && CurrentStep < 7)
    {
        <div class="card p-5 text-center shadow-sm">
            <h4>Step @CurrentStep Content Placeholder</h4>
            <p class="text-muted">Logic for subsequent business steps will be implemented next.</p>
            <button class="btn btn-outline-secondary mt-3" @onclick="PrevStep">Back</button>
        </div>
    }
    else if (CurrentStep == 7)
    {
        <div class="text-center p-5">
            <div class="alert alert-success shadow">
                <h4>Registration Submitted Successfully!</h4>
                <p>The business record has been queued for bank review.</p>
            </div>
            <button class="btn btn-primary" @onclick="ResetStepper">Register Another Business</button>
        </div>
    }
</div>

@code {
    private int CurrentStep = 1;

    private BusinessInfoDTO.PageModel businessModel = new();
    private AddressDTO.PageModel addressModel = new();
    private BeneficiaryDTO.PageModel beneficiaryModel = new();

    private async Task HandleNext()
    {
        CurrentStep++;
        StateHasChanged();
    }

    private void PrevStep()
    {
        if (CurrentStep > 1)
        {
            CurrentStep--;
            StateHasChanged();
        }
    }

    private async Task HandleSubmit()
    {
        CurrentStep = 7;
        StateHasChanged();
    }

    private void ResetStepper()
    {
        CurrentStep = 1;
        businessModel = new();
        addressModel = new();
        beneficiaryModel = new();
        StateHasChanged();
    }
}
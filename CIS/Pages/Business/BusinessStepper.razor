@page "/cis/business"
@namespace CIS.Client.Pages.Business
@using CIS.Assets.DTO
@using CIS.Assets.Enum
@using CIS.Client.Services
@inject BusinessService BusinessService

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Business Account Registration</h2>
        <span class="badge bg-primary px-3 py-2">Step @CurrentStep of 6</span>
    </div>

    @* Progress Bar *@
    <div class="progress mb-4 shadow-sm" style="height: 12px; border-radius: 10px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated"
             style="width: @(CurrentStep * 16.66)%; border-radius: 10px;"></div>
    </div>

    @if (CurrentStep == 1)
    {
        <BusinessInformation BusinessModel="businessModel" AddressModel="addressModel" OnNext="HandleNext" />
    }
    else if (CurrentStep == 2)
    {
        <AccountContact BusinessModel="businessModel" AddressModel="addressModel" OnNext="HandleNext" OnBack="PrevStep" />
    }
    else if (CurrentStep == 3)
    {
        <BeneficiaryInfo BeneficiaryModel="beneficiaryModel"
                         CustomerID="businessModel.CustomerID"
                         OnNext="HandleNext"
                         OnBack="PrevStep" />
    }
    else if (CurrentStep == 4)
    {
        <ClientAcknowlegdement CustomerID="businessModel.CustomerID"
                               OnNext="HandleNext"
                               OnBack="PrevStep" />
    }
    else if (CurrentStep == 5)
    {
        <BankReviewInfo ReviewModel="bankReviewModel"
                        CustomerID="businessModel.CustomerID"
                        OnNext="HandleNext"
                        OnBack="PrevStep" />
    }
    else if (CurrentStep == 6)
    {
        @* REGISTERED STEP 6: FINAL REVIEW *@
        <BusinessReview BusinessModel="businessModel"
                        AddressModel="addressModel"
                        BeneficiaryModel="beneficiaryModel"
                        OnBack="PrevStep"
                        OnSubmit="HandleSubmit" />
    }
    else if (CurrentStep == 7)
    {
        <div class="text-center p-5 animate__animated animate__fadeIn">
            <div class="card border-0 shadow-lg p-5">
                <div class="mb-4">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                </div>
                <h2 class="fw-bold">Registration Completed!</h2>
                <p class="text-muted mb-4">The business record for <strong>@businessModel.NameOfBusiness</strong> has been successfully registered and reviewed.</p>
                <div class="d-grid gap-2 col-md-6 mx-auto">
                    <button class="btn btn-primary btn-lg" @onclick="ResetStepper">
                        <i class="bi bi-plus-circle me-2"></i> Register New Business
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="@(() => StateHasChanged())">
                        <i class="bi bi-printer me-2"></i> Print Forms
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private int CurrentStep = 1;

    private BusinessInfoDTO.PageModel businessModel = new();
    private AddressDTO.PageModel addressModel = new();
    private BeneficiaryDTO.PageModel beneficiaryModel = new();
    private BankReviewDTO.PageModel bankReviewModel = new();

    private async Task HandleNext()
    {
        CurrentStep++;
        StateHasChanged();
        await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    private void PrevStep()
    {
        if (CurrentStep > 1)
        {
            CurrentStep--;
            StateHasChanged();
            JS.InvokeVoidAsync("window.scrollTo", 0, 0);
        }
    }

    private async Task HandleSubmit()
    {
        CurrentStep = 7;
        StateHasChanged();
    }

    private void ResetStepper()
    {
        CurrentStep = 1;
        businessModel = new();
        addressModel = new();
        beneficiaryModel = new();
        bankReviewModel = new();
        StateHasChanged();
    }

    [Inject] private IJSRuntime JS { get; set; }
}
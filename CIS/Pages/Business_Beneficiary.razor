    .bcb-select-wrap { position: relative; }
    .bcb-select-arrow { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: #94a3b8; pointer-events: none; }
    .bcb-radio-group { display: flex; flex-wrap: wrap; gap: 10px; }

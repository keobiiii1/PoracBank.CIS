    .pcs-toggle-switch.on .pcs-toggle-thumb { transform: translateX(20px); }
    .pcs-phone-wrap { display: flex; align-items: center; border: 1.5px solid #e2e8f0; border-radius: 11px; overflow: hidden; transition: border-color 0.18s, box-shadow 0.18s; background: #fff; }

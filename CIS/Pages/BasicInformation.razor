@code {
    // ── Parameters ────────────────────────────────────────────────
    [Parameter] public CustomerDTO.PageModel Customer { get; set; } = new();
    [Parameter] public EventCallback<CustomerDTO.PageModel> CustomerChanged { get; set; }
    [Parameter] public IndividualInfoDTO.PageModel Model { get; set; } = new();
    [Parameter] public EventCallback<IndividualInfoDTO.PageModel> ModelChanged { get; set; }
    [Parameter] public IndividualForeignerDTO.PageModel ForeignerModel { get; set; } = new();
    [Parameter] public EventCallback<IndividualForeignerDTO.PageModel> ForeignerModelChanged { get; set; }
    [Parameter] public AddressDTO.PageModel AddressModel { get; set; } = new();
    [Parameter] public IndividualInfoDTO.PageModel InfoModel { get; set; } = new();
    [Parameter] public ContactDTO.PageModel ContactModel { get; set; } = new();
    [Parameter] public EventCallback<ContactDTO.PageModel> ContactModelChanged { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    // ── State ──────────────────────────────────────────────────────
    private EditForm? personalForm;
    private EditForm? contactForm;
    private ValidationMessageStore? personalMessageStore;
    private ValidationMessageStore? contactMessageStore;

    // Personal state
    // Contact state
    private string? permHouseNo, permStreet, permBarangay, permCity, permProvince;
    private string? presHouseNo, presStreet, presBarangay, presCity, presProvince;
    private string? permAddressError, presAddressError;
    private string? mobileRaw;

    // Track which forms have passed
    private bool personalPassed = false;
    private bool contactPassed = false;
    private bool contactAttempted = false;

    // ── Lifecycle ──────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        Model.IsResident = true;
        Model.CustomerCategories = Customer.CustomerCategories;
        AddressModel.IsPresentSameAsPermanent = true;

        // Restore address parts from saved draft
        if (!string.IsNullOrWhiteSpace(AddressModel.PermanentAddress))
            RestoreAddressParts(AddressModel.PermanentAddress, ref permHouseNo, ref permStreet, ref permBarangay, ref permCity, ref permProvince);
        if (!string.IsNullOrWhiteSpace(AddressModel.PresentAddress))
            RestoreAddressParts(AddressModel.PresentAddress, ref presHouseNo, ref presStreet, ref presBarangay, ref presCity, ref presProvince);
        if (!string.IsNullOrWhiteSpace(InfoModel.MobilePhoneNumber) && InfoModel.MobilePhoneNumber.StartsWith("+63"))
            mobileRaw = InfoModel.MobilePhoneNumber[3..];
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;

        var pCtx = personalForm?.EditContext;
        if (pCtx != null)
        {
            personalMessageStore = new ValidationMessageStore(pCtx);
            pCtx.OnFieldChanged += (_, _) => { ValidatePersonalConditional(); pCtx.NotifyValidationStateChanged(); };
        }

        var cCtx = contactForm?.EditContext;
        if (cCtx != null)
        {
            contactMessageStore = new ValidationMessageStore(cCtx);
            cCtx.OnFieldChanged += (_, _) => { if (contactAttempted) { ValidateContactConditional(cCtx); cCtx.NotifyValidationStateChanged(); } };
        }
    }

    // ── Combined trigger ──────────────────────────────────────────
    private async Task TriggerAll()
    {
        personalPassed = false;
        contactPassed = false;

        // Validate personal form — only fire OnValidSubmit if no errors
        var pCtx = personalForm?.EditContext;
        if (pCtx != null)
        {
            pCtx.Validate();
            ValidatePersonalConditional();
            pCtx.NotifyValidationStateChanged();

            if (!pCtx.GetValidationMessages().Any())
                await personalForm!.OnValidSubmit.InvokeAsync();
        }

        // Validate contact form — only fire OnValidSubmit if no errors
        var cCtx = contactForm?.EditContext;
        if (cCtx != null)
        {
            contactAttempted = true;
            cCtx.Validate();
            ValidateContactConditional(cCtx);
            cCtx.NotifyValidationStateChanged();

            if (!cCtx.GetValidationMessages().Any())
                await contactForm!.OnValidSubmit.InvokeAsync();
        }

        if (personalPassed && contactPassed)
        {
            await CommitAndAdvance();
            return;
        }

        // Force UI re-render so error messages are in the DOM before JS scans for them
        StateHasChanged();
        await Task.Delay(50);

        var scrollIds = new[]
        {
            "field-CustomerCategories",
            "field-FirstName",
            "field-Gender",
            "field-MaidenName",
            "field-SpouseName",
            "field-DateOfBirth",
            "field-MotherMaidenGivenName",
            "field-ForeignerDetails",
            "field-PermanentAddress",
            "field-MobilePhone",
            "field-MailingPreference"
        };
        foreach (var id in scrollIds)
        {
            try { if (await JS.InvokeAsync<bool>("scrollToFirstError", id)) break; }
            catch { }
        }
    }

    private void OnPersonalValidSubmit() => personalPassed = true;
    private void OnContactValidSubmit() => contactPassed = true;

    // ── Commit both forms and advance ────────────────────────────
    private async Task CommitAndAdvance()
    {
        // Personal cleanup
        Customer.EntityType = EntityType.Individual;
        Customer.CustomerCategories = Model.CustomerCategories;
        if (Model.Citizenship != Citizenship.Others) Model.CitizenshipOther = null;
        if (Model.MaritalStatus is not (MaritalStatus.Married or MaritalStatus.Widowed))
            (Model.SpouseGivenName, Model.SpouseMiddleName, Model.SpouseLastName) = (null, null, null);
        if (!(Model.Gender == Gender.Female && Model.MaritalStatus == MaritalStatus.Married))
            (Model.MaidenName, Model.MaidenMiddleName, Model.MaidenLastName) = (null, null, null);
        if (Model.IsForeigner)
        {
            ForeignerModel.PassportIDNumber = Model.PassportIDNumber;
            ForeignerModel.PassportExpiry = Model.PassportExpiry;
            ForeignerModel.IsACR = Model.IsACR;
            ForeignerModel.IsSIRV = Model.IsSIRV;
            ForeignerModel.IsSRRV = Model.IsSRRV;
        }
        else
        {
            ForeignerModel.PassportIDNumber = Model.PassportIDNumber = null;
            ForeignerModel.PassportExpiry = Model.PassportExpiry = null;
            ForeignerModel.IsACR = Model.IsACR = false;
            ForeignerModel.IsSIRV = Model.IsSIRV = false;
            ForeignerModel.IsSRRV = Model.IsSRRV = false;
        }

        // Contact cleanup
        if (AddressModel.IsPresentSameAsPermanent)
        {
            AddressModel.PresentAddress = AddressModel.PermanentAddress;
            AddressModel.PresentZipCode = AddressModel.PermanentZipCode;
            AddressModel.PresentCountry = AddressModel.PermanentCountry;
            AddressModel.MailingPreference = MailingPreference.PermanentAddress;
        }
        ContactModel.EntityType = EntityType.Individual;
        ContactModel.HomePhoneNumber = InfoModel.HomePhoneNumber;
        ContactModel.MobilePhoneNumber = InfoModel.MobilePhoneNumber;
        ContactModel.EmailAddress = InfoModel.EmailAddress;

        await CustomerChanged.InvokeAsync(Customer);
        await ForeignerModelChanged.InvokeAsync(ForeignerModel);
        await ContactModelChanged.InvokeAsync(ContactModel);
        await OnNext.InvokeAsync();
    }

    // ── Personal validation ───────────────────────────────────────
    private void ValidatePersonalConditional()
    {
        var store = personalMessageStore;
        var ctx = personalForm?.EditContext;
        if (store == null || ctx == null) return;
        store.Clear();
        if (Model.CustomerCategories.Count == 0)
            store.Add(() => Model.CustomerCategories, "At least one customer category must be selected.");
        if (Model.Citizenship == Citizenship.Others && string.IsNullOrWhiteSpace(Model.CitizenshipOther))
            store.Add(() => Model.CitizenshipOther, "Please specify citizenship.");
        if (Model.MaritalStatus is MaritalStatus.Married or MaritalStatus.Widowed)
        {
            if (string.IsNullOrWhiteSpace(Model.SpouseGivenName)) store.Add(() => Model.SpouseGivenName, "Spouse given name is required.");
            if (string.IsNullOrWhiteSpace(Model.SpouseLastName)) store.Add(() => Model.SpouseLastName, "Spouse last name is required.");
        }
        if (Model.Gender == Gender.Female && Model.MaritalStatus == MaritalStatus.Married)
        {
            if (string.IsNullOrWhiteSpace(Model.MaidenName)) store.Add(() => Model.MaidenName, "Maiden first name is required.");
            if (string.IsNullOrWhiteSpace(Model.MaidenMiddleName)) store.Add(() => Model.MaidenMiddleName, "Maiden middle name is required.");
            if (string.IsNullOrWhiteSpace(Model.MaidenLastName)) store.Add(() => Model.MaidenLastName, "Maiden last name is required.");
        }
        if (Model.IsForeigner)
        {
            if (string.IsNullOrWhiteSpace(Model.PassportIDNumber)) store.Add(() => Model.PassportIDNumber, "Passport ID number is required.");
            if (Model.PassportExpiry == null) store.Add(() => Model.PassportExpiry, "Passport expiry date is required.");
            else if (Model.PassportExpiry <= DateOnly.FromDateTime(DateTime.Today)) store.Add(() => Model.PassportExpiry, "Passport expiry must be a future date.");
        }
    }

    // ── Contact validation ────────────────────────────────────────
    private void ValidateContactConditional(EditContext ctx)
    {
        var store = contactMessageStore;
        if (store == null) return;
        store.Clear();
        if (string.IsNullOrWhiteSpace(AddressModel.PermanentAddress))
        { permAddressError = "Please fill in all permanent address fields."; store.Add(() => AddressModel.PermanentAddress, "Permanent address is required."); }
        else permAddressError = null;
        if (string.IsNullOrWhiteSpace(InfoModel.EmailAddress))
            store.Add(() => InfoModel.EmailAddress, "Email address is required.");
        else if (!InfoModel.EmailAddress.Contains('@') || !InfoModel.EmailAddress.Contains('.'))
            store.Add(() => InfoModel.EmailAddress, "Please enter a valid email address.");
        if (!AddressModel.IsPresentSameAsPermanent && AddressModel.MailingPreference == MailingPreference.None)
            store.Add(() => AddressModel.MailingPreference, "Please select a mailing preference.");
        if (!AddressModel.IsPresentSameAsPermanent)
        {
            if (string.IsNullOrWhiteSpace(AddressModel.PresentAddress))
            { presAddressError = "Please fill in all present address fields."; store.Add(() => AddressModel.PresentAddress, "Present address is required."); }
            else presAddressError = null;
            if (string.IsNullOrWhiteSpace(AddressModel.PresentZipCode)) store.Add(() => AddressModel.PresentZipCode, "Present zip code is required.");
            if (string.IsNullOrWhiteSpace(AddressModel.PresentCountry)) store.Add(() => AddressModel.PresentCountry, "Present country is required.");
        }
    }

    // ── Handlers ──────────────────────────────────────────────────
    private void HandleAddressSync(ChangeEventArgs e)
    {
        AddressModel.IsPresentSameAsPermanent = (bool)(e.Value ?? false);
        if (AddressModel.IsPresentSameAsPermanent)
        {
            AddressModel.PresentAddress = AddressModel.PermanentAddress;
            AddressModel.PresentZipCode = AddressModel.PermanentZipCode;
            AddressModel.PresentCountry = AddressModel.PermanentCountry;
            AddressModel.MailingPreference = MailingPreference.PermanentAddress;
            (presHouseNo, presStreet, presBarangay, presCity, presProvince) = (null, null, null, null, null);
        }
        else { AddressModel.PresentAddress = null; AddressModel.PresentZipCode = null; AddressModel.PresentCountry = null; }
    }

    private void BuildPermanentAddress(ChangeEventArgs _)
    {
        AddressModel.PermanentAddress = string.Join(", ", new[] { permHouseNo, permStreet, permBarangay, permCity, permProvince }.Where(p => !string.IsNullOrWhiteSpace(p)));
        permAddressError = string.IsNullOrWhiteSpace(AddressModel.PermanentAddress) ? "Permanent address is required." : null;
    }

    private void BuildPresentAddress(ChangeEventArgs _)
    {
        AddressModel.PresentAddress = string.Join(", ", new[] { presHouseNo, presStreet, presBarangay, presCity, presProvince }.Where(p => !string.IsNullOrWhiteSpace(p)));
        presAddressError = string.IsNullOrWhiteSpace(AddressModel.PresentAddress) ? "Present address is required." : null;
    }

    private void HandleMobileInput(ChangeEventArgs e)
    {
        var raw = System.Text.RegularExpressions.Regex.Replace(e.Value?.ToString() ?? "", @"[^\d]", "");
        if (raw.Length > 10) raw = raw[..10];
        mobileRaw = raw;
        InfoModel.MobilePhoneNumber = raw.Length > 0 ? "+63" + raw : null;
    }

    private static void RestoreAddressParts(string combined, ref string? houseNo, ref string? street, ref string? barangay, ref string? city, ref string? province)
    {
        var parts = combined.Split(", ", 5, StringSplitOptions.None);
        if (parts.Length == 5) { houseNo = parts[0]; street = parts[1]; barangay = parts[2]; city = parts[3]; province = parts[4]; }
        else if (parts.Length == 4) { houseNo = null; street = parts[0]; barangay = parts[1]; city = parts[2]; province = parts[3]; }
        else if (parts.Length >= 1) { street = combined; }
    }

    private static string GetMailingLabel(MailingPreference pref) => pref switch
    {
        MailingPreference.None => "None",
        MailingPreference.PermanentAddress => "Permanent Address",
        MailingPreference.PresentAddress => "Present Address",
        _ => pref.ToString()
    };

    private static string GetCategoryLabel(CustomerCategory cat) => cat switch
    {
        CustomerCategory.LoanBorrower => "Loan Borrower",
        CustomerCategory.LoanCoMaker => "Loan Co-Maker",
        CustomerCategory.Depositor => "Depositor",
        _ => cat.ToString()
    };

    private void ToggleCategory(CustomerCategory cat, bool isChecked)
    {
        if (isChecked && !Model.CustomerCategories.Contains(cat)) Model.CustomerCategories.Add(cat);
        else Model.CustomerCategories.Remove(cat);
    }
}

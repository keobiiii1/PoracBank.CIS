@namespace CIS.Client.Pages.Individual
@using CIS.Client.Services
@using CIS.Assets.DTO
@using CIS.Assets.Enum
@inject IndividualService IndividualService
@inject ProfileService ProfileService
@inject IJSRuntime JS

@* ══════════════════════════════════════════════════════════
   STEP 1 — Personal Information (EditForm A)
══════════════════════════════════════════════════════════ *@
<EditForm Model="Model" OnValidSubmit="OnPersonalValidSubmit" @ref="personalForm">
    <DataAnnotationsValidator />

    <div class="pcs-wrap">

        @* ── Customer Category ── *@
        <div class="pcs-section" id="field-CustomerCategories">
            <div class="pcs-section-header">
                <div class="pcs-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M9 11l3 3L22 4" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" stroke="white" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </div>
                <span class="pcs-section-title">Customer Category</span>
                <span class="pcs-cat-note">Select at least one</span>
            </div>
            <div class="pcs-checkbox-group">
                @foreach (var cat in Enum.GetValues<CustomerCategory>().Where(c => c != CustomerCategory.None))
                {
                    <label class="pcs-checkbox-card @(Model.CustomerCategories.Contains(cat) ? "checked" : "")">
                        <input type="checkbox" id="cat_@cat"
                               checked="@Model.CustomerCategories.Contains(cat)"
                               @onchange="e => ToggleCategory(cat, (bool)e.Value!)" />
                        <div class="pcs-checkbox-tick">
                            <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                                <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </div>
                        <span>@GetCategoryLabel(cat)</span>
                    </label>
                }
            </div>
            <ValidationMessage For="@(() => Model.CustomerCategories)" class="pcs-field-error mt-2" />
        </div>

        @* ── Full Name ── *@
        <div class="pcs-section" id="field-FirstName">
            <div class="pcs-section-header">
                <div class="pcs-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="white" stroke-width="2" stroke-linecap="round" />
                        <circle cx="12" cy="7" r="4" stroke="white" stroke-width="2" />
                    </svg>
                </div>
                <span class="pcs-section-title">Full Name</span>
            </div>
            <div class="pcs-grid pcs-grid-3">
                <div class="pcs-field">
                    <label class="pcs-label">First Name <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="Model.FirstName" class="pcs-input" placeholder="e.g. Juan" />
                    <ValidationMessage For="@(() => Model.FirstName)" class="pcs-field-error" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Middle Name</label>
                    <InputText @bind-Value="Model.MiddleName" class="pcs-input" placeholder="e.g. Santos" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Last Name <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="Model.LastName" class="pcs-input" placeholder="e.g. Dela Cruz" />
                    <ValidationMessage For="@(() => Model.LastName)" class="pcs-field-error" />
                </div>
            </div>
        </div>

        @* ── Personal Details ── *@
        <div class="pcs-section" id="field-Gender">
            <div class="pcs-section-header">
                <div class="pcs-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <span class="pcs-section-title">Personal Details</span>
            </div>
            <div class="pcs-grid pcs-grid-4">
                <div class="pcs-field">
                    <label class="pcs-label">Gender <span class="pcs-req">*</span></label>
                    <InputSelect @bind-Value="Model.Gender" class="pcs-select">
                        @foreach (var g in Enum.GetValues<Gender>()) { <option value="@g">@g</option> }
                    </InputSelect>
                    <ValidationMessage For="@(() => Model.Gender)" class="pcs-field-error" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Citizenship <span class="pcs-req">*</span></label>
                    <InputSelect @bind-Value="Model.Citizenship" class="pcs-select">
                        @foreach (var c in Enum.GetValues<Citizenship>()) { <option value="@c">@c</option> }
                    </InputSelect>
                    <ValidationMessage For="@(() => Model.Citizenship)" class="pcs-field-error" />
                </div>
                @if (Model.Citizenship == Citizenship.Others)
                {
                    <div class="pcs-field pcs-field-reveal">
                        <label class="pcs-label">Specify Citizenship <span class="pcs-req">*</span></label>
                        <InputText @bind-Value="Model.CitizenshipOther" class="pcs-input" placeholder="Specify nationality" />
                        <ValidationMessage For="@(() => Model.CitizenshipOther)" class="pcs-field-error" />
                    </div>
                }
                <div class="pcs-field">
                    <label class="pcs-label">Marital Status <span class="pcs-req">*</span></label>
                    <InputSelect @bind-Value="Model.MaritalStatus" class="pcs-select">
                        @foreach (var m in Enum.GetValues<MaritalStatus>()) { <option value="@m">@m</option> }
                    </InputSelect>
                    <ValidationMessage For="@(() => Model.MaritalStatus)" class="pcs-field-error" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Philippines Resident?</label>
                    <div class="pcs-radio-group">
                        <label class="pcs-radio-card @(Model.IsResident ? "checked" : "")">
                            <input type="radio" name="isResident" checked="@Model.IsResident" @onchange="() => Model.IsResident = true" class="pcs-radio-input" />
                            <div class="pcs-radio-dot"></div><span>Yes</span>
                        </label>
                        <label class="pcs-radio-card @(!Model.IsResident ? "checked" : "")">
                            <input type="radio" name="isResident" checked="@(!Model.IsResident)" @onchange="() => Model.IsResident = false" class="pcs-radio-input" />
                            <div class="pcs-radio-dot"></div><span>No</span>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        @* ── Maiden Name (Female + Married) ── *@
        @if (Model.Gender == Gender.Female && Model.MaritalStatus == MaritalStatus.Married)
        {
            <div class="pcs-section pcs-section-conditional" id="field-MaidenName">
                <div class="pcs-section-header">
                    <div class="pcs-section-icon pcs-icon-blue">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                            <circle cx="12" cy="8" r="4" stroke="white" stroke-width="2" />
                            <path d="M12 12v8M9 18h6" stroke="white" stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </div>
                    <span class="pcs-section-title">Maiden Name Details</span>
                </div>
                <div class="pcs-grid pcs-grid-3">
                    <div class="pcs-field">
                        <label class="pcs-label">Maiden First Name <span class="pcs-req">*</span></label>
                        <InputText @bind-Value="Model.MaidenName" class="pcs-input" placeholder="First name before marriage" />
                        <ValidationMessage For="@(() => Model.MaidenName)" class="pcs-field-error" />
                    </div>
                    <div class="pcs-field">
                        <label class="pcs-label">Maiden Middle Name</label>
                        <InputText @bind-Value="Model.MaidenMiddleName" class="pcs-input" placeholder="Middle name" />
                        <ValidationMessage For="@(() => Model.MaidenMiddleName)" class="pcs-field-error" />
                    </div>
                    <div class="pcs-field">
                        <label class="pcs-label">Maiden Last Name <span class="pcs-req">*</span></label>
                        <InputText @bind-Value="Model.MaidenLastName" class="pcs-input" placeholder="Last name before marriage" />
                        <ValidationMessage For="@(() => Model.MaidenLastName)" class="pcs-field-error" />
                    </div>
                </div>
            </div>
        }

        @* ── Spouse Name (Married or Widowed) ── *@
        @if (Model.MaritalStatus == MaritalStatus.Married || Model.MaritalStatus == MaritalStatus.Widowed)
        {
            <div class="pcs-section pcs-section-conditional" id="field-SpouseName">
                <div class="pcs-section-header">
                    <div class="pcs-section-icon pcs-icon-blue">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="white" stroke-width="2" stroke-linecap="round" />
                            <circle cx="9" cy="7" r="4" stroke="white" stroke-width="2" />
                            <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="white" stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </div>
                    <span class="pcs-section-title">Spouse Full Name</span>
                </div>
                <div class="pcs-grid pcs-grid-3">
                    <div class="pcs-field">
                        <label class="pcs-label">Given Name <span class="pcs-req">*</span></label>
                        <InputText @bind-Value="Model.SpouseGivenName" class="pcs-input" placeholder="Given name" />
                        <ValidationMessage For="@(() => Model.SpouseGivenName)" class="pcs-field-error" />
                    </div>
                    <div class="pcs-field">
                        <label class="pcs-label">Middle Name</label>
                        <InputText @bind-Value="Model.SpouseMiddleName" class="pcs-input" placeholder="Middle name" />
                    </div>
                    <div class="pcs-field">
                        <label class="pcs-label">Last Name <span class="pcs-req">*</span></label>
                        <InputText @bind-Value="Model.SpouseLastName" class="pcs-input" placeholder="Last name" />
                        <ValidationMessage For="@(() => Model.SpouseLastName)" class="pcs-field-error" />
                    </div>
                </div>
            </div>
        }

        @* ── Birth Details ── *@
        <div class="pcs-section" id="field-DateOfBirth">
            <div class="pcs-section-header">
                <div class="pcs-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <rect x="3" y="4" width="18" height="18" rx="2" stroke="white" stroke-width="2" />
                        <path d="M16 2v4M8 2v4M3 10h18" stroke="white" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </div>
                <span class="pcs-section-title">Birth Details</span>
            </div>
            <div class="pcs-grid pcs-grid-3">
                <div class="pcs-field">
                    <label class="pcs-label">Date of Birth <span class="pcs-req">*</span></label>
                    <InputDate @bind-Value="Model.DateOfBirth" class="pcs-input" min="1900-01-01" max="2999-12-31" />
                    <ValidationMessage For="@(() => Model.DateOfBirth)" class="pcs-field-error" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Place of Birth</label>
                    <InputText @bind-Value="Model.PlaceOfBirth" class="pcs-input" placeholder="e.g. Manila" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Country of Origin <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="Model.CountryOfOrigin" class="pcs-input" placeholder="e.g. Philippines" />
                    <ValidationMessage For="@(() => Model.CountryOfOrigin)" class="pcs-field-error" />
                </div>
            </div>
        </div>

        @* ── Mother's Maiden Name ── *@
        <div class="pcs-section" id="field-MotherMaidenGivenName">
            <div class="pcs-section-header">
                <div class="pcs-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="white" stroke-width="2" stroke-linecap="round" />
                        <circle cx="12" cy="7" r="4" stroke="white" stroke-width="2" />
                    </svg>
                </div>
                <span class="pcs-section-title">Mother's Maiden Name</span>
            </div>
            <div class="pcs-grid pcs-grid-3">
                <div class="pcs-field">
                    <label class="pcs-label">Given Name <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="Model.MotherMaidenGivenName" class="pcs-input" placeholder="Mother's Given Name" />
                    <ValidationMessage For="@(() => Model.MotherMaidenGivenName)" class="pcs-field-error" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Middle Name <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="Model.MotherMaidenMiddleName" class="pcs-input" placeholder="Mother's Middle Name" />
                    <ValidationMessage For="@(() => Model.MotherMaidenMiddleName)" class="pcs-field-error" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Last Name <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="Model.MotherMaidenLastName" class="pcs-input" placeholder="Mother's Maiden Last Name" />
                    <ValidationMessage For="@(() => Model.MotherMaidenLastName)" class="pcs-field-error" />
                </div>
            </div>
        </div>

        @* ── Foreign National Toggle ── *@
        <div class="pcs-section">
            <label class="pcs-toggle-row">
                <div class="pcs-toggle-info">
                    <span class="pcs-toggle-label">Foreign National</span>
                    <span class="pcs-toggle-sub">Applicant Holds a Foreign Passport</span>
                </div>
                <div class="pcs-toggle-switch @(Model.IsForeigner ? "on" : "")">
                    <InputCheckbox @bind-Value="Model.IsForeigner" class="pcs-toggle-input" id="chkForeigner" />
                    <div class="pcs-toggle-thumb"></div>
                </div>
            </label>
        </div>

        @if (Model.IsForeigner)
        {
            <div class="pcs-section pcs-section-conditional" id="field-ForeignerDetails">
                <div class="pcs-section-header">
                    <div class="pcs-section-icon">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                    <span class="pcs-section-title">Foreigner Details</span>
                </div>
                <div class="pcs-grid pcs-grid-2">
                    <div class="pcs-field">
                        <label class="pcs-label">Passport ID Number <span class="pcs-req">*</span></label>
                        <InputText @bind-Value="Model.PassportIDNumber" class="pcs-input" placeholder="e.g. A12345678" />
                        <ValidationMessage For="@(() => Model.PassportIDNumber)" class="pcs-field-error" />
                    </div>
                    <div class="pcs-field">
                        <label class="pcs-label">Passport Expiry <span class="pcs-req">*</span></label>
                        <InputDate @bind-Value="Model.PassportExpiry" class="pcs-input" min="@DateTime.Today.ToString("yyyy-MM-dd")" max="2999-12-31" />
                        <ValidationMessage For="@(() => Model.PassportExpiry)" class="pcs-field-error" />
                    </div>
                </div>
                <div class="pcs-divider"></div>
                <div class="pcs-label mb-2">Visa / Permit Classification</div>
                <div class="pcs-checkbox-group">
                    <label class="pcs-checkbox-card @(Model.IsACR ? "checked" : "")">
                        <InputCheckbox @bind-Value="Model.IsACR" class="pcs-toggle-input" />
                        <div class="pcs-checkbox-tick"><svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg></div>
                        <div><div class="pcs-checkbox-main">ACR</div><div class="pcs-checkbox-sub">Alien Certificate of Registration</div></div>
                    </label>
                    <label class="pcs-checkbox-card @(Model.IsSIRV ? "checked" : "")">
                        <InputCheckbox @bind-Value="Model.IsSIRV" class="pcs-toggle-input" />
                        <div class="pcs-checkbox-tick"><svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg></div>
                        <div><div class="pcs-checkbox-main">SIRV</div><div class="pcs-checkbox-sub">Special Investor's Resident Visa</div></div>
                    </label>
                    <label class="pcs-checkbox-card @(Model.IsSRRV ? "checked" : "")">
                        <InputCheckbox @bind-Value="Model.IsSRRV" class="pcs-toggle-input" />
                        <div class="pcs-checkbox-tick"><svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg></div>
                        <div><div class="pcs-checkbox-main">SRRV</div><div class="pcs-checkbox-sub">Special Resident Retiree's Visa</div></div>
                    </label>
                </div>
            </div>
        }

    </div>
</EditForm>

@* ══════════════════════════════════════════════════════════
   STEP 1 — Contact Information (EditForm B)
══════════════════════════════════════════════════════════ *@
<EditForm Model="AddressModel" OnValidSubmit="OnContactValidSubmit" @ref="contactForm">
    <DataAnnotationsValidator />

    <div class="pcs-wrap">

        @* ── Permanent Address ── *@
        <div class="pcs-section" id="field-PermanentAddress">
            <div class="pcs-section-header">
                <div class="pcs-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M9 21V12h6v9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <span class="pcs-section-title">Permanent Address</span>
            </div>
            <div class="pcs-grid pcs-grid-2 mb-3">
                <div class="pcs-field">
                    <label class="pcs-label">House No. / Unit</label>
                    <InputText @bind-Value="permHouseNo" class="pcs-input" placeholder="e.g. 123" @oninput="BuildPermanentAddress" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Street <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="permStreet" class="pcs-input" placeholder="e.g. Rizal St." @oninput="BuildPermanentAddress" />
                </div>
            </div>
            <div class="pcs-grid pcs-grid-3 mb-3">
                <div class="pcs-field">
                    <label class="pcs-label">Barangay <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="permBarangay" class="pcs-input" placeholder="e.g. Brgy. San Jose" @oninput="BuildPermanentAddress" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">City / Municipality <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="permCity" class="pcs-input" placeholder="e.g. Porac" @oninput="BuildPermanentAddress" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Province <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="permProvince" class="pcs-input" placeholder="e.g. Pampanga" @oninput="BuildPermanentAddress" />
                </div>
            </div>
            <div class="pcs-grid pcs-grid-2">
                <div class="pcs-field">
                    <label class="pcs-label">Zip Code <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="AddressModel.PermanentZipCode" class="pcs-input" placeholder="e.g. 2400" />
                    <ValidationMessage For="@(() => AddressModel.PermanentZipCode)" class="pcs-field-error" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Country <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="AddressModel.PermanentCountry" class="pcs-input" placeholder="e.g. Philippines" />
                    <ValidationMessage For="@(() => AddressModel.PermanentCountry)" class="pcs-field-error" />
                </div>
            </div>
            @if (permAddressError != null) { <div class="pcs-field-error mt-2">@permAddressError</div> }
        </div>

        @* ── Same as Permanent Toggle ── *@
        <div class="pcs-section">
            <label class="pcs-toggle-row">
                <div class="pcs-toggle-info">
                    <span class="pcs-toggle-label">Present address is same as permanent</span>
                    <span class="pcs-toggle-sub">Toggle Off to Enter a Different Present Address</span>
                </div>
                <div class="pcs-toggle-switch @(AddressModel.IsPresentSameAsPermanent ? "on" : "")">
                    <input type="checkbox" class="pcs-toggle-input" checked="@AddressModel.IsPresentSameAsPermanent" @onchange="HandleAddressSync" />
                    <div class="pcs-toggle-thumb"></div>
                </div>
            </label>
        </div>

        @* ── Present Address (conditional) ── *@
        @if (!AddressModel.IsPresentSameAsPermanent)
        {
            <div class="pcs-section pcs-section-conditional" id="field-PresentAddress">
                <div class="pcs-section-header">
                    <div class="pcs-section-icon pcs-icon-blue">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <circle cx="12" cy="9" r="2.5" stroke="white" stroke-width="2" />
                        </svg>
                    </div>
                    <span class="pcs-section-title">Present Address</span>
                </div>
                <div class="pcs-grid pcs-grid-2 mb-3">
                    <div class="pcs-field">
                        <label class="pcs-label">House No. / Unit</label>
                        <InputText @bind-Value="presHouseNo" class="pcs-input" placeholder="e.g. 123" @oninput="BuildPresentAddress" />
                    </div>
                    <div class="pcs-field">
                        <label class="pcs-label">Street <span class="pcs-req">*</span></label>
                        <InputText @bind-Value="presStreet" class="pcs-input" placeholder="e.g. Rizal St." @oninput="BuildPresentAddress" />
                    </div>
                </div>
                <div class="pcs-grid pcs-grid-3 mb-3">
                    <div class="pcs-field">
                        <label class="pcs-label">Barangay <span class="pcs-req">*</span></label>
                        <InputText @bind-Value="presBarangay" class="pcs-input" placeholder="e.g. Brgy. San Jose" @oninput="BuildPresentAddress" />
                    </div>
                    <div class="pcs-field">
                        <label class="pcs-label">City / Municipality <span class="pcs-req">*</span></label>
                        <InputText @bind-Value="presCity" class="pcs-input" placeholder="e.g. Porac" @oninput="BuildPresentAddress" />
                    </div>
                    <div class="pcs-field">
                        <label class="pcs-label">Province <span class="pcs-req">*</span></label>
                        <InputText @bind-Value="presProvince" class="pcs-input" placeholder="e.g. Pampanga" @oninput="BuildPresentAddress" />
                    </div>
                </div>
                <div class="pcs-grid pcs-grid-2">
                    <div class="pcs-field">
                        <label class="pcs-label">Zip Code <span class="pcs-req">*</span></label>
                        <InputText @bind-Value="AddressModel.PresentZipCode" class="pcs-input" placeholder="e.g. 2400" />
                        <ValidationMessage For="@(() => AddressModel.PresentZipCode)" class="pcs-field-error" />
                    </div>
                    <div class="pcs-field">
                        <label class="pcs-label">Country <span class="pcs-req">*</span></label>
                        <InputText @bind-Value="AddressModel.PresentCountry" class="pcs-input" placeholder="e.g. Philippines" />
                        <ValidationMessage For="@(() => AddressModel.PresentCountry)" class="pcs-field-error" />
                    </div>
                </div>
                @if (presAddressError != null) { <div class="pcs-field-error mt-2">@presAddressError</div> }
            </div>
        }

        @* ── Contact Details ── *@
        <div class="pcs-section" id="field-MobilePhone">
            <div class="pcs-section-header">
                <div class="pcs-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.36 11.36 0 003.56.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.57a1 1 0 01-.25 1.01l-2.2 2.21z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <span class="pcs-section-title">Contact Details</span>
            </div>
            <div class="pcs-grid pcs-grid-3">
                <div class="pcs-field">
                    <label class="pcs-label">Home Phone No.</label>
                    <InputText @bind-Value="InfoModel.HomePhoneNumber" class="pcs-input" placeholder="e.g. 045-123-4567" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Mobile Phone No. <span class="pcs-req">*</span></label>
                    <div class="pcs-phone-wrap">
                        <span class="pcs-phone-prefix">+63</span>
                        <input class="pcs-input pcs-phone-input" type="tel" maxlength="10" placeholder="9XXXXXXXXX"
                               value="@mobileRaw" @oninput="HandleMobileInput" />
                    </div>
                    <ValidationMessage For="@(() => InfoModel.MobilePhoneNumber)" class="pcs-field-error" />
                </div>
                <div class="pcs-field">
                    <label class="pcs-label">Email Address <span class="pcs-req">*</span></label>
                    <InputText @bind-Value="InfoModel.EmailAddress" class="pcs-input" placeholder="e.g. juan@email.com" />
                    <ValidationMessage For="@(() => InfoModel.EmailAddress)" class="pcs-field-error" />
                </div>
            </div>
        </div>

        @* ── Mailing Preference ── *@
        <div class="pcs-section" id="field-MailingPreference">
            <div class="pcs-section-header">
                <div class="pcs-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <polyline points="22,6 12,13 2,6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <span class="pcs-section-title">Mailing Preference</span>
            </div>
            <div class="pcs-grid pcs-grid-1" style="max-width:320px;">
                <div class="pcs-field">
                    <label class="pcs-label">Send Correspondence To <span class="pcs-req">*</span></label>
                    @if (AddressModel.IsPresentSameAsPermanent)
                    {
                        <input class="pcs-input" value="Permanent Address" disabled />
                    }
                    else
                    {
                        <div class="pcs-select-wrap">
                            <InputSelect @bind-Value="AddressModel.MailingPreference" class="pcs-select">
                                <option value="@MailingPreference.None" disabled>Select</option>
                                @foreach (var pref in Enum.GetValues<MailingPreference>())
                                {
                                    if (pref == MailingPreference.None) continue;
                                    <option value="@pref">@GetMailingLabel(pref)</option>
                                }
                            </InputSelect>
                            <svg class="pcs-select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                        <ValidationMessage For="@(() => AddressModel.MailingPreference)" class="pcs-field-error" />
                    }
                </div>
            </div>
        </div>

        @* ── Footer ── *@
        <div class="pcs-footer">
            <div class="pcs-footer-hint"><span class="pcs-req">*</span>&nbsp;Required fields must be filled before continuing</div>
            <button type="button" class="pcs-btn-next" @onclick="TriggerAll">
                <span>Continue</span>
                <div class="pcs-btn-arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M5 12h14M13 6l6 6-6 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
            </button>
        </div>

    </div>
</EditForm>


@page "/"
@namespace CIS.Client.Pages.AccountSelection
@using CIS.Client.Services
@inject RegistrationStorageService Storage

<div class="selection-container shadow-sm mt-4">
    <div class="header-border mb-5">
        <div class="d-flex align-items-center text-success fw-bold pb-2">
            <i class="bi bi-card-heading me-2"></i> Select Account Type
        </div>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="account-card active" @onclick='() => selectedType = "individual"'>
                
                <div class="icon-circle bg-info-subtle text-info mb-3">
                    <i class="bi bi-person-fill"></i>
                </div>
                <h5 class="fw-bold mb-1">Individual Account</h5>
                <p class="text-muted small">For personal savings, checking, or time deposit accounts</p>          
            </div>
        </div>

        @* <div class="col-md-6">
            <div class="account-card @(selectedType == "business" ? "active" : "")" 
                 @onclick='() => selectedType = "business"'>
                <div class="icon-circle bg-primary-subtle text-primary mb-3">
                    <i class="bi bi-building-fill"></i>
                </div>
                <h5 class="fw-bold mb-1">Business Account</h5>
                <p class="text-muted small">For companies, partnerships, or corporations</p>
                <div class="badge-container">
                    <span class="badge rounded-pill bg-primary-subtle text-primary">
                        <i class="bi bi-star-fill me-1"></i> Enterprise Ready
                    </span>
                </div>
            </div>
        </div> 
        *@
    </div>

    <button class="btn start-btn w-100 py-3 fw-bold shadow" @onclick="HandleStart">
        <i class="bi bi-rocket-takeoff-fill me-2"></i> Start Application <i class="bi bi-arrow-right ms-2"></i>
    </button>
</div>

@code {
    private string selectedType = "individual";

    [Inject] private NavigationManager Nav { get; set; } = default!;

    private async Task HandleStart()
    {
        await Storage.ClearIndividualDraftAsync();
        await Storage.ClearDraftAsync();
        Nav.NavigateTo($"/cis/{selectedType}");
    }
}

<style>
    .selection-container {
        background: white;
        border-radius: 24px;
        padding: 40px;
        border: 1px solid #eef2f7;
        max-width: 700px;
        margin: auto;
    }

    .header-border {
        border-bottom: 2px solid;
        border-image: linear-gradient(to right, #00a859 30%, #2563eb 100%) 1;
    }

    .account-card {
        border: 2px solid transparent;
        border-radius: 20px;
        padding: 40px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        background: linear-gradient(white, white) padding-box, linear-gradient(to right, #00a859, #2563eb) border-box;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
    }

        .account-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        }

    .icon-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
    }

    .start-btn {
        background: linear-gradient(90deg, #00c853 0%, #2962ff 100%);
        color: white;
        border: none;
        border-radius: 50px;
        transition: all 0.2s;
    }

        .start-btn:hover {
            transform: scale(1.01);
            filter: brightness(1.1);
            color: white;
        }
</style>
@page "/cis/individual"
@namespace CIS.Client.Pages.Individual
@using CIS.Client.Services
@inject IndividualService IndividualService
@inject RegistrationStorageService Storage
@inject NavigationManager Nav
@inject IJSRuntime JS

@* ══════════════════════════════════════════
   STEPPER HEADER  (hidden on success screen)
══════════════════════════════════════════ *@
@if (CurrentStep < 8)
{
    <div class="ist-shell">

        @* ── Top bar: brand + progress ── *@
        <div class="ist-topbar">
            <div class="ist-brand">
                <div class="ist-brand-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M12 12C14.76 12 17 9.76 17 7s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5z" fill="white" />
                        <path d="M12 14c-4.42 0-8 3.58-8 8h16c0-4.42-3.58-8-8-8z" fill="white" />
                    </svg>
                </div>
                <div>
                    <div class="ist-brand-name">Individual Account</div>
                    <div class="ist-brand-sub">New Registration</div>
                </div>
            </div>
            <div class="ist-progress-info">
                <div class="ist-step-fraction">
                    <span class="ist-step-current">@CurrentStep</span>
                    <span class="ist-step-sep">/</span>
                    <span class="ist-step-total">@TotalSteps</span>
                </div>
                <div class="ist-progress-bar-wrap">
                    <div class="ist-progress-bar-fill" style="width: @(CurrentStep * 100 / TotalSteps)%"></div>
                </div>
                <div class="ist-progress-pct">@(CurrentStep * 100 / TotalSteps)%</div>
            </div>
        </div>

        @* ── Step track (full-width, flex connectors) ── *@
        <div class="ist-track-wrap">
            <div class="ist-track">
                @for (int i = 1; i <= TotalSteps; i++)
                {
                    var idx = i;
                    var state = idx < CurrentStep ? "done"
                              : idx == CurrentStep ? "active"
                              : "todo";
                    var label = StepLabels[idx - 1];

                    <div class="ist-step ist-step-@state @(idx < CurrentStep ? "ist-step-clickable" : "")"
                         @onclick="() => GoToStep(idx)">
                        <div class="ist-step-circle">
                            @if (state == "done")
                            {
                                <svg width="11" height="11" viewBox="0 0 12 12" fill="none">
                                    <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2"
                                          stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            }
                            else
                            {
                                <span>@idx</span>
                            }
                        </div>
                        <span class="ist-step-label">@label</span>
                    </div>

                    @if (idx < TotalSteps)
                    {
                        <div class="ist-connector @(idx < CurrentStep ? "done" : "")"></div>
                    }
                }
            </div>
        </div>

        @* ── Active step name banner ── *@
        @if (CurrentStep <= StepLabels.Length)
        {
            <div class="ist-current-banner">
                <div class="ist-banner-dot"></div>
                <span>@StepLabels[CurrentStep - 1]</span>
            </div>
        }

    </div>
}

@* ══════════════════════════════════════════════════════════
   BUSINESS & BENEFICIARY SELECTION MODAL
══════════════════════════════════════════════════════════ *@
@if (showSelectionModal)
{
    <div class="bbm-overlay">
        <div class="bbm-dialog">

            <div class="bbm-header">
                <div class="bbm-header-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                        <path d="M9 11l3 3L22 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <div>
                    <div class="bbm-title">Additional Information</div>
                    <div class="bbm-subtitle">Select which sections apply to you</div>
                </div>
            </div>

            <div class="bbm-body">
                <p class="bbm-desc">Before proceeding, let us know if any of the following apply to your account application.</p>

                @* ── Business question ── *@
                <div class="bbm-option @(modalApplyBusiness == true ? "bbm-option-yes" : modalApplyBusiness == false ? "bbm-option-no" : "")">
                    <div class="bbm-option-info">
                        <div class="bbm-option-icon @(modalApplyBusiness == true ? "bbm-option-icon-active" : "")">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                <path d="M9 22V12h6v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </div>
                        <div>
                            <div class="bbm-option-label">Applying with Business?</div>
                            <div class="bbm-option-sub">Include business information &amp; account contact details</div>
                        </div>
                    </div>
                    <div class="bbm-toggle-wrap" @onclick="@(() => modalApplyBusiness = !(modalApplyBusiness ?? false))">
                        <div class="bbm-toggle @(modalApplyBusiness == true ? "bbm-toggle-on" : "")">
                            <div class="bbm-toggle-thumb"></div>
                        </div>
                        <span class="bbm-toggle-label-text @(modalApplyBusiness == true ? "bbm-toggle-label-on" : "")">
                            @(modalApplyBusiness == true ? "Yes" : "No")
                        </span>
                    </div>
                </div>

                @* ── Beneficiary question ── *@
                <div class="bbm-option @(modalApplyBeneficiary == true ? "bbm-option-yes" : modalApplyBeneficiary == false ? "bbm-option-no" : "")">
                    <div class="bbm-option-info">
                        <div class="bbm-option-icon @(modalApplyBeneficiary == true ? "bbm-option-icon-active" : "")">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                                <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2" />
                            </svg>
                        </div>
                        <div>
                            <div class="bbm-option-label">Applying with Beneficiary?</div>
                            <div class="bbm-option-sub">Include beneficiary &amp; trust information</div>
                        </div>
                    </div>
                    <div class="bbm-toggle-wrap" @onclick="@(() => modalApplyBeneficiary = !(modalApplyBeneficiary ?? false))">
                        <div class="bbm-toggle @(modalApplyBeneficiary == true ? "bbm-toggle-on" : "")">
                            <div class="bbm-toggle-thumb"></div>
                        </div>
                        <span class="bbm-toggle-label-text @(modalApplyBeneficiary == true ? "bbm-toggle-label-on" : "")">
                            @(modalApplyBeneficiary == true ? "Yes" : "No")
                        </span>
                    </div>
                </div>

            </div>

            <div class="bbm-footer">
                <button type="button" class="bbm-btn-back" @onclick="CloseModal">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Back
                </button>
                <button type="button" class="bbm-btn-confirm" @onclick="ConfirmModal">
                    Continue
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M5 12h14M13 6l6 6-6 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
            </div>

        </div>
    </div>
}

@* ══════════════════════════════════════════
   STEP CONTENT
══════════════════════════════════════════ *@
<div class="ist-content">
    @if (submitError != null)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-exclamation-triangle-fill"></i>
            @submitError
        </div>
    }

    @if (CurrentStep == 1)
    {
        customerModel.EntityType = EntityType.Individual;
        <BasicInformation @bind-Customer="customerModel"
                          @bind-Model="personalModel"
                          @bind-ForeignerModel="foreignerModel"
                          AddressModel="addressModel"
                          InfoModel="personalModel"
                          @bind-ContactModel="contactModel"
                          OnNext="HandleNext" />
    }
    else if (CurrentStep == 2)
    {
        <EmploymentInformation EmploymentModel="employmentModel"
                               InfoModel="personalModel"
                               CustomerId="customerModel.CustomerID"
                               @bind-BusintModel="busintModel"
                               @bind-GovRelModel="govrelModel"
                               @bind-AccPurpModel="accpurpModel"
                               OnNext="HandleNext"
                               OnBack="PrevStep" />
    }
    else if (CurrentStep == 3)
    {
        <IdentificationInformation IdModel="identificationModel"
                                   CustomerId="customerModel.CustomerID"
                                   OnNext="HandleNext"
                                   OnBack="PrevStep" />
    }
    else if (CurrentStep == 4)
    {
        <Business_Beneficiary @bind-BusinessModel="businessInfoModel"
                              AddressModel="addressModel"
                              @bind-AccountContactModel="accountContactModel"
                              @bind-BeneficiaryModel="beneficiaryModel"
                              ShowBusiness="showBusinessSection"
                              ShowBeneficiary="showBeneficiarySection"
                              OnNext="HandleNext"
                              OnBack="PrevStep" />
    }
    else if (CurrentStep == 5)
    {
        <ClientAcknowledgement @bind-AcknowledgementModel="acknowledgementModel"
                               OnNext="HandleNext"
                               OnBack="PrevStep" />
    }
    else if (CurrentStep == 6)
    {
        <BankReviewInfo @bind-ReviewModel="bankReviewModel"
                        OnNext="HandleNext"
                        OnBack="PrevStep" />
    }
    else if (CurrentStep == 7)
    {
        <Review_Submit Customer="customerModel"
                       Personal="personalModel"
                       Address="addressModel"
                       Identification="identificationModel"
                       Employment="employmentModel"
                       BusinessInfo="businessInfoModel"
                       AccountContact="accountContactModel"
                       Beneficiary="beneficiaryModel"
                       Acknowledgement="acknowledgementModel"
                       BankReview="bankReviewModel"
                       OnBack="PrevStep"
                       OnSubmit="HandleSubmit" />
    }
    else if (CurrentStep == 8)
    {
        <RegistrationSuccess CustomerName="@($"{personalModel.FirstName} {personalModel.LastName}")"
                             CustomerId="@customerModel.CustomerID"
                             CIDNumber="@customerModel.CIDNumber"
                             RegistrationType="Individual"
                             OnReset="ResetStepper" />
    }
</div>

@code {
    private int CurrentStep = 1;
    private const int TotalSteps = 7;

    private readonly HashSet<int> validatedSteps = new();

    // ── Business & Beneficiary modal state ────────────────────────
    private bool showSelectionModal = false;
    private bool? modalApplyBusiness = null;
    private bool? modalApplyBeneficiary = null;
    private bool modalValidationError = false;
    private bool showBusinessSection = false;
    private bool showBeneficiarySection = false;

    private static readonly string[] StepLabels =
    [
        "Personal & Contact", "Employment & Account",
        "Identification", "Business & Beneficiary",
        "Acknowledgement", "Bank Use Only", "Review"
    ];

    private CustomerDTO.PageModel customerModel = new();
    private IndividualInfoDTO.PageModel personalModel = new();
    private AddressDTO.PageModel addressModel = new();
    private IndividualIdentificationDTO.PageModel identificationModel = new();
    private IndividualEmploymentDTO.PageModel employmentModel = new();
    private IndividualFamilyDTO.PageModel familyModel = new();
    private ContactDTO.PageModel contactModel = new();
    private IndividualForeignerDTO.PageModel foreignerModel = new();
    private BusinessInterestDTO.PageModel busintModel = new();
    private GovernmentRelationDTO.PageModel govrelModel = new();
    private AccountPurposeDTO.PageModel accpurpModel = new();
    private BusinessInfoDTO.PageModel businessInfoModel = new();
    private BusinessInfoDTO.PageModel accountContactModel = new();
    private BeneficiaryDTO.PageModel beneficiaryModel = new();
    private ClientAcknowledgementDTO.PageModel acknowledgementModel = new();
    private BankReviewDTO.PageModel bankReviewModel = new();

    protected override async Task OnInitializedAsync()
    {
        var draft = await Storage.GetIndividualDraftAsync();
        if (draft != null)
        {
            customerModel = draft.Customer ?? new();
            personalModel = draft.Individual ?? new();
            addressModel = draft.Address ?? new();
            identificationModel = draft.Identification ?? new();
            employmentModel = draft.Employment ?? new();
            familyModel = draft.Family ?? new();
            contactModel = draft.Contact ?? new();
            foreignerModel = draft.Foreigner ?? new();
            busintModel = draft.BusinessInterest ?? new();
            govrelModel = draft.GovernmentRelation ?? new();
            accpurpModel = draft.AccountPurpose ?? new();
            businessInfoModel = draft.BusinessInfo ?? new();
            accountContactModel = draft.AccountContact ?? new();
            beneficiaryModel = draft.Beneficiary ?? new();
            acknowledgementModel = draft.Acknowledgement ?? new();
            bankReviewModel = draft.BankReview ?? new();
            CurrentStep = draft.CurrentStep;
            for (int s = 1; s < draft.CurrentStep; s++) validatedSteps.Add(s);
        }
    }

    private async Task HandleNext()
    {
        // After Identification (step 3), show the Business & Beneficiary selection modal
        if (CurrentStep == 3)
        {
            showSelectionModal = true;
            modalValidationError = false;
            StateHasChanged();
            return;
        }

        validatedSteps.Add(CurrentStep);
        CurrentStep++;
        await Storage.SaveIndividualDraftAsync(
            customerModel, personalModel, addressModel, identificationModel,
            employmentModel, familyModel, contactModel, foreignerModel,
            busintModel, govrelModel, accpurpModel,
            businessInfoModel, accountContactModel, beneficiaryModel,
            acknowledgementModel, bankReviewModel, CurrentStep
        );
        StateHasChanged();
        await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    private void CloseModal()
    {
        showSelectionModal = false;
        modalApplyBusiness = null;
        modalApplyBeneficiary = null;
        modalValidationError = false;
        StateHasChanged();
    }

    private async Task ConfirmModal()
    {
        // Treat null (untouched) as false — toggles are off by default
        showSelectionModal = false;
        showBusinessSection = modalApplyBusiness == true;
        showBeneficiarySection = modalApplyBeneficiary == true;

        validatedSteps.Add(CurrentStep);

        // If neither section applies, skip step 4 and go straight to Acknowledgement (step 5)
        if (!showBusinessSection && !showBeneficiarySection)
        {
            CurrentStep = 5;
        }
        else
        {
            CurrentStep = 4;
        }

        await Storage.SaveIndividualDraftAsync(
            customerModel, personalModel, addressModel, identificationModel,
            employmentModel, familyModel, contactModel, foreignerModel,
            busintModel, govrelModel, accpurpModel,
            businessInfoModel, accountContactModel, beneficiaryModel,
            acknowledgementModel, bankReviewModel, CurrentStep
        );
        StateHasChanged();
        await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    private string? submitError;

    private async Task HandleSubmit()
    {
        submitError = null;
        var request = Storage.BuildRegistrationRequest(
            customerModel, personalModel, addressModel, identificationModel,
            employmentModel, familyModel, contactModel, foreignerModel,
            busintModel, govrelModel, accpurpModel,
            businessInfoModel, accountContactModel, beneficiaryModel,
            acknowledgementModel, bankReviewModel
        );
        var (newCustomerId, cidNumber) = await IndividualService.FinalizeRegistrationAsync(request);
        if (newCustomerId > 0)
        {
            customerModel.CustomerID = newCustomerId;
            customerModel.CIDNumber = cidNumber;
            CurrentStep = 8;
            await Storage.ClearIndividualDraftAsync();
            StateHasChanged();
        }
        else
        {
            submitError = "Failed to finalize registration. Please try again.";
        }
    }

    private void GoToStep(int step)
    {
        if (step >= 1 && step < CurrentStep && validatedSteps.Contains(step))
        { CurrentStep = step; StateHasChanged(); }
    }

    private void PrevStep()
    {
        if (CurrentStep > 1)
        {
            // If both sections were skipped and we're on step 5, go back to step 3
            if (CurrentStep == 5 && !showBusinessSection && !showBeneficiarySection)
                CurrentStep = 3;
            else
                CurrentStep--;
            StateHasChanged();
        }
    }

    private async Task ResetStepper()
    {
        await Storage.ClearIndividualDraftAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }
}

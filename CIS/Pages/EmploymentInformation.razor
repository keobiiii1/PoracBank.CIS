@namespace CIS.Client.Pages.Individual
@using System.ComponentModel
@using System.Reflection
@using CIS.Assets.DTO
@using CIS.Assets.Enum
@using CIS.Client.Services
@using static CIS.Assets.DTO.IndividualInfoDTO.PageModel
@inject IndividualService IndividualService
@inject IJSRuntime JS

@* ══════════════════════════════════════════════════════════
   STEP 3 — Employment Information (EditForm)
══════════════════════════════════════════════════════════ *@
<EditForm Model="EmploymentModel" OnValidSubmit="OnEmploymentValidSubmit" @ref="employmentForm">
    <DataAnnotationsValidator />

    <div class="eas-wrap">

        @* ── Employment Details ── *@
        <div class="eas-section" id="field-EmploymentStatus">
            <div class="eas-section-header">
                <div class="eas-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <rect x="2" y="7" width="20" height="14" rx="2" stroke="white" stroke-width="2" />
                        <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" stroke="white" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </div>
                <span class="eas-section-title">Employment Details</span>
            </div>
            <div class="eas-grid eas-grid-2">
                <div class="eas-field">
                    <label class="eas-label">Employment Status <span class="eas-req">*</span></label>
                    <InputSelect @bind-Value="EmploymentModel.EmploymentStatus" class="eas-select">
                        <option value="@EmploymentStatus.None" disabled>Select Employment Status</option>
                        @foreach (EmploymentStatus s in Enum.GetValues<EmploymentStatus>())
                        {
                            if (s == EmploymentStatus.None) continue;
                            <option value="@s">@GetEnumDescription(s)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => EmploymentModel.EmploymentStatus)" class="eas-field-error" />
                    @if (EmploymentModel.EmploymentStatus == EmploymentStatus.Others)
                    {
                        <InputText @bind-Value="EmploymentModel.EmploymentStatusOther" class="eas-input mt-2" placeholder="Please specify status" />
                        <ValidationMessage For="@(() => EmploymentModel.EmploymentStatusOther)" class="eas-field-error" />
                    }
                </div>
                <div class="eas-field">
                    <label class="eas-label">Type of Employment <span class="eas-req">*</span></label>
                    <InputSelect @bind-Value="EmploymentModel.TypeOfEmployment" class="eas-select">
                        <option value="@TypeOfEmployment.None" disabled>Select Type of Employment</option>
                        @foreach (TypeOfEmployment t in Enum.GetValues<TypeOfEmployment>())
                        {
                            if (t == TypeOfEmployment.None) continue;
                            <option value="@t">@GetEnumDescription(t)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => EmploymentModel.TypeOfEmployment)" class="eas-field-error" />
                    @if (EmploymentModel.TypeOfEmployment == TypeOfEmployment.Others)
                    {
                        <InputText @bind-Value="EmploymentModel.TypeOfEmploymentOther" class="eas-input mt-2" placeholder="Specify employment type" />
                        <ValidationMessage For="@(() => EmploymentModel.TypeOfEmploymentOther)" class="eas-field-error" />
                    }
                    @if (EmploymentModel.TypeOfEmployment == TypeOfEmployment.OFW)
                    {
                        <InputText @bind-Value="EmploymentModel.OFWCountry" class="eas-input mt-2" placeholder="Country of Employment" />
                        <ValidationMessage For="@(() => EmploymentModel.OFWCountry)" class="eas-field-error" />
                    }
                </div>
                <div class="eas-field">
                    <label class="eas-label">Nature of Work <span class="eas-req">*</span></label>
                    <InputText @bind-Value="EmploymentModel.NatureOfWork" class="eas-input" placeholder="e.g. Office-based, Field Work" />
                    <ValidationMessage For="@(() => EmploymentModel.NatureOfWork)" class="eas-field-error" />
                </div>
                <div class="eas-field">
                    <label class="eas-label">Educational Attainment</label>
                    <InputText @bind-Value="EmploymentModel.EducationalAttainment" class="eas-input" placeholder="e.g. College Graduate" />
                </div>
                <div class="eas-field">
                    <label class="eas-label">Average Monthly Income <span class="eas-req">*</span></label>
                    <InputSelect @bind-Value="EmploymentModel.AverageMonthlyIncome" class="eas-select">
                        <option value="@AverageMonthlyIncome.None" disabled>Select Average Monthly Income</option>
                        @foreach (AverageMonthlyIncome a in Enum.GetValues<AverageMonthlyIncome>())
                        {
                            if (a == AverageMonthlyIncome.None) continue;
                            <option value="@a">@GetEnumDescription(a)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => EmploymentModel.AverageMonthlyIncome)" class="eas-field-error" />
                </div>
                <div class="eas-field">
                    <label class="eas-label">Source of Funds <span class="eas-req">*</span></label>
                    <InputSelect @bind-Value="EmploymentModel.SourceOfFunds" class="eas-select">
                        <option value="@SourceOfFunds.None" disabled>Select Source of Funds</option>
                        @foreach (SourceOfFunds sf in Enum.GetValues<SourceOfFunds>())
                        {
                            if (sf == SourceOfFunds.None) continue;
                            <option value="@sf">@GetEnumDescription(sf)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => EmploymentModel.SourceOfFunds)" class="eas-field-error" />
                    @if (EmploymentModel.SourceOfFunds == SourceOfFunds.Others)
                    {
                        <InputText @bind-Value="EmploymentModel.SourceOfFundsOther" class="eas-input mt-2" placeholder="Specify source of funds" />
                        <ValidationMessage For="@(() => EmploymentModel.SourceOfFundsOther)" class="eas-field-error" />
                    }
                </div>
            </div>
        </div>

        @* ── Employer / Business Details ── *@
        <div class="eas-section" id="field-NameOfEmployer">
            <div class="eas-section-header">
                <div class="eas-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M9 22V12h6v10" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <span class="eas-section-title">Employer / Business Details</span>
            </div>
            <div class="eas-grid eas-grid-2">
                <div class="eas-field">
                    <label class="eas-label">Name of Employer <span class="eas-req">*</span></label>
                    <InputText @bind-Value="EmploymentModel.NameOfEmployer" class="eas-input" placeholder="Company or employer name" />
                    <ValidationMessage For="@(() => EmploymentModel.NameOfEmployer)" class="eas-field-error" />
                </div>
                <div class="eas-field">
                    <label class="eas-label">Position / Rank <span class="eas-req">*</span></label>
                    <InputText @bind-Value="EmploymentModel.PositionRank" class="eas-input" placeholder="e.g. Manager, Clerk" />
                    <ValidationMessage For="@(() => EmploymentModel.PositionRank)" class="eas-field-error" />
                </div>
            </div>
            <div class="eas-divider"></div>
            <div class="eas-subsection-label">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="2" /></svg>
                Employer's Address <span class="eas-req">*</span>
            </div>
            <div class="eas-grid eas-grid-4">
                <div class="eas-field"><label class="eas-label">Building No.</label><InputText @bind-Value="EmploymentModel.EmployerBuildingNo" class="eas-input" placeholder="Bldg. No." /></div>
                <div class="eas-field"><label class="eas-label">Street <span class="eas-req">*</span></label><InputText @bind-Value="EmploymentModel.EmployerStreet" class="eas-input" placeholder="Street name" /><ValidationMessage For="@(() => EmploymentModel.EmployerStreet)" class="eas-field-error" /></div>
                <div class="eas-field"><label class="eas-label">Brgy / District <span class="eas-req">*</span></label><InputText @bind-Value="EmploymentModel.EmployerBrgyDistrict" class="eas-input" placeholder="Barangay" /><ValidationMessage For="@(() => EmploymentModel.EmployerBrgyDistrict)" class="eas-field-error" /></div>
                <div class="eas-field"><label class="eas-label">City / Town <span class="eas-req">*</span></label><InputText @bind-Value="EmploymentModel.EmployerCityTown" class="eas-input" placeholder="City or town" /><ValidationMessage For="@(() => EmploymentModel.EmployerCityTown)" class="eas-field-error" /></div>
            </div>
            <div class="eas-divider"></div>
            <div class="eas-subsection-label">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                Contact Details of Employer <span class="eas-req">*</span>
            </div>
            <div class="eas-grid eas-grid-2">
                <div class="eas-field">
                    <label class="eas-label">Phone No. <span class="eas-req">*</span></label>
                    <div class="eas-phone-wrap">
                        <span class="eas-phone-prefix">+63</span>
                        <input class="eas-input eas-phone-input" type="tel" inputmode="numeric" maxlength="10"
                               placeholder="9XXXXXXXXX"
                               value="@employerPhoneRaw"
                               @oninput="HandleEmployerPhoneInput" />
                    </div>
                    @if (employerPhoneError != null)
                    {
                        <span class="eas-field-error">@employerPhoneError</span>
                    }
                    else
                    {
                        <ValidationMessage For="@(() => EmploymentModel.EmployerPhoneNumber)" class="eas-field-error" />
                    }
                </div>
                <div class="eas-field"><label class="eas-label">Email Address <span class="eas-req">*</span></label><InputText @bind-Value="EmploymentModel.EmployerEmailAddress" class="eas-input" placeholder="e.g. hr@company.com" /><ValidationMessage For="@(() => EmploymentModel.EmployerEmailAddress)" class="eas-field-error" /></div>
            </div>
        </div>

    </div>
</EditForm>

@* ══════════════════════════════════════════════════════════
   STEP 3 — Account & Business (manual validation, no EditForm)
══════════════════════════════════════════════════════════ *@
<div class="eas-wrap">

    @* ── Account Purpose & Products ── *@
    <div class="eas-section" style="margin-top: 8px;" id="field-AccountPurpose">
        <div class="eas-section-header">
            <div class="eas-section-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <span class="eas-section-title">Account Purpose &amp; Products</span>
        </div>
        <div class="eas-grid eas-grid-2">
            <div class="eas-field">
                <label class="eas-label">Purpose of Account <span class="eas-req">*</span></label>
                <div class="eas-select-wrap">
                    <InputSelect @bind-Value="InfoModel.AccountPurpose" class="@(abShowErrors && InfoModel.AccountPurpose == PurposeOfAccount.None ? "eas-select eas-invalid" : "eas-select")">
                        <option value="@PurposeOfAccount.None" disabled>Select Purpose of Account</option>
                        @foreach (var val in Enum.GetValues<PurposeOfAccount>())
                        {
                            if (val == PurposeOfAccount.None) continue;
                            <option value="@val">@FormatEnum(val.ToString())</option>
                        }
                    </InputSelect>
                    <svg class="eas-select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </div>
                @if (abShowErrors && InfoModel.AccountPurpose == PurposeOfAccount.None)
                {
                    <span class="eas-field-error">Purpose of account is required.</span>
                }
                @if (InfoModel.AccountPurpose == PurposeOfAccount.Others)
                {
                    <InputText @bind-Value="InfoModel.AccountPurposeOther" class="eas-input mt-2" placeholder="Specify purpose" />
                    @if (abShowErrors && string.IsNullOrWhiteSpace(InfoModel.AccountPurposeOther))
                    {
                        <span class="eas-field-error">Please specify the purpose.</span>
                    }
                }
            </div>
            <div class="eas-field">
                <label class="eas-label">Products to be Availed <span class="eas-req">*</span></label>
                <div class="eas-select-wrap">
                    <InputSelect @bind-Value="InfoModel.ProductsAvailed" class="@(abShowErrors && string.IsNullOrWhiteSpace(InfoModel.ProductsAvailed) ? "eas-select eas-invalid" : "eas-select")">
                        <option value="" disabled selected>Select Products to be Availed</option>
                        <option value="Savings">Savings</option>
                        <option value="Checking">Checking</option>
                        <option value="Loan">Loan</option>
                        <option value="Others">Others</option>
                    </InputSelect>
                    <svg class="eas-select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </div>
                @if (abShowErrors && string.IsNullOrWhiteSpace(InfoModel.ProductsAvailed))
                {
                    <span class="eas-field-error">Products to be availed is required.</span>
                }
                @if (InfoModel.ProductsAvailed == "Others")
                {
                    <InputText @bind-Value="InfoModel.ProductsAvailedOther" class="eas-input mt-2" placeholder="Specify product" />
                    @if (abShowErrors && string.IsNullOrWhiteSpace(InfoModel.ProductsAvailedOther))
                    {
                        <span class="eas-field-error">Please specify the product.</span>
                    }
                }
            </div>
        </div>
    </div>

    @* ── Business Interests ── *@
    <div class="eas-section" id="field-BusinessInterests">
        <div class="eas-section-header">
            <div class="eas-section-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M9 22V12h6v10" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <span class="eas-section-title">Business Interests</span>
            <button type="button" class="eas-add-btn" @onclick="AddBusiness">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" /></svg>
                Add Business
            </button>
        </div>
        @if (InfoModel.BusinessInterests.Count == 0)
        {
            <div class="eas-empty-hint">No business interests added. Click "Add Business" to add one.</div>
        }
        else
        {
            <div class="eas-list-header eas-grid-biz">
                <span class="eas-list-col-label">Business Name <span class="eas-req">*</span></span>
                <span class="eas-list-col-label">% Ownership <span class="eas-req">*</span></span>
                <span></span>
            </div>
            @for (int i = 0; i < InfoModel.BusinessInterests.Count; i++)
            {
                var idx = i;
                var biz = InfoModel.BusinessInterests[idx];
                <div class="eas-list-row eas-grid-biz">
                    <div class="eas-field">
                        <InputText @bind-Value="biz.BusinessName" class="@(abShowErrors && string.IsNullOrWhiteSpace(biz.BusinessName) ? "eas-input eas-invalid" : "eas-input")" placeholder="e.g. Dela Cruz Trading" />
                        @if (abShowErrors && string.IsNullOrWhiteSpace(biz.BusinessName))
                        {
                            <span class="eas-field-error">Business name is required.</span>
                        }
                    </div>
                    <div class="eas-field">
                        <input type="text" class="form-control" placeholder="0.00–100" inputmode="decimal" maxlength="6" value="@biz.OwnershipPercentage" @oninput="(e) => HandleOwnershipInput(e, biz, idx)" />
                        @if (ownershipInvalidRows.Contains(idx))
                        {
                            <span class="eas-field-error">Please enter a valid Ownership Percentage (0.00–100).</span>
                        }
                        else if (abShowErrors && biz.OwnershipPercentage == null)
                        {
                            <span class="eas-field-error">Ownership % is required.</span>
                        }
                    </div>
                    <button type="button" class="eas-remove-btn" @onclick="() => RemoveBusiness(idx)" title="Remove"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" /></svg></button>
                </div>
            }
        }
    </div>

    @* ── PEP: Government Official ── *@
    <div class="eas-section" id="field-GovOfficial">
        <label class="eas-toggle-row">
            <div class="eas-toggle-info">
                <span class="eas-toggle-label">Past / Present Government Official?</span>
                <span class="eas-toggle-sub">Politically Exposed Person (PEP) declaration</span>
            </div>
            <div class="eas-toggle-switch @(InfoModel.IsGovOfficial ? "on" : "")">
                <InputCheckbox @bind-Value="InfoModel.IsGovOfficial" class="eas-toggle-input" />
                <div class="eas-toggle-thumb"></div>
            </div>
        </label>
        @if (InfoModel.IsGovOfficial)
        {
            <div class="eas-divider"></div>
            <div class="eas-section-header" style="margin-bottom:12px;">
                <span class="eas-section-title" style="font-size:0.68rem;">Official Positions</span>
                <button type="button" class="eas-add-btn" @onclick="AddGovPosition"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" /></svg> Add Position</button>
            </div>
            @if (InfoModel.GovOfficialPositions.Count == 0)
            {
                <div class="eas-empty-hint">No positions added.</div>
            }
            else
            {
                <div class="eas-list-header eas-grid-pep">
                    <span class="eas-list-col-label">Highest Position <span class="eas-req">*</span></span>
                    <span class="eas-list-col-label">Period Covered <span class="eas-req">*</span></span>
                    <span></span>
                </div>
                @for (int i = 0; i < InfoModel.GovOfficialPositions.Count; i++)
                {
                    var idx = i;
                    <div class="eas-list-row eas-grid-pep">
                        <div class="eas-field">
                            <InputText @bind-Value="InfoModel.GovOfficialPositions[idx].Position" class="@(abShowErrors && string.IsNullOrWhiteSpace(InfoModel.GovOfficialPositions[idx].Position) ? "eas-input eas-invalid" : "eas-input")" placeholder="e.g. Barangay Captain" />
                            @if (abShowErrors && string.IsNullOrWhiteSpace(InfoModel.GovOfficialPositions[idx].Position))
                            {
                                <span class="eas-field-error">Position is required.</span>
                            }
                        </div>
                        <div class="eas-field">
                            <InputText @bind-Value="InfoModel.GovOfficialPositions[idx].Period" class="@(abShowErrors && string.IsNullOrWhiteSpace(InfoModel.GovOfficialPositions[idx].Period) ? "eas-input eas-invalid" : "eas-input")" placeholder="e.g. 2018–2022" />
                            @if (abShowErrors && string.IsNullOrWhiteSpace(InfoModel.GovOfficialPositions[idx].Period))
                            {
                                <span class="eas-field-error">Period is required.</span>
                            }
                        </div>
                        <button type="button" class="eas-remove-btn" @onclick="() => RemoveGovPosition(idx)" title="Remove"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" /></svg></button>
                    </div>
                }
            }
        }
    </div>

    @* ── Relative in Government ── *@
    <div class="eas-section" id="field-GovRelative">
        <label class="eas-toggle-row">
            <div class="eas-toggle-info">
                <span class="eas-toggle-label">Relative who is a Government Official?</span>
                <span class="eas-toggle-sub">(Within the 1st Degree of Consanguinity and Affinity)</span>
            </div>
            <div class="eas-toggle-switch @(InfoModel.HasGovRelative ? "on" : "")">
                <InputCheckbox @bind-Value="InfoModel.HasGovRelative" class="eas-toggle-input" />
                <div class="eas-toggle-thumb"></div>
            </div>
        </label>
        @if (InfoModel.HasGovRelative)
        {
            <div class="eas-divider"></div>
            <div class="eas-section-header" style="margin-bottom:12px;">
                <span class="eas-section-title" style="font-size:0.68rem;">Relative Details</span>
                <button type="button" class="eas-add-btn" @onclick="AddGovRelative"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" /></svg> Add Relative</button>
            </div>
            @if (InfoModel.GovRelatives.Count == 0)
            {
                <div class="eas-empty-hint">No relatives added.</div>
            }
            else
            {
                @for (int i = 0; i < InfoModel.GovRelatives.Count; i++)
                {
                    var idx = i;
                    var rel = InfoModel.GovRelatives[idx];
                    <div class="eas-rel-card">
                        <div class="eas-rel-card-header">
                            <span class="eas-rel-card-num">Relative #@(idx + 1)</span>
                            <button type="button" class="eas-remove-btn" @onclick="() => RemoveGovRelative(idx)" title="Remove"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" /></svg></button>
                        </div>
                        <div class="eas-rel-card-grid">
                            <div class="eas-field">
                                <label class="eas-label">Full Name <span class="eas-req">*</span></label>
                                <InputText @bind-Value="rel.Name" class="@(abShowErrors && string.IsNullOrWhiteSpace(rel.Name) ? "eas-input eas-invalid" : "eas-input")" placeholder="Full name" />
                                @if (abShowErrors && string.IsNullOrWhiteSpace(rel.Name))
                                {
                                    <span class="eas-field-error">Full name is required.</span>
                                }
                            </div>
                            <div class="eas-field">
                                <label class="eas-label">Relationship <span class="eas-req">*</span></label>
                                <InputText @bind-Value="rel.Relationship" class="@(abShowErrors && string.IsNullOrWhiteSpace(rel.Relationship) ? "eas-input eas-invalid" : "eas-input")" placeholder="e.g. Father, Spouse" />
                                @if (abShowErrors && string.IsNullOrWhiteSpace(rel.Relationship))
                                {
                                    <span class="eas-field-error">Relationship is required.</span>
                                }
                            </div>
                            <div class="eas-field">
                                <label class="eas-label">Position <span class="eas-req">*</span></label>
                                <InputText @bind-Value="rel.Position" class="@(abShowErrors && string.IsNullOrWhiteSpace(rel.Position) ? "eas-input eas-invalid" : "eas-input")" placeholder="e.g. Mayor" />
                                @if (abShowErrors && string.IsNullOrWhiteSpace(rel.Position))
                                {
                                    <span class="eas-field-error">Position is required.</span>
                                }
                            </div>
                            <div class="eas-field">
                                <label class="eas-label">Period Covered <span class="eas-req">*</span></label>
                                <InputText @bind-Value="rel.PeriodCovered" class="@(abShowErrors && string.IsNullOrWhiteSpace(rel.PeriodCovered) ? "eas-input eas-invalid" : "eas-input")" placeholder="e.g. 2019–present" />
                                @if (abShowErrors && string.IsNullOrWhiteSpace(rel.PeriodCovered))
                                {
                                    <span class="eas-field-error">Period covered is required.</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        }
    </div>

    @* ── Footer ── *@
    <div class="eas-footer">
        <button type="button" class="eas-btn-back" @onclick="OnBack">
            <div class="eas-btn-arrow-left"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg></div>
            <span>Back</span>
        </button>
        <div class="eas-footer-hint"><span class="eas-req">*</span>&nbsp;Required fields must be filled before continuing</div>
        <button type="button" class="eas-btn-next" @onclick="TriggerAll">
            <span>Continue</span>
            <div class="eas-btn-arrow"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg></div>
        </button>
    </div>

</div>

@code {
    // ── Parameters ────────────────────────────────────────────────
    [Parameter] public IndividualEmploymentDTO.PageModel EmploymentModel { get; set; } = new();
    [Parameter] public IndividualInfoDTO.PageModel InfoModel { get; set; } = new();
    [Parameter] public long CustomerId { get; set; }
    [Parameter] public BusinessInterestDTO.PageModel BusintModel { get; set; } = new();
    [Parameter] public EventCallback<BusinessInterestDTO.PageModel> BusintModelChanged { get; set; }
    [Parameter] public GovernmentRelationDTO.PageModel GovRelModel { get; set; } = new();
    [Parameter] public EventCallback<GovernmentRelationDTO.PageModel> GovRelModelChanged { get; set; }
    [Parameter] public AccountPurposeDTO.PageModel AccPurpModel { get; set; } = new();
    [Parameter] public EventCallback<AccountPurposeDTO.PageModel> AccPurpModelChanged { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    // ── State ──────────────────────────────────────────────────────
    private EditForm? employmentForm;
    private ValidationMessageStore? employmentMessageStore;
    private bool employmentHasAttempted = false;
    private bool employmentPassed = false;
    private bool abShowErrors = false;
    private readonly HashSet<int> ownershipInvalidRows = new();

    // ── Phone state ───────────────────────────────────────────────
    private string? employerPhoneRaw;
    private string? employerPhoneError;

    // ── Lifecycle ──────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        abShowErrors = false;
        if (InfoModel.GovOfficialPositions.Count == 0 && !string.IsNullOrWhiteSpace(InfoModel.GovPosition))
            InfoModel.GovOfficialPositions.Add(new IndividualInfoDTO.PageModel.GovOfficialPositionModel { Position = InfoModel.GovPosition, Period = InfoModel.GovPeriod ?? "" });

        if (!string.IsNullOrWhiteSpace(EmploymentModel.EmployerPhoneNumber))
            employerPhoneRaw = EmploymentModel.EmployerPhoneNumber.StartsWith("+63")
                ? EmploymentModel.EmployerPhoneNumber[3..]
                : EmploymentModel.EmployerPhoneNumber;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        var ctx = employmentForm?.EditContext;
        if (ctx == null) return;
        employmentMessageStore = new ValidationMessageStore(ctx);
        ctx.OnFieldChanged += (_, _) =>
        {
            if (employmentHasAttempted)
            {
                ValidateEmploymentConditional();
                ctx.NotifyValidationStateChanged();
            }
        };
    }

    // ── Combined trigger ──────────────────────────────────────────
    private async Task TriggerAll()
    {
        employmentPassed = false;
        abShowErrors = true;

        // Employment form
        employmentHasAttempted = true;
        var ctx = employmentForm?.EditContext;
        if (ctx != null)
        {
            ctx.Validate();
            ValidateEmploymentConditional();
            ctx.NotifyValidationStateChanged();
        }
        await employmentForm!.OnValidSubmit.InvokeAsync();

        bool abValid = IsAccountBusinessValid();
        if (employmentPassed && abValid)
        {
            await CommitAndAdvance();
            return;
        }

        // Force UI re-render so error messages are in the DOM before JS scans for them
        StateHasChanged();
        await Task.Delay(50);

        var scrollIds = new[]
        {
            "field-EmploymentStatus",
            "field-NameOfEmployer",
            "field-AccountPurpose",
            "field-BusinessInterests",
            "field-GovOfficial",
            "field-GovRelative"
        };
        foreach (var id in scrollIds)
        {
            try { if (await JS.InvokeAsync<bool>("scrollToFirstError", id)) break; }
            catch { }
        }
    }

    private void OnEmploymentValidSubmit() => employmentPassed = true;
    private async Task CommitAndAdvance()
    {
        // Employment cleanup
        EmploymentModel.CustomerID = CustomerId;
        if (EmploymentModel.EmploymentStatus != EmploymentStatus.Others) EmploymentModel.EmploymentStatusOther = null;
        if (EmploymentModel.TypeOfEmployment != TypeOfEmployment.Others) EmploymentModel.TypeOfEmploymentOther = null;
        if (EmploymentModel.TypeOfEmployment != TypeOfEmployment.OFW) EmploymentModel.OFWCountry = null;
        if (EmploymentModel.SourceOfFunds != SourceOfFunds.Others) EmploymentModel.SourceOfFundsOther = null;

        // AccountBusiness cleanup
        InfoModel.CustomerID = CustomerId;
        if (InfoModel.AccountPurpose != PurposeOfAccount.Others) InfoModel.AccountPurposeOther = null;
        if (InfoModel.ProductsAvailed != "Others") InfoModel.ProductsAvailedOther = null;
        if (!InfoModel.IsGovOfficial)
        {
            InfoModel.GovOfficialPositions.Clear();
            InfoModel.GovPosition = null;
            InfoModel.GovPeriod = null;
        }
        else
        {
            var first = InfoModel.GovOfficialPositions.FirstOrDefault();
            InfoModel.GovPosition = first?.Position;
            InfoModel.GovPeriod = first?.Period;
        }

        BusintModel.CustomerID = CustomerId;
        GovRelModel.CustomerID = CustomerId;
        GovRelModel.HighestPositionOccupied = InfoModel.GovPosition;
        GovRelModel.PeriodCovered = InfoModel.GovPeriod;

        AccPurpModel.EntityID = CustomerId;
        AccPurpModel.EntityType = EntityType.Individual;
        AccPurpModel.PurposeOfAccount = InfoModel.AccountPurpose;
        AccPurpModel.PurposeOfAccountOther = InfoModel.AccountPurposeOther;
        AccPurpModel.ProductsAvailed = InfoModel.ProductsAvailed;
        AccPurpModel.ProductsAvailedOther = InfoModel.ProductsAvailedOther;

        await BusintModelChanged.InvokeAsync(BusintModel);
        await GovRelModelChanged.InvokeAsync(GovRelModel);
        await AccPurpModelChanged.InvokeAsync(AccPurpModel);
        await OnNext.InvokeAsync();
    }

    // ── Employment validation ─────────────────────────────────────
    private void ValidateEmploymentConditional()
    {
        var store = employmentMessageStore;
        var ctx = employmentForm?.EditContext;
        if (store == null || ctx == null) return;
        store.Clear();

        if (EmploymentModel.EmploymentStatus == EmploymentStatus.None)
            store.Add(() => EmploymentModel.EmploymentStatus, "Employment status is required.");
        else if (EmploymentModel.EmploymentStatus == EmploymentStatus.Others && string.IsNullOrWhiteSpace(EmploymentModel.EmploymentStatusOther))
            store.Add(() => EmploymentModel.EmploymentStatusOther, "Please specify your employment status.");

        if (EmploymentModel.TypeOfEmployment == TypeOfEmployment.None)
            store.Add(() => EmploymentModel.TypeOfEmployment, "Type of employment is required.");
        else if (EmploymentModel.TypeOfEmployment == TypeOfEmployment.Others && string.IsNullOrWhiteSpace(EmploymentModel.TypeOfEmploymentOther))
            store.Add(() => EmploymentModel.TypeOfEmploymentOther, "Please specify your employment type.");
        else if (EmploymentModel.TypeOfEmployment == TypeOfEmployment.OFW && string.IsNullOrWhiteSpace(EmploymentModel.OFWCountry))
            store.Add(() => EmploymentModel.OFWCountry, "Country of employment is required for OFW.");

        if (string.IsNullOrWhiteSpace(EmploymentModel.NatureOfWork)) store.Add(() => EmploymentModel.NatureOfWork, "Nature of work is required.");
        if (EmploymentModel.AverageMonthlyIncome == AverageMonthlyIncome.None) store.Add(() => EmploymentModel.AverageMonthlyIncome, "Average monthly income is required.");
        if (EmploymentModel.SourceOfFunds == SourceOfFunds.None) store.Add(() => EmploymentModel.SourceOfFunds, "Source of funds is required.");
        else if (EmploymentModel.SourceOfFunds == SourceOfFunds.Others && string.IsNullOrWhiteSpace(EmploymentModel.SourceOfFundsOther))
            store.Add(() => EmploymentModel.SourceOfFundsOther, "Please specify your source of funds.");

        if (string.IsNullOrWhiteSpace(EmploymentModel.NameOfEmployer)) store.Add(() => EmploymentModel.NameOfEmployer, "Name of employer is required.");
        if (string.IsNullOrWhiteSpace(EmploymentModel.PositionRank)) store.Add(() => EmploymentModel.PositionRank, "Position / rank is required.");
        if (string.IsNullOrWhiteSpace(EmploymentModel.EmployerStreet)) store.Add(() => EmploymentModel.EmployerStreet, "Street is required.");
        if (string.IsNullOrWhiteSpace(EmploymentModel.EmployerBrgyDistrict)) store.Add(() => EmploymentModel.EmployerBrgyDistrict, "Barangay / district is required.");
        if (string.IsNullOrWhiteSpace(EmploymentModel.EmployerCityTown)) store.Add(() => EmploymentModel.EmployerCityTown, "City / town is required.");
        if (string.IsNullOrWhiteSpace(EmploymentModel.EmployerPhoneNumber))
            store.Add(() => EmploymentModel.EmployerPhoneNumber, "Employer phone number is required.");
        else if (EmploymentModel.EmployerPhoneNumber.Length < 7)
            store.Add(() => EmploymentModel.EmployerPhoneNumber, "Phone number must be 10 digits (e.g. 9XXXXXXXXX).");
        if (string.IsNullOrWhiteSpace(EmploymentModel.EmployerEmailAddress))
            store.Add(() => EmploymentModel.EmployerEmailAddress, "Employer email address is required.");
        else if (!EmploymentModel.EmployerEmailAddress.Contains('@') || !EmploymentModel.EmployerEmailAddress.Contains('.'))
            store.Add(() => EmploymentModel.EmployerEmailAddress, "Please enter a valid email address.");
    }

    // ── AccountBusiness validation ────────────────────────────────
    private bool IsAccountBusinessValid()
    {
        if (InfoModel.AccountPurpose == PurposeOfAccount.None) return false;
        if (InfoModel.AccountPurpose == PurposeOfAccount.Others && string.IsNullOrWhiteSpace(InfoModel.AccountPurposeOther)) return false;
        if (string.IsNullOrWhiteSpace(InfoModel.ProductsAvailed)) return false;
        if (InfoModel.ProductsAvailed == "Others" && string.IsNullOrWhiteSpace(InfoModel.ProductsAvailedOther)) return false;
        foreach (var biz in InfoModel.BusinessInterests)
        {
            if (string.IsNullOrWhiteSpace(biz.BusinessName)) return false;
            if (biz.OwnershipPercentage == null || biz.OwnershipPercentage < 0 || biz.OwnershipPercentage > 100) return false;
        }
        if (InfoModel.IsGovOfficial)
        {
            if (InfoModel.GovOfficialPositions.Count == 0) return false;
            foreach (var p in InfoModel.GovOfficialPositions)
            {
                if (string.IsNullOrWhiteSpace(p.Position) || string.IsNullOrWhiteSpace(p.Period)) return false;
            }
        }
        foreach (var rel in InfoModel.GovRelatives)
        {
            if (string.IsNullOrWhiteSpace(rel.Name) || string.IsNullOrWhiteSpace(rel.Relationship) || string.IsNullOrWhiteSpace(rel.Position) || string.IsNullOrWhiteSpace(rel.PeriodCovered)) return false;
        }
        return true;
    }

    // ── Helpers ───────────────────────────────────────────────────
    private void AddBusiness() => InfoModel.BusinessInterests.Add(new BusinessInterestModel());
    private void RemoveBusiness(int i) { if (i >= 0 && i < InfoModel.BusinessInterests.Count) InfoModel.BusinessInterests.RemoveAt(i); }
    private void AddGovPosition() => InfoModel.GovOfficialPositions.Add(new IndividualInfoDTO.PageModel.GovOfficialPositionModel());
    private void RemoveGovPosition(int i) { if (i >= 0 && i < InfoModel.GovOfficialPositions.Count) InfoModel.GovOfficialPositions.RemoveAt(i); }
    private void AddGovRelative() => InfoModel.GovRelatives.Add(new GovRelativeModel());
    private void RemoveGovRelative(int i) { if (i >= 0 && i < InfoModel.GovRelatives.Count) InfoModel.GovRelatives.RemoveAt(i); }
    private void HandleOwnershipInput(ChangeEventArgs e, IndividualInfoDTO.PageModel.BusinessInterestModel item, int rowIndex)
    {
        var raw = e.Value?.ToString() ?? "";
        if (raw.Any(char.IsLetter)) { ownershipInvalidRows.Add(rowIndex); return; }
        ownershipInvalidRows.Remove(rowIndex);
        var filtered = new System.Text.StringBuilder();
        bool hasDot = false;
        foreach (var ch in raw)
        {
            if (char.IsDigit(ch)) filtered.Append(ch);
            else if (ch == '.' && !hasDot) { filtered.Append(ch); hasDot = true; }
        }
        var input = filtered.ToString();
        if (string.IsNullOrEmpty(input) || input == ".") { item.OwnershipPercentage = null; return; }
        if (decimal.TryParse(input, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal parsed))
        {
            if (parsed > 100) parsed = 100;
            if (parsed < 0) parsed = 0;
            item.OwnershipPercentage = parsed;
        }
    }
    private void HandleEmployerPhoneInput(ChangeEventArgs e)
    {
        var raw = System.Text.RegularExpressions.Regex.Replace(e.Value?.ToString() ?? "", @"[^\d]", "");
        if (raw.Length > 10) raw = raw[..10];
        employerPhoneRaw = raw;

        if (raw.Length == 0)
        {
            EmploymentModel.EmployerPhoneNumber = null;
            employerPhoneError = "Employer phone number is required.";
        }
        else if (raw.Length < 10)
        {
            EmploymentModel.EmployerPhoneNumber = "+63" + raw;
            employerPhoneError = "Phone number must be 10 digits (e.g. 9XXXXXXXXX).";
        }
        else
        {
            EmploymentModel.EmployerPhoneNumber = "+63" + raw;
            employerPhoneError = null;
        }
    }

    private static string FormatEnum(string value) => System.Text.RegularExpressions.Regex.Replace(value, @"(?<=[a-z])(?=[A-Z])|(?<=[A-Z])(?=[A-Z][a-z])", " ");
    private string GetEnumDescription<TEnum>(TEnum value) where TEnum : Enum
    {
        var field = value.GetType().GetField(value.ToString());
        var attr = field?.GetCustomAttribute<DescriptionAttribute>();
        return attr?.Description ?? value.ToString();
    }
}
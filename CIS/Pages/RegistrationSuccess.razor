@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="rs-shell">

    <div class="rs-card">

        @* ── Top accent bar ── *@
        <div class="rs-accent-bar"></div>

        @* ── Icon ── *@
        <div class="rs-icon-wrap">
            <div class="rs-icon-ring rs-ring-3"></div>
            <div class="rs-icon-ring rs-ring-2"></div>
            <div class="rs-icon-ring rs-ring-1"></div>
            <div class="rs-icon-core">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                    <path d="M5 13l4 4L19 7" stroke="white" stroke-width="2.5"
                          stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
        </div>

        @* ── Heading ── *@
        <div class="rs-heading-group">
            <p class="rs-eyebrow">Registration Complete</p>
            <h1 class="rs-title">Account Successfully Created</h1>
            <p class="rs-subtitle">
                The <span class="rs-highlight">@RegistrationType.ToUpper()</span> account for
                <strong>@CustomerName</strong> has been saved to the system.
            </p>
        </div>

        @* ── CID Card ── *@
        <div class="rs-cid-card">
            <div class="rs-cid-card-inner">
                <div class="rs-cid-left">
                    <div class="rs-cid-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                            <rect x="2" y="5" width="20" height="14" rx="3" stroke="white" stroke-width="2"/>
                            <path d="M2 10h20" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                            <circle cx="7" cy="15" r="1.5" fill="white"/>
                        </svg>
                    </div>
                    <div class="rs-cid-text">
                        <span class="rs-cid-label">Customer ID Number</span>
                        <span class="rs-cid-value">@CIDNumber</span>
                    </div>
                </div>
                <div class="rs-cid-badge">Verified</div>
            </div>
            <div class="rs-cid-shimmer"></div>
        </div>

        @* ── Meta info ── *@
        <div class="rs-meta-row">
            <div class="rs-meta-item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/>
                    <path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>@DateTime.Now.ToString("MMMM dd, yyyy")</span>
            </div>
            <div class="rs-meta-dot"></div>
            <div class="rs-meta-item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/>
                    <path d="M12 7v5l3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>@DateTime.Now.ToString("HH:mm")</span>
            </div>
            <div class="rs-meta-dot"></div>
            <div class="rs-meta-item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/>
                </svg>
                <span>@RegistrationType Account</span>
            </div>
        </div>

        @* ── Divider ── *@
        <div class="rs-divider"></div>

        @* ── Actions ── *@
        <div class="rs-actions">
            <button type="button" class="rs-btn-primary" @onclick="PrintAndRedirect">
                <div class="rs-btn-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M6 9V2h12v7" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2" stroke="white" stroke-width="2" stroke-linecap="round"/>
                        <path d="M6 14h12v8H6z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span>Print Application</span>
            </button>

            <button type="button" class="rs-btn-secondary" @onclick="RegisterAnother">
                <div class="rs-btn-icon-sec">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                    </svg>
                </div>
                <span>Register Another @RegistrationType</span>
            </button>
        </div>

    </div>
</div>

<style>
    .rs-shell {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 16px;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    /* ── Card ── */
    .rs-card {
        background: #ffffff;
        border-radius: 28px;
        padding: 48px 44px;
        max-width: 540px;
        width: 100%;
        position: relative;
        animation: rs-card-in 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
        overflow: hidden;
        text-align: center;
    }

    @@keyframes rs-card-in {
        from { opacity: 0; transform: translateY(32px) scale(0.96); }
        to   { opacity: 1; transform: translateY(0)    scale(1); }
    }

    /* ── Accent bar ── */
    .rs-accent-bar {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: linear-gradient(90deg, #00a859 0%, #0056b3 60%, #00a859 100%);
        background-size: 200% 100%;
        animation: rs-shimmer-bar 3s linear infinite;
    }

    @@keyframes rs-shimmer-bar {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    /* ── Icon ── */
    .rs-icon-wrap {
        position: relative;
        width: 96px; height: 96px;
        margin: 24px auto 32px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .rs-icon-ring {
        position: absolute;
        border-radius: 50%;
        animation: rs-ring-pulse 2.5s ease-out infinite;
    }

    .rs-ring-1 {
        width: 96px; height: 96px;
        background: linear-gradient(135deg, #00a859, #0056b3);
        animation-delay: 0s;
    }

    .rs-ring-2 {
        width: 112px; height: 112px;
        background: linear-gradient(135deg, rgba(0,168,89,0.2), rgba(0,86,179,0.2));
        animation-delay: 0.4s;
    }

    .rs-ring-3 {
        width: 130px; height: 130px;
        background: linear-gradient(135deg, rgba(0,168,89,0.08), rgba(0,86,179,0.08));
        animation-delay: 0.8s;
    }

    @@keyframes rs-ring-pulse {
        0%   { transform: scale(0.85); opacity: 0; }
        40%  { opacity: 1; }
        100% { transform: scale(1.05); opacity: 0; }
    }

    .rs-icon-core {
        position: absolute;
        width: 72px; height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg, #00a859, #0056b3);
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 8px 32px rgba(0,168,89,0.4), 0 4px 16px rgba(0,86,179,0.3);
        animation: rs-icon-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
    }

    @@keyframes rs-icon-in {
        from { transform: scale(0) rotate(-20deg); opacity: 0; }
        to   { transform: scale(1) rotate(0deg);   opacity: 1; }
    }

    /* ── Heading group ── */
    .rs-heading-group {
        animation: rs-fade-up 0.6s ease 0.4s both;
    }

    .rs-eyebrow {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #00a859;
        margin: 0 0 10px;
    }

    .rs-title {
        font-size: 1.65rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 12px;
        line-height: 1.2;
        letter-spacing: -0.3px;
    }

    .rs-subtitle {
        font-size: 0.9rem;
        color: #64748b;
        line-height: 1.6;
        margin: 0;
    }

    .rs-highlight {
        color: #0056b3;
        font-weight: 600;
    }

    /* ── CID Card ── */
    .rs-cid-card {
        margin: 28px 0 0;
        border-radius: 18px;
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #0f2d1a 100%);
        padding: 20px 24px;
        position: relative;
        overflow: hidden;
        animation: rs-fade-up 0.6s ease 0.5s both;
    }

    .rs-cid-card::before {
        content: '';
        position: absolute;
        top: -40px; right: -40px;
        width: 160px; height: 160px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(0,168,89,0.2), transparent 70%);
    }

    .rs-cid-card-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        z-index: 1;
    }

    .rs-cid-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .rs-cid-text {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 2px;
    }

    .rs-cid-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.15);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .rs-cid-label {
        display: block;
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.5);
        margin-bottom: 4px;
    }

    .rs-cid-value {
        display: block;
        font-size: 1.4rem;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: 1px;
        font-variant-numeric: tabular-nums;
    }

    .rs-cid-badge {
        padding: 5px 14px;
        border-radius: 99px;
        background: linear-gradient(135deg, rgba(0,168,89,0.3), rgba(0,168,89,0.15));
        border: 1px solid rgba(0,168,89,0.4);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: #4ade80;
    }

    .rs-cid-shimmer {
        position: absolute;
        top: 0; left: -100%;
        width: 60%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent);
        animation: rs-cid-sweep 3s ease-in-out 1.2s infinite;
    }

    @@keyframes rs-cid-sweep {
        0%   { left: -60%; }
        100% { left: 160%; }
    }

    /* ── Meta row ── */
    .rs-meta-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 20px;
        animation: rs-fade-up 0.6s ease 0.6s both;
    }

    .rs-meta-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.72rem;
        color: #94a3b8;
        font-weight: 500;
    }

    .rs-meta-dot {
        width: 3px; height: 3px;
        border-radius: 50%;
        background: #cbd5e1;
    }

    /* ── Divider ── */
    .rs-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, #e2e8f0, transparent);
        margin: 28px 0;
        animation: rs-fade-up 0.6s ease 0.65s both;
    }

    /* ── Actions ── */
    .rs-actions {
        display: flex;
        flex-direction: column;
        gap: 12px;
        animation: rs-fade-up 0.6s ease 0.7s both;
    }

    .rs-btn-primary {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 15px 28px;
        background: linear-gradient(90deg, #00a859 0%, #0056b3 100%);
        color: #fff;
        border: none;
        border-radius: 14px;
        font-size: 0.92rem;
        font-weight: 700;
        cursor: pointer;
        transition: filter 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 4px 20px rgba(0,168,89,0.35), 0 2px 8px rgba(0,86,179,0.2);
        position: relative;
        overflow: hidden;
        letter-spacing: 0.2px;
    }

    .rs-btn-primary::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(255,255,255,0.12), transparent);
        pointer-events: none;
    }

    .rs-btn-primary:hover {
        filter: brightness(1.08);
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(0,168,89,0.4), 0 4px 12px rgba(0,86,179,0.25);
    }

    .rs-btn-primary:active { transform: translateY(0); }

    .rs-btn-icon {
        width: 32px; height: 32px;
        border-radius: 9px;
        background: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .rs-btn-secondary {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 14px 28px;
        background: #fff;
        color: #475569;
        border: 1.5px solid #e2e8f0;
        border-radius: 14px;
        font-size: 0.92rem;
        font-weight: 600;
        cursor: pointer;
        transition: border-color 0.18s, color 0.18s, transform 0.15s, box-shadow 0.18s;
        letter-spacing: 0.2px;
    }

    .rs-btn-secondary:hover {
        border-color: #00a859;
        color: #00a859;
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(0,168,89,0.12);
    }

    .rs-btn-icon-sec {
        width: 32px; height: 32px;
        border-radius: 9px;
        background: #f1f5f9;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        transition: background 0.18s;
    }

    .rs-btn-secondary:hover .rs-btn-icon-sec {
        background: rgba(0,168,89,0.1);
    }

    @@keyframes rs-fade-up {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 600px) {
        .rs-card { padding: 36px 24px; border-radius: 22px; }
        .rs-title { font-size: 1.35rem; }
        .rs-meta-row { flex-wrap: wrap; gap: 6px; }
        .rs-meta-dot { display: none; }
    }
</style>

@code {
    [Parameter] public string CustomerName { get; set; } = "";
    [Parameter] public long CustomerId { get; set; }
    [Parameter] public string CIDNumber { get; set; } = "";
    [Parameter] public string RegistrationType { get; set; } = "Individual";
    [Parameter] public EventCallback OnReset { get; set; }

    private async Task PrintAndRedirect()
    {
        var printUrl = $"/porac-bank-cis?customerId={CustomerId}";
        await JS.InvokeVoidAsync("open", printUrl, "_blank");
    }

    private async Task RegisterAnother()
    {
        await OnReset.InvokeAsync();
    }
}

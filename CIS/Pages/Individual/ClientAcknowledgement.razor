@inject IJSRuntime JS
@using CIS.Assets.DTO

<div class="ca-wrap">

    @* ══════════════════════════════════════
       SECTION 1 — Acknowledgement Text
    ══════════════════════════════════════ *@
    <div class="ca-section">
        <div class="ca-section-header">
            <div class="ca-section-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <span class="ca-section-title">Client's Acknowledgement</span>
        </div>

        <div class="ca-ack-text">
            <p>By signing this form, We certify that all information provided herein is true and correct to the best of my knowledge. We further agree:</p>
            <ol>
                <li>To allow Porac Bank to verify the above information and inform Porac Bank of any changes in the information provided in the form;</li>
                <li>That all deposit products and credit facilities that I/We have availed, or shall, in the future, avail from Porac Bank shall be governed by the terms and conditions set forth by Porac Bank as well as the rules and regulations of the Bangko Sentral ng Pilipinas (BSP) and such other laws, rules and regulations relative to said products and facilities.</li>
                <li>To grant Porac Bank access to all information relating to my/our present and future accounts and to disclose such data and papers pertaining to my/our accounts as may be required by government regulatory authorities for purposes of compliance with relevant laws and regulations issued by appropriate regulatory authorities and agencies of the government.</li>
            </ol>
        </div>
    </div>

    @* ══════════════════════════════════════
       SECTION 2 — Signature & Details
    ══════════════════════════════════════ *@
    <div class="ca-section">
        <div class="ca-section-header">
            <div class="ca-section-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M12 20h9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <span class="ca-section-title">Signature of Depositor / Authorized Representative</span>
        </div>

        <div class="ca-signature-wrap">
            <div class="ca-canvas-container">
                <canvas id="signature-pad" width="600" height="240" style="cursor: crosshair; display: block; width: 100%; height: 240px;"></canvas>
            </div>
            <button type="button" class="ca-clear-btn" @onclick='() => JS.InvokeVoidAsync("signaturePad.clear")'>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                    <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
                Clear Signature
            </button>
        </div>

        <div class="ca-divider"></div>

        <div class="caf-grid caf-grid-2">
            <div class="ca-field">
                <label class="ca-label">Printed Name <span class="ca-req">*</span></label>
                <InputText @bind-Value="AcknowledgementModel.PrintedName"
                           class="@(showErrors && string.IsNullOrWhiteSpace(AcknowledgementModel.PrintedName) ? "ca-input ca-invalid" : "ca-input")"
                           placeholder="Enter full name" />
                @if (showErrors && string.IsNullOrWhiteSpace(AcknowledgementModel.PrintedName))
                {
                    <span class="ca-field-error">Printed name is required.</span>
                }
            </div>
            <div class="ca-field">
                <label class="ca-label">Date Signed <span class="ca-req">*</span></label>
                <input type="date"
                       class="@(showErrors && !dateSelected ? "ca-input ca-invalid" : "ca-input")"
                       min="1900-01-01" max="2999-12-31"
                       value="@(dateSigned == default ? "" : dateSigned.ToString("yyyy-MM-dd"))"
                       @onchange="HandleDateChange" />
                @if (showErrors && !dateSelected)
                {
                    <span class="ca-field-error">Date signed is required.</span>
                }
            </div>
        </div>
    </div>

    @* ══════════════════════════════════════
       FOOTER
    ══════════════════════════════════════ *@
    <div class="ca-footer">
        <button type="button" class="ca-btn-back" @onclick="OnBack">
            <div class="ca-btn-arrow-left">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                    <path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <span>Back</span>
        </button>
        <div class="ca-footer-hint">
            <span class="ca-req">*</span>&nbsp;Required fields must be filled before continuing
        </div>
        <button type="button" class="ca-btn-next" @onclick="TryNext">
            <span>Continue</span>
            <div class="ca-btn-arrow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                    <path d="M5 12h14M13 6l6 6-6 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
        </button>
    </div>

</div>

<style>
    .ca-wrap {
        display: flex;
        flex-direction: column;
        gap: 8px;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    .ca-section {
        background: #ffffff;
        border: 1px solid #edf0f4;
        border-radius: 18px;
        padding: 22px 24px;
        transition: border-color 0.2s, box-shadow 0.2s;
        position: relative;
        overflow: hidden;
    }

    .ca-section::after {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
        background: linear-gradient(180deg, #00a859, #0056b3);
        opacity: 0;
        transition: opacity 0.25s;
    }

    .ca-section:focus-within { border-color: #c8e6d8; box-shadow: 0 4px 20px rgba(0,168,89,0.07); }
    .ca-section:focus-within::after { opacity: 1; }

    .ca-section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
    }

    .ca-section-icon {
        width: 28px; height: 28px;
        border-radius: 8px;
        background: linear-gradient(135deg, #00a859, #0056b3);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0,168,89,0.25);
    }

    .ca-section-title {
        font-size: 0.72rem;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        flex: 1;
    }

    /* ── Acknowledgement text ── */
    .ca-ack-text {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 20px 24px;
        font-size: 0.86rem;
        color: #334155;
        line-height: 1.75;
        text-align: justify;
        max-height: 280px;
        overflow-y: auto;
    }

    .ca-ack-text p { margin: 0 0 12px; }
    .ca-ack-text p:last-child { margin-bottom: 0; }

    .ca-ack-text ol {
        margin: 8px 0 12px;
        padding-left: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .ca-ack-text ol li {
        padding-left: 4px;
    }

    /* ── Signature ── */
    .ca-signature-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        margin-bottom: 4px;
    }

    .ca-canvas-container {
        width: 100%;
        max-width: 640px;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        min-height: 240px;
    }

    .ca-clear-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 7px 16px;
        background: #fff;
        color: #dc2626;
        border: 1.5px solid #fca5a5;
        border-radius: 9px;
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.18s, border-color 0.18s;
    }

    .ca-clear-btn:hover { background: #fff1f1; border-color: #ef4444; }

    .ca-divider { height: 1px; background: #f1f5f9; margin: 16px 0; }

    /* ── Grid ── */
    .caf-grid { display: grid; gap: 16px; }
    .caf-grid-2 { grid-template-columns: repeat(2, 1fr); }

    /* ── Fields ── */
    .ca-field { display: flex; flex-direction: column; gap: 6px; }

    .ca-label {
        font-size: 0.71rem;
        font-weight: 700;
        color: #64748b;
        letter-spacing: 0.2px;
        display: flex; align-items: center; gap: 3px;
    }

    .ca-req { color: #ef4444; font-size: 0.8rem; line-height: 1; }

    .ca-input {
        height: 42px;
        padding: 0 14px;
        border: 1.5px solid #e2e8f0;
        border-radius: 11px;
        font-size: 0.86rem;
        color: #0f172a;
        background: #fff;
        outline: none;
        transition: border-color 0.18s, box-shadow 0.18s, background 0.18s;
        width: 100%;
        -webkit-appearance: none;
        appearance: none;
    }

    .ca-input[type="date"] { padding: 0 12px; }
    .ca-input:hover { border-color: #94a3b8; }
    .ca-input:focus { border-color: #00a859; box-shadow: 0 0 0 3px rgba(0,168,89,0.12); background: #fafffe; }
    .ca-input.ca-invalid { border-color: #ef4444 !important; box-shadow: 0 0 0 3px rgba(239,68,68,0.08) !important; }

    .ca-field-error {
        font-size: 0.7rem;
        color: #dc2626;
        font-weight: 500;
        margin: 0; padding: 0;
        display: block;
    }

    /* ── Footer ── */
    .ca-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 6px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .ca-footer-hint { font-size: 0.72rem; color: #94a3b8; display: flex; align-items: center; gap: 3px; }

    .ca-btn-next {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 13px 28px;
        background: linear-gradient(90deg, #00a859 0%, #0056b3 100%);
        color: #fff;
        border: none;
        border-radius: 13px;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        transition: filter 0.18s, transform 0.15s, box-shadow 0.18s;
        box-shadow: 0 4px 18px rgba(0,168,89,0.3);
        letter-spacing: 0.2px;
    }

    .ca-btn-next:hover { filter: brightness(1.07); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,168,89,0.38); }
    .ca-btn-next:active { transform: translateY(0); filter: brightness(0.97); }

    .ca-btn-arrow {
        width: 30px; height: 30px;
        background: rgba(255,255,255,0.2);
        border-radius: 9px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .ca-btn-back {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 13px 20px;
        background: #fff;
        color: #475569;
        border: 1.5px solid #e2e8f0;
        border-radius: 13px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: border-color 0.18s, color 0.18s, transform 0.15s;
    }

    .ca-btn-back:hover { border-color: #94a3b8; color: #0f172a; transform: translateY(-1px); }

    .ca-btn-arrow-left {
        width: 28px; height: 28px;
        background: #f1f5f9;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    @@media (max-width: 480px) {
        .caf-grid-2 { grid-template-columns: 1fr; }
        .ca-section { padding: 16px; border-radius: 14px; }
        .ca-footer { flex-direction: column; align-items: stretch; }
        .ca-btn-next, .ca-btn-back { justify-content: center; }
    }
</style>

@code {
    [Parameter] public ClientAcknowledgementDTO.PageModel AcknowledgementModel { get; set; } = new();
    [Parameter] public EventCallback<ClientAcknowledgementDTO.PageModel> AcknowledgementModelChanged { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private bool showErrors = false;
    private DateOnly dateSigned;
    private bool dateSelected = false;

    protected override void OnInitialized()
    {
        if (AcknowledgementModel.DateSigned != null)
        {
            dateSigned = AcknowledgementModel.DateSigned.Value;
            dateSelected = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(200);
            await JS.InvokeVoidAsync("signaturePad.init", "signature-pad");
        }
    }

    private void HandleDateChange(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(raw) && DateOnly.TryParse(raw, out var parsed))
        {
            dateSigned = parsed;
            dateSelected = true;
        }
        else
        {
            dateSigned = default;
            dateSelected = false;
        }
    }

    private bool IsValid()
    {
        if (string.IsNullOrWhiteSpace(AcknowledgementModel.PrintedName)) return false;
        if (!dateSelected) return false;
        return true;
    }

    private async Task TryNext()
    {
        showErrors = true;
        if (!IsValid()) return;

        AcknowledgementModel.DateSigned = dateSelected ? dateSigned : null;
        AcknowledgementModel.SignatureData = await JS.InvokeAsync<string>("signaturePad.getData");
        await AcknowledgementModelChanged.InvokeAsync(AcknowledgementModel);
        await OnNext.InvokeAsync();
    }
}

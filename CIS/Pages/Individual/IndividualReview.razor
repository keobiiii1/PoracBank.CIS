@using CIS.Client.Services
@using CIS.Assets.Enum
@using CIS.Assets.DTO
@using System.ComponentModel
@using System.Reflection

<div class="rv-wrap">

    @* ── Info banner ── *@
    <div class="rv-banner">
        <div class="rv-banner-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="white" stroke-width="2"/>
                <path d="M12 8v4M12 16h.01" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
        </div>
        <div class="rv-banner-content">
            <span class="rv-banner-title">Review Before Submitting</span>
            <span class="rv-banner-text">Please review all encoded details carefully before final submission.</span>
        </div>
    </div>

    @* ══════════════════════════════════════
       1 — Personal Information
    ══════════════════════════════════════ *@
    <div class="rv-section">
        <div class="rv-section-header">
            <div class="rv-section-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    <circle cx="12" cy="7" r="4" stroke="white" stroke-width="2"/>
                </svg>
            </div>
            <span class="rv-section-title">Personal Information</span>
        </div>

        @* Customer Category *@
        @if (Personal.CustomerCategories != null && Personal.CustomerCategories.Any())
        {
            <div class="rv-subsection">Customer Category</div>
            <div class="rv-tag-group">
                @foreach (var cat in Personal.CustomerCategories)
                {
                    <span class="rv-tag">@GetCategoryLabel(cat)</span>
                }
            </div>
            <div class="rv-divider"></div>
        }

        <div class="rv-grid rv-grid-3">
            <div class="rv-item"><span class="rv-key">Full Name</span><span class="rv-val">@Personal.FirstName @Personal.MiddleName @Personal.LastName</span></div>
            <div class="rv-item"><span class="rv-key">Date of Birth</span><span class="rv-val">@Personal.DateOfBirth?.ToString("MMMM dd, yyyy")</span></div>
            <div class="rv-item"><span class="rv-key">Place of Birth</span><span class="rv-val">@OrDash(Personal.PlaceOfBirth)</span></div>
            <div class="rv-item"><span class="rv-key">Gender</span><span class="rv-val">@Personal.Gender</span></div>
            <div class="rv-item"><span class="rv-key">Citizenship</span><span class="rv-val">@Personal.Citizenship @(Personal.Citizenship == Citizenship.Others ? $"({Personal.CitizenshipOther})" : "")</span></div>
            <div class="rv-item"><span class="rv-key">Marital Status</span><span class="rv-val">@Personal.MaritalStatus</span></div>
            <div class="rv-item"><span class="rv-key">Country of Origin</span><span class="rv-val">@OrDash(Personal.CountryOfOrigin)</span></div>
            <div class="rv-item"><span class="rv-key">Philippines Resident</span><span class="rv-val">@(Personal.IsResident ? "Yes" : "No")</span></div>
            <div class="rv-item"><span class="rv-key">Foreign National</span><span class="rv-val">@(Personal.IsForeigner ? "Yes" : "No")</span></div>
        </div>

        @if (Personal.IsForeigner)
        {
            <div class="rv-divider"></div>
            <div class="rv-subsection">Foreigner Details</div>
            <div class="rv-grid rv-grid-3">
                <div class="rv-item"><span class="rv-key">Passport No.</span><span class="rv-val">@OrDash(Personal.PassportIDNumber)</span></div>
                <div class="rv-item"><span class="rv-key">Passport Expiry</span><span class="rv-val">@Personal.PassportExpiry?.ToString("MMMM dd, yyyy")</span></div>
                <div class="rv-item">
                    <span class="rv-key">Visa / Permit</span>
                    <span class="rv-val">
                        @OrDash(string.Join(", ", new[] {
                            Personal.IsACR  ? "ACR"  : null,
                            Personal.IsSIRV ? "SIRV" : null,
                            Personal.IsSRRV ? "SRRV" : null
                        }.Where(x => x != null)))
                    </span>
                </div>
            </div>
        }

        @if (Personal.Gender == Gender.Female && Personal.MaritalStatus == MaritalStatus.Married)
        {
            <div class="rv-divider"></div>
            <div class="rv-subsection">Maiden Name</div>
            <div class="rv-grid rv-grid-3">
                <div class="rv-item"><span class="rv-key">First Name</span><span class="rv-val">@OrDash(Personal.MaidenName)</span></div>
                <div class="rv-item"><span class="rv-key">Middle Name</span><span class="rv-val">@OrDash(Personal.MaidenMiddleName)</span></div>
                <div class="rv-item"><span class="rv-key">Last Name</span><span class="rv-val">@OrDash(Personal.MaidenLastName)</span></div>
            </div>
        }

        @if (Personal.MaritalStatus is MaritalStatus.Married or MaritalStatus.Widowed)
        {
            <div class="rv-divider"></div>
            <div class="rv-subsection">Spouse</div>
            <div class="rv-grid rv-grid-3">
                <div class="rv-item"><span class="rv-key">Given Name</span><span class="rv-val">@OrDash(Personal.SpouseGivenName)</span></div>
                <div class="rv-item"><span class="rv-key">Middle Name</span><span class="rv-val">@OrDash(Personal.SpouseMiddleName)</span></div>
                <div class="rv-item"><span class="rv-key">Last Name</span><span class="rv-val">@OrDash(Personal.SpouseLastName)</span></div>
            </div>
        }

        <div class="rv-divider"></div>
        <div class="rv-subsection">Mother's Maiden Name</div>
        <div class="rv-grid rv-grid-3">
            <div class="rv-item"><span class="rv-key">Given Name</span><span class="rv-val">@OrDash(Personal.MotherMaidenGivenName)</span></div>
            <div class="rv-item"><span class="rv-key">Middle Name</span><span class="rv-val">@OrDash(Personal.MotherMaidenMiddleName)</span></div>
            <div class="rv-item"><span class="rv-key">Last Name</span><span class="rv-val">@OrDash(Personal.MotherMaidenLastName)</span></div>
        </div>
    </div>

    @* ══════════════════════════════════════
       2 — Contact & Address
    ══════════════════════════════════════ *@
    <div class="rv-section">
        <div class="rv-section-header">
            <div class="rv-section-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.36 11.36 0 003.56.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.57a1 1 0 01-.25 1.01l-2.2 2.21z" stroke="white" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <span class="rv-section-title">Contact &amp; Address</span>
        </div>
        <div class="rv-grid rv-grid-3">
            <div class="rv-item"><span class="rv-key">Mobile Phone</span><span class="rv-val">@OrDash(Personal.MobilePhoneNumber)</span></div>
            <div class="rv-item"><span class="rv-key">Home Phone</span><span class="rv-val">@OrDash(Personal.HomePhoneNumber)</span></div>
            <div class="rv-item"><span class="rv-key">Email Address</span><span class="rv-val">@OrDash(Personal.EmailAddress)</span></div>
            <div class="rv-item rv-full"><span class="rv-key">Permanent Address</span><span class="rv-val">@OrDash(Address.PermanentAddress)@(string.IsNullOrWhiteSpace(Address.PermanentZipCode) ? "" : $", {Address.PermanentZipCode}") @OrDash(Address.PermanentCountry)</span></div>
            @if (!Address.IsPresentSameAsPermanent)
            {
                <div class="rv-item rv-full"><span class="rv-key">Present Address</span><span class="rv-val">@OrDash(Address.PresentAddress)@(string.IsNullOrWhiteSpace(Address.PresentZipCode) ? "" : $", {Address.PresentZipCode}") @OrDash(Address.PresentCountry)</span></div>
            }
            else
            {
                <div class="rv-item"><span class="rv-key">Present Address</span><span class="rv-val rv-same">Same as permanent</span></div>
            }
            <div class="rv-item"><span class="rv-key">Mailing Preference</span><span class="rv-val">@Address.MailingPreference</span></div>
        </div>
    </div>

    @* ══════════════════════════════════════
       3 — Identification
    ══════════════════════════════════════ *@
    <div class="rv-section">
        <div class="rv-section-header">
            <div class="rv-section-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <rect x="2" y="5" width="20" height="14" rx="2" stroke="white" stroke-width="2"/>
                    <path d="M2 10h20" stroke="white" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <span class="rv-section-title">Identification</span>
        </div>

        @* ── Selfie ── *@
        @if (!string.IsNullOrWhiteSpace(Identification.SelfieDataUrl))
        {
            <div class="rv-subsection">Selfie</div>
            <div class="rv-photo-row">
                <div class="rv-photo-card">
                    <img src="@Identification.SelfieDataUrl" class="rv-photo-img" alt="Selfie" />
                    <span class="rv-photo-label">Face Photo</span>
                </div>
            </div>
            <div class="rv-divider"></div>
        }

        @* ── Government IDs ── *@
        <div class="rv-subsection">Government IDs</div>

        @* TIN *@
        @if (!string.IsNullOrWhiteSpace(Identification.TINNumber))
        {
            <div class="rv-id-block">
                <div class="rv-id-block-header">
                    <span class="rv-id-block-name">TIN</span>
                    <span class="rv-id-block-number">@Identification.TINNumber</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(Identification.TINFrontDataUrl) || !string.IsNullOrWhiteSpace(Identification.TINBackDataUrl))
                {
                    <div class="rv-photo-row">
                        @if (!string.IsNullOrWhiteSpace(Identification.TINFrontDataUrl))
                        {
                            <div class="rv-photo-card">
                                <img src="@Identification.TINFrontDataUrl" class="rv-photo-img" alt="TIN Front" />
                                <span class="rv-photo-label">Front</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Identification.TINBackDataUrl))
                        {
                            <div class="rv-photo-card">
                                <img src="@Identification.TINBackDataUrl" class="rv-photo-img" alt="TIN Back" />
                                <span class="rv-photo-label">Back</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="rv-id-block"><div class="rv-id-block-header"><span class="rv-id-block-name">TIN</span><span class="rv-same">—</span></div></div>
        }

        @* SSS *@
        @if (!string.IsNullOrWhiteSpace(Identification.SSSNumber))
        {
            <div class="rv-id-block">
                <div class="rv-id-block-header">
                    <span class="rv-id-block-name">SSS</span>
                    <span class="rv-id-block-number">@Identification.SSSNumber</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(Identification.SSSFrontDataUrl) || !string.IsNullOrWhiteSpace(Identification.SSSBackDataUrl))
                {
                    <div class="rv-photo-row">
                        @if (!string.IsNullOrWhiteSpace(Identification.SSSFrontDataUrl))
                        {
                            <div class="rv-photo-card">
                                <img src="@Identification.SSSFrontDataUrl" class="rv-photo-img" alt="SSS Front" />
                                <span class="rv-photo-label">Front</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Identification.SSSBackDataUrl))
                        {
                            <div class="rv-photo-card">
                                <img src="@Identification.SSSBackDataUrl" class="rv-photo-img" alt="SSS Back" />
                                <span class="rv-photo-label">Back</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="rv-id-block"><div class="rv-id-block-header"><span class="rv-id-block-name">SSS</span><span class="rv-same">—</span></div></div>
        }

        @* GSIS *@
        @if (!string.IsNullOrWhiteSpace(Identification.GSISNumber))
        {
            <div class="rv-id-block">
                <div class="rv-id-block-header">
                    <span class="rv-id-block-name">GSIS</span>
                    <span class="rv-id-block-number">@Identification.GSISNumber</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(Identification.GSISFrontDataUrl) || !string.IsNullOrWhiteSpace(Identification.GSISBackDataUrl))
                {
                    <div class="rv-photo-row">
                        @if (!string.IsNullOrWhiteSpace(Identification.GSISFrontDataUrl))
                        {
                            <div class="rv-photo-card">
                                <img src="@Identification.GSISFrontDataUrl" class="rv-photo-img" alt="GSIS Front" />
                                <span class="rv-photo-label">Front</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Identification.GSISBackDataUrl))
                        {
                            <div class="rv-photo-card">
                                <img src="@Identification.GSISBackDataUrl" class="rv-photo-img" alt="GSIS Back" />
                                <span class="rv-photo-label">Back</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="rv-id-block"><div class="rv-id-block-header"><span class="rv-id-block-name">GSIS</span><span class="rv-same">—</span></div></div>
        }

        <div class="rv-divider"></div>

        @* ── IDs Presented ── *@
        <div class="rv-subsection">IDs Presented</div>

        @* Driver's License *@
        @if (!string.IsNullOrWhiteSpace(Identification.DriversLicenseIDNo))
        {
            <div class="rv-id-block">
                <div class="rv-id-block-header">
                    <span class="rv-id-block-name">Driver's License</span>
                    <span class="rv-id-block-number">@Identification.DriversLicenseIDNo</span>
                    <span class="rv-id-block-exp">Exp: @Identification.DriversLicenseExpiry?.ToString("MMM dd, yyyy")</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(Identification.DriversLicenseFrontDataUrl) || !string.IsNullOrWhiteSpace(Identification.DriversLicenseBackDataUrl))
                {
                    <div class="rv-photo-row">
                        @if (!string.IsNullOrWhiteSpace(Identification.DriversLicenseFrontDataUrl))
                        {
                            <div class="rv-photo-card">
                                <img src="@Identification.DriversLicenseFrontDataUrl" class="rv-photo-img" alt="DL Front" />
                                <span class="rv-photo-label">Front</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Identification.DriversLicenseBackDataUrl))
                        {
                            <div class="rv-photo-card">
                                <img src="@Identification.DriversLicenseBackDataUrl" class="rv-photo-img" alt="DL Back" />
                                <span class="rv-photo-label">Back</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @* Passport *@
        @if (!string.IsNullOrWhiteSpace(Identification.PassportIDNo))
        {
            <div class="rv-id-block">
                <div class="rv-id-block-header">
                    <span class="rv-id-block-name">Passport</span>
                    <span class="rv-id-block-number">@Identification.PassportIDNo</span>
                    <span class="rv-id-block-exp">Exp: @Identification.PassportIDExpiry?.ToString("MMM dd, yyyy")</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(Identification.PassportFrontDataUrl) || !string.IsNullOrWhiteSpace(Identification.PassportBackDataUrl))
                {
                    <div class="rv-photo-row">
                        @if (!string.IsNullOrWhiteSpace(Identification.PassportFrontDataUrl))
                        {
                            <div class="rv-photo-card">
                                <img src="@Identification.PassportFrontDataUrl" class="rv-photo-img" alt="Passport Front" />
                                <span class="rv-photo-label">Front</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Identification.PassportBackDataUrl))
                        {
                            <div class="rv-photo-card">
                                <img src="@Identification.PassportBackDataUrl" class="rv-photo-img" alt="Passport Back" />
                                <span class="rv-photo-label">Back</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @* Other ID *@
        @if (!string.IsNullOrWhiteSpace(Identification.OtherIDType))
        {
            <div class="rv-id-block">
                <div class="rv-id-block-header">
                    <span class="rv-id-block-name">@Identification.OtherIDType</span>
                    <span class="rv-id-block-number">@OrDash(Identification.OtherIDNumber)</span>
                    <span class="rv-id-block-exp">Exp: @Identification.OtherIDExpiry?.ToString("MMM dd, yyyy")</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(Identification.OtherIDFrontDataUrl) || !string.IsNullOrWhiteSpace(Identification.OtherIDBackDataUrl))
                {
                    <div class="rv-photo-row">
                        @if (!string.IsNullOrWhiteSpace(Identification.OtherIDFrontDataUrl))
                        {
                            <div class="rv-photo-card">
                                <img src="@Identification.OtherIDFrontDataUrl" class="rv-photo-img" alt="Other ID Front" />
                                <span class="rv-photo-label">Front</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Identification.OtherIDBackDataUrl))
                        {
                            <div class="rv-photo-card">
                                <img src="@Identification.OtherIDBackDataUrl" class="rv-photo-img" alt="Other ID Back" />
                                <span class="rv-photo-label">Back</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @if (string.IsNullOrWhiteSpace(Identification.DriversLicenseIDNo) &&
             string.IsNullOrWhiteSpace(Identification.PassportIDNo) &&
             string.IsNullOrWhiteSpace(Identification.OtherIDType))
        {
            <div class="rv-item rv-full"><span class="rv-val rv-same">No IDs presented</span></div>
        }
    </div>

    @* ══════════════════════════════════════
       4 — Employment
    ══════════════════════════════════════ *@
    <div class="rv-section">
        <div class="rv-section-header">
            <div class="rv-section-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <rect x="2" y="7" width="20" height="14" rx="2" stroke="white" stroke-width="2"/>
                    <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" stroke="white" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <span class="rv-section-title">Employment</span>
        </div>
        <div class="rv-grid rv-grid-3">
            <div class="rv-item"><span class="rv-key">Employment Status</span><span class="rv-val">@Employment.EmploymentStatus @(Employment.EmploymentStatus == EmploymentStatus.Others ? $"({Employment.EmploymentStatusOther})" : "")</span></div>
            <div class="rv-item"><span class="rv-key">Type of Employment</span><span class="rv-val">@Employment.TypeOfEmployment @(Employment.TypeOfEmployment == TypeOfEmployment.OFW ? $"({Employment.OFWCountry})" : "") @(Employment.TypeOfEmployment == TypeOfEmployment.Others ? $"({Employment.TypeOfEmploymentOther})" : "")</span></div>
            <div class="rv-item"><span class="rv-key">Nature of Work</span><span class="rv-val">@OrDash(Employment.NatureOfWork)</span></div>
            <div class="rv-item"><span class="rv-key">Educational Attainment</span><span class="rv-val">@OrDash(Employment.EducationalAttainment)</span></div>
            <div class="rv-item"><span class="rv-key">Avg. Monthly Income</span><span class="rv-val">@Employment.AverageMonthlyIncome</span></div>
            <div class="rv-item"><span class="rv-key">Source of Funds</span><span class="rv-val">@Employment.SourceOfFunds @(Employment.SourceOfFunds == SourceOfFunds.Others ? $"({Employment.SourceOfFundsOther})" : "")</span></div>
        </div>
        <div class="rv-divider"></div>
        <div class="rv-subsection">Employer Details</div>
        <div class="rv-grid rv-grid-3">
            <div class="rv-item"><span class="rv-key">Name of Employer</span><span class="rv-val">@OrDash(Employment.NameOfEmployer)</span></div>
            <div class="rv-item"><span class="rv-key">Position / Rank</span><span class="rv-val">@OrDash(Employment.PositionRank)</span></div>
            <div class="rv-item"><span class="rv-key">Phone</span><span class="rv-val">@OrDash(Employment.EmployerPhoneNumber)</span></div>
            <div class="rv-item"><span class="rv-key">Email</span><span class="rv-val">@OrDash(Employment.EmployerEmailAddress)</span></div>
            <div class="rv-item rv-full">
                <span class="rv-key">Address</span>
                <span class="rv-val">@OrDash(string.Join(", ", new[]{ Employment.EmployerBuildingNo, Employment.EmployerStreet, Employment.EmployerBrgyDistrict, Employment.EmployerCityTown }.Where(x => !string.IsNullOrWhiteSpace(x))))</span>
            </div>
        </div>
    </div>

    @* ══════════════════════════════════════
       5 — Account & Business
    ══════════════════════════════════════ *@
    <div class="rv-section">
        <div class="rv-section-header">
            <div class="rv-section-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <span class="rv-section-title">Account &amp; Business</span>
        </div>
        <div class="rv-grid rv-grid-2">
            <div class="rv-item">
                <span class="rv-key">Purpose of Account</span>
                <span class="rv-val">
                    @(Personal.AccountPurpose == PurposeOfAccount.None ? "—" : FormatEnum(Personal.AccountPurpose.ToString())) 
                    @(Personal.AccountPurpose == PurposeOfAccount.Others ? $"({Personal.AccountPurposeOther})" : "")
                </span>
            </div>
            <div class="rv-item">
                <span class="rv-key">Products to be Availed</span>
                <span class="rv-val">
                    @OrDash(Personal.ProductsAvailed) @(Personal.ProductsAvailed == "Others" ? $"({Personal.ProductsAvailedOther})" : "")
                </span>
            </div>
            <div class="rv-item"><span class="rv-key">Past / Present Gov. Official (PEP)</span><span class="rv-val">@(Personal.IsGovOfficial ? "Yes" : "No")</span></div>
            <div class="rv-item"><span class="rv-key">Relative in Government</span><span class="rv-val">@(Personal.HasGovRelative ? "Yes" : "No")</span></div>
        </div>

        @if (Personal.IsGovOfficial)
        {
            <div class="rv-divider"></div>
            <div class="rv-subsection">Government Official Details</div>
            <div class="rv-grid rv-grid-2">
                <div class="rv-item"><span class="rv-key">Highest Position</span><span class="rv-val">@OrDash(Personal.GovPosition)</span></div>
                <div class="rv-item"><span class="rv-key">Period Covered</span><span class="rv-val">@OrDash(Personal.GovPeriod)</span></div>
            </div>
        }

        @if (Personal.BusinessInterests != null && Personal.BusinessInterests.Any())
        {
            <div class="rv-divider"></div>
            <div class="rv-subsection">Business Interests</div>
            <div class="rv-list-header rv-grid-biz">
                <span class="rv-list-col">Business Name</span>
                <span class="rv-list-col">Ownership %</span>
            </div>
            @foreach (var biz in Personal.BusinessInterests)
            {
                <div class="rv-list-row rv-grid-biz">
                    <span>@OrDash(biz.BusinessName)</span>
                    <span>@biz.OwnershipPercentage%</span>
                </div>
            }
        }

        @if (Personal.HasGovRelative && Personal.GovRelatives != null && Personal.GovRelatives.Any())
        {
            <div class="rv-divider"></div>
            <div class="rv-subsection">Relatives in Government</div>
            <div class="rv-list-header rv-grid-rel">
                <span class="rv-list-col">Full Name</span>
                <span class="rv-list-col">Relationship</span>
                <span class="rv-list-col">Position</span>
                <span class="rv-list-col">Period</span>
            </div>
            @foreach (var rel in Personal.GovRelatives)
            {
                <div class="rv-list-row rv-grid-rel">
                    <span>@OrDash(rel.Name)</span>
                    <span>@OrDash(rel.Relationship)</span>
                    <span>@OrDash(rel.Position)</span>
                    <span>@OrDash(rel.PeriodCovered)</span>
                </div>
            }
        }
    </div>

    @* ══════════════════════════════════════
       7 — Business Information
    ══════════════════════════════════════ *@
    @if (!string.IsNullOrWhiteSpace(BusinessInfo.NameOfBusiness))
    {
        <div class="rv-section">
            <div class="rv-section-header">
                <div class="rv-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M9 22V12h6v10" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span class="rv-section-title">Business Information</span>
            </div>

            <div class="rv-grid rv-grid-3">
                <div class="rv-item"><span class="rv-key">Business Name</span><span class="rv-val">@OrDash(BusinessInfo.NameOfBusiness)</span></div>
                <div class="rv-item"><span class="rv-key">Sector</span><span class="rv-val">@(BusinessInfo.IsGovernment ? "Government" : "Private")</span></div>
                <div class="rv-item"><span class="rv-key">Type of Organization</span><span class="rv-val">@BusinessInfo.TypeOfOrganization @(!string.IsNullOrWhiteSpace(BusinessInfo.TypeOfOrganizationOther) ? $"({BusinessInfo.TypeOfOrganizationOther})" : "")</span></div>
                
                <div class="rv-item"><span class="rv-key">Size of Business</span><span class="rv-val">@GetEnumDescription(BusinessInfo.SizeOfBusiness)</span></div>
                <div class="rv-item"><span class="rv-key">Avg. Annual Income</span><span class="rv-val">@GetEnumDescription(BusinessInfo.AverageAnnualIncome)</span></div>
                <div class="rv-item"><span class="rv-key">Nature of Business</span><span class="rv-val">@OrDash(BusinessInfo.NatureOfBusiness)</span></div>

                @* Address Details from the form *@
                <div class="rv-item rv-full">
                    <span class="rv-key">Business Address</span>
                    <span class="rv-val">@OrDash(Address.BusinessAddress)</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(Address.PrincipalAddress) && Address.PrincipalAddress != Address.BusinessAddress)
                {
                    <div class="rv-item rv-full">
                        <span class="rv-key">Principal Address</span>
                        <span class="rv-val">@Address.PrincipalAddress</span>
                    </div>
                }
                else
                {
                    <div class="rv-item"><span class="rv-key">Principal Address</span><span class="rv-val rv-same">Same as business address</span></div>
                }
            </div>

            <div class="rv-divider"></div>
            <div class="rv-subsection">Registration Details</div>
            <div class="rv-grid rv-grid-3">
                <div class="rv-item"><span class="rv-key">TIN</span><span class="rv-val">@OrDash(BusinessInfo.TaxIdentificationNumber)</span></div>
                <div class="rv-item"><span class="rv-key">Reg. Number</span><span class="rv-val">@OrDash(BusinessInfo.BusinessRegNumber)</span></div>
                <div class="rv-item"><span class="rv-key">Date of Registration</span><span class="rv-val">@(BusinessInfo.DateOfRegistration?.ToString("MMM dd, yyyy") ?? "—")</span></div>
                
                <div class="rv-item"><span class="rv-key">Registration Expiry</span><span class="rv-val">@(BusinessInfo.BusinessRegExpiry?.ToString("MMM dd, yyyy") ?? "—")</span></div>
                <div class="rv-item"><span class="rv-key">Place of Registration</span><span class="rv-val">@OrDash(BusinessInfo.PlaceOfRegistration)</span></div>
                <div class="rv-item"><span class="rv-key">DTI Cert Number</span><span class="rv-val">@OrDash(BusinessInfo.DTICertNumber)</span></div>
                
                <div class="rv-item"><span class="rv-key">DTI Cert Expiry</span><span class="rv-val">@(BusinessInfo.DTICertExpiry?.ToString("MMM dd, yyyy") ?? "—")</span></div>
            </div>

            @* Keep existing Business Contact if data exists from other steps *@
            @if (!string.IsNullOrWhiteSpace(BusinessInfo.EmailAddress) || !string.IsNullOrWhiteSpace(BusinessInfo.OfficePhoneNo))
            {
                <div class="rv-divider"></div>
                <div class="rv-subsection">Business Contact</div>
                <div class="rv-grid rv-grid-3">
                    <div class="rv-item"><span class="rv-key">Office Phone</span><span class="rv-val">@OrDash(BusinessInfo.OfficePhoneNo)</span></div>
                    <div class="rv-item"><span class="rv-key">Email</span><span class="rv-val">@OrDash(BusinessInfo.EmailAddress)</span></div>
                    <div class="rv-item"><span class="rv-key">Contact Person</span><span class="rv-val">@OrDash(BusinessInfo.ContactPerson)</span></div>
                </div>
            }
        </div>
    }

    @* ══════════════════════════════════════
       8 — Account Contact
    ══════════════════════════════════════ *@
    @if (AccountContact != null && (AccountContact.AccountPurpose != PurposeOfAccount.None || !string.IsNullOrWhiteSpace(AccountContact.ProductsAvailed)))
    {
        <div class="rv-section">
            <div class="rv-section-header">
                <div class="rv-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </div>
                <span class="rv-section-title">Account Contact</span>
            </div>
            <div class="rv-grid rv-grid-3">
                @* Purpose of Account [cite: 751-755] *@
                <div class="rv-item">
                    <span class="rv-key">Purpose of Account</span>
                    <span class="rv-val">
                        @(AccountContact.AccountPurpose == PurposeOfAccount.None ? "—" : FormatEnum(AccountContact.AccountPurpose.ToString())) 
                        @(AccountContact.AccountPurpose == PurposeOfAccount.Others ? $"({AccountContact.AccountPurposeOther})" : "")
                    </span>
                </div>

                @* Products Availed [cite: 757-763, 849] *@
                <div class="rv-item">
                    <span class="rv-key">Products Availed</span>
                    <span class="rv-val">
                        @OrDash(AccountContact.ProductsAvailed?.Replace(",", ", ")) 
                        @(!string.IsNullOrWhiteSpace(AccountContact.ProductsAvailedOther) ? $"({AccountContact.ProductsAvailedOther})" : "")
                    </span>
                </div>

                @* Contact Info [cite: 765-770] *@
                <div class="rv-item"><span class="rv-key">Office Phone</span><span class="rv-val">@OrDash(AccountContact.OfficePhoneNo)</span></div>
                <div class="rv-item"><span class="rv-key">Email Address</span><span class="rv-val">@OrDash(AccountContact.EmailAddress)</span></div>
                <div class="rv-item"><span class="rv-key">Contact Person</span><span class="rv-val">@OrDash(AccountContact.ContactPerson)</span></div>

                @* Keep existing size/income if they are used elsewhere in your logic [cite: 89-90] *@
                <div class="rv-item"><span class="rv-key">Size of Business</span><span class="rv-val">@GetEnumDescription(AccountContact.SizeOfBusiness)</span></div>
                <div class="rv-item"><span class="rv-key">Avg. Annual Income</span><span class="rv-val">@GetEnumDescription(AccountContact.AverageAnnualIncome)</span></div>
            </div>
        </div>
    }

    @* ══════════════════════════════════════
       9 — Beneficiary Information
    ══════════════════════════════════════ *@
    @if (!string.IsNullOrWhiteSpace(Beneficiary.BeneficiaryName))
    {
        <div class="rv-section">
            <div class="rv-section-header">
                <div class="rv-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="white" stroke-width="2" stroke-linecap="round"/>
                        <circle cx="9" cy="7" r="4" stroke="white" stroke-width="2"/>
                        <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </div>
                <span class="rv-section-title">Beneficiary</span>
            </div>
            <div class="rv-grid rv-grid-3">
                <div class="rv-item"><span class="rv-key">Name</span><span class="rv-val">@Beneficiary.BeneficiaryName</span></div>
                <div class="rv-item"><span class="rv-key">Trust Type</span><span class="rv-val">@GetTrustTypeLabel(Beneficiary.TrustType)</span></div>
                <div class="rv-item"><span class="rv-key">Birthday</span><span class="rv-val">@Beneficiary.Birthday?.ToString("MMMM dd, yyyy")</span></div>
                
                <div class="rv-item"><span class="rv-key">Place of Birth</span><span class="rv-val">@OrDash(Beneficiary.PlaceOfBirth)</span></div>
                <div class="rv-item"><span class="rv-key">Nationality</span><span class="rv-val">@OrDash(Beneficiary.Nationality)</span></div>
                <div class="rv-item"><span class="rv-key">Nature of Work</span><span class="rv-val">@OrDash(Beneficiary.NatureOfWork)</span></div>
                
                <div class="rv-item">
                    <span class="rv-key">Source of Funds</span>
                    <span class="rv-val">
                        @OrDash(Beneficiary.SourceOfFunds) 
                        @(Beneficiary.SourceOfFunds == "Others" ? $"({Beneficiary.SourceOfFundsOther})" : "")
                    </span>
                </div>
                <div class="rv-item rv-full">
                    <span class="rv-key">Address</span>
                    <span class="rv-val">@OrDash(Beneficiary.Address)</span>
                </div>
            </div>
        </div>
    }

    @* ══════════════════════════════════════
       10 — Client Acknowledgement
    ══════════════════════════════════════ *@
    @if (!string.IsNullOrWhiteSpace(Acknowledgement.PrintedName))
    {
        <div class="rv-section">
            <div class="rv-section-header">
                <div class="rv-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M9 11l3 3L22 4" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </div>
                <span class="rv-section-title">Client Acknowledgement</span>
            </div>
            <div class="rv-grid rv-grid-2">
                <div class="rv-item">
                    <span class="rv-key">Printed Name</span>
                    <span class="rv-val">@Acknowledgement.PrintedName</span>
                </div>
                <div class="rv-item">
                    <span class="rv-key">Date Signed</span>
                    <span class="rv-val">@(Acknowledgement.DateSigned?.ToString("MMMM dd, yyyy") ?? "—")</span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Acknowledgement.SignatureData))
            {
                <div class="rv-divider"></div>
                <div class="rv-item rv-full" style="background: #fff; border: 1.5px dashed #e2e8f0;">
                    <span class="rv-key">Signature</span>
                    <div style="display: flex; justify-content: center; padding: 10px;">
                        <img src="@Acknowledgement.SignatureData" 
                             class="rv-signature" 
                             alt="Client Signature" 
                             style="max-width: 100%; height: auto; max-height: 120px; object-fit: contain;" />
                    </div>
                </div>
            }
        </div>
    }

    @* ══════════════════════════════════════
       11 — Bank Review (Internal Use)
    ══════════════════════════════════════ *@
    @if (!string.IsNullOrWhiteSpace(BankReview.VerifiedBy) || BankReview.IsEmployee || BankReview.IsRelative)
    {
        <div class="rv-section">
            <div class="rv-section-header">
                <div class="rv-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span class="rv-section-title">Bank Review & Verification</span>
            </div>

            @* Screening & Nature of Work *@
            <div class="rv-subsection">Screening & Nature of Work</div>
            <div class="rv-grid rv-grid-2">
                <div class="rv-item">
                    <span class="rv-key">Screening Lists</span>
                    <span class="rv-val">@OrDash(string.Join(", ", BankReview.ScreeningList))</span>
                </div>
                <div class="rv-item">
                    <span class="rv-key">Nature of Work / Business</span>
                    <span class="rv-val">
                        @OrDash(string.Join(", ", BankReview.WorkList))
                        @(BankReview.SelectedWork == "OTHERS" ? $" ({BankReview.NatureOfWorkBusinessOther})" : "")
                    </span>
                </div>
            </div>

            <div class="rv-divider"></div>

            @* Employee & Relationship Status *@
            <div class="rv-subsection">Internal Status</div>
            <div class="rv-grid rv-grid-3">
                <div class="rv-item">
                    <span class="rv-key">Porac Bank Employee</span>
                    <span class="rv-val">@(BankReview.IsEmployee ? $"Yes ({BankReview.Position})" : "No")</span>
                </div>
                <div class="rv-item"><span class="rv-key">DOSRI Status</span><span class="rv-val">@(BankReview.IsDosri ? "Yes" : "No")</span></div>
                <div class="rv-item"><span class="rv-key">RPT Status</span><span class="rv-val">@(BankReview.IsRpt ? "Yes" : "No")</span></div>
            </div>

            @if (BankReview.IsRelative)
            {
                <div class="rv-grid rv-grid-3 mt-2">
                    <div class="rv-item"><span class="rv-key">Relative of Employee</span><span class="rv-val">@BankReview.RelativeEmployeeName</span></div>
                    <div class="rv-item"><span class="rv-key">Relative Position</span><span class="rv-val">@BankReview.RelativePosition</span></div>
                    <div class="rv-item"><span class="rv-key">Relationship</span><span class="rv-val">@BankReview.RelativeRelationship</span></div>
                </div>
            }

            <div class="rv-divider"></div>

            @* Documents Presented *@
            <div class="rv-subsection">Documents Presented</div>
            <div class="rv-item rv-full">
                <span class="rv-val" style="font-size: 0.8rem;">
                    @if (BankReview.DocsList.Any() || BankReview.AdditionalDocsList.Any())
                    {
                        <ul style="margin: 0; padding-left: 20px;">
                            @foreach (var doc in BankReview.DocsList) { <li>@doc</li> }
                            @foreach (var doc in BankReview.AdditionalDocsList) { <li>@doc</li> }
                            @if (!string.IsNullOrWhiteSpace(BankReview.DocumentsOther)) { <li>Other: @BankReview.DocumentsOther</li> }
                        </ul>
                    }
                    else { <span>No documents recorded.</span> }
                </span>
            </div>

            <div class="rv-divider"></div>

            @* Approval & Signatures *@
            <div class="rv-grid rv-grid-3">
                <div class="rv-item"><span class="rv-key">Verified By</span><span class="rv-val">@OrDash(BankReview.VerifiedBy)</span></div>
                <div class="rv-item"><span class="rv-key">Approved By</span><span class="rv-val">@OrDash(BankReview.ApprovedBy)</span></div>
                <div class="rv-item"><span class="rv-key">Remarks</span><span class="rv-val">@OrDash(BankReview.Remarks)</span></div>
            </div>

            @if (!string.IsNullOrWhiteSpace(BankReview.SignatureAuthenticated))
            {
                <div class="rv-item rv-full mt-2" style="background: #fff; border: 1.5px dashed #e2e8f0;">
                    <span class="rv-key">Authenticated Signature (Internal)</span>
                    <div style="display: flex; justify-content: center; padding: 10px;">
                        <img src="@BankReview.SignatureAuthenticated" 
                             class="rv-signature" 
                             alt="Bank Signature" 
                             style="max-height: 80px;" />
                    </div>
                </div>
            }
        </div>
    }

    @* ── Footer ── *@
    <div class="rv-footer">
        <button type="button" class="rv-btn-back" @onclick="OnBack" disabled="@IsSubmitting">
            <div class="rv-btn-arrow-left">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                    <path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <span>Back to Edit</span>
        </button>
        <div class="rv-footer-hint">Please review everything above before submitting.</div>
        <button type="button" class="rv-btn-submit" @onclick="SubmitAsync" disabled="@IsSubmitting">
            @if (IsSubmitting)
            {
                <div class="rv-spinner"></div>
                <span>Submitting...</span>
            }
            else
            {
                <span>Confirm &amp; Submit</span>
                <div class="rv-btn-arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M5 12h14M13 6l6 6-6 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
            }
        </button>
    </div>

</div>


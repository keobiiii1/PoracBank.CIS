@code {
    [Parameter] public CustomerDTO.PageModel Customer { get; set; } = new();
    [Parameter] public IndividualInfoDTO.PageModel Personal { get; set; } = new();
    [Parameter] public AddressDTO.PageModel Address { get; set; } = new();
    [Parameter] public IndividualIdentificationDTO.PageModel Identification { get; set; } = new();
    [Parameter] public IndividualEmploymentDTO.PageModel Employment { get; set; } = new();
    [Parameter] public BusinessInfoDTO.PageModel BusinessInfo { get; set; } = new();
    [Parameter] public BusinessInfoDTO.PageModel AccountContact { get; set; } = new();
    [Parameter] public BeneficiaryDTO.PageModel Beneficiary { get; set; } = new();
    [Parameter] public ClientAcknowledgementDTO.PageModel Acknowledgement { get; set; } = new();
    [Parameter] public BankReviewDTO.PageModel BankReview { get; set; } = new();

    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }

    private bool IsSubmitting { get; set; } = false;

    private async Task SubmitAsync()
    {
        if (IsSubmitting) return;
        IsSubmitting = true;
        try { await OnSubmit.InvokeAsync(); }
        finally { IsSubmitting = false; }
    }

    private static string GetCategoryLabel(CustomerCategory cat) => cat switch
    {
        CustomerCategory.LoanBorrower => "Loan Borrower",
        CustomerCategory.LoanCoMaker  => "Loan Co-Maker",
        CustomerCategory.Depositor    => "Depositor",
        _                             => cat.ToString()
    };

    private static string OrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "\u2014" : value;

    private static string GetEnumDescription<TEnum>(TEnum value) where TEnum : Enum
    {
        var field = value.GetType().GetField(value.ToString()!);
        var attr  = field?.GetCustomAttribute<DescriptionAttribute>();
        if (attr != null) return attr.Description;
        return System.Text.RegularExpressions.Regex.Replace(
            value.ToString()!, @"(?<=[a-z])(?=[A-Z])|(?<=[A-Z])(?=[A-Z][a-z])", " ");
    }

    private static string FormatEnum(string value)
    {
        return System.Text.RegularExpressions.Regex.Replace(
            value, @"(?<=[a-z])(?=[A-Z])|(?<=[A-Z])(?=[A-Z][a-z])", " ");
    }

    private static string GetTrustTypeLabel(TrustType type) => type switch
    {
        TrustType.ITF => "In Trust For (ITF)",
        TrustType.FAO => "For the Account Of (FAO)",
        _ => type == TrustType.None ? "—" : type.ToString()
    };
}

<script>
    window.scrollToFirstError = function (id) {
        var el = document.getElementById(id);
        if (!el) return false;
        var err = el.querySelector('.bi-field-error');
        if (!err || !err.textContent.trim()) return false;
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return true;
    };
</script>

@code {
    [Parameter] public BusinessInfoDTO.PageModel BusinessModel { get; set; } = new();
    [Parameter] public EventCallback<BusinessInfoDTO.PageModel> BusinessModelChanged { get; set; }
    [Parameter] public AddressDTO.PageModel AddressModel { get; set; } = new();
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private EditForm? editForm;
    private ValidationMessageStore? messageStore;
    private bool showPrincipalAddress;
    private bool hasAttemptedSubmit = false;
    private bool sectorSelected = false;

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        var ctx = editForm?.EditContext;
        if (ctx == null) return;

        messageStore = new ValidationMessageStore(ctx);
        ctx.OnFieldChanged += (_, _) =>
        {
            if (hasAttemptedSubmit)
            {
                messageStore?.Clear();
                ctx.NotifyValidationStateChanged();
            }
        };
    }

    private static readonly string[] ScrollTargets =
    [
        "field-NameOfBusiness", "field-BusinessAddress", "field-NatureOfBusiness"
    ];

    private async Task TriggerValidation()
    {
        var ctx = editForm?.EditContext;
        if (ctx == null) return;

        hasAttemptedSubmit = true;
        ctx.Validate();
        ctx.NotifyValidationStateChanged();

        if (!IsValid())
        {
            // Scroll to first section with an error
            foreach (var id in ScrollTargets)
            {
                try { if (await JS.InvokeAsync<bool>("scrollToFirstError", id)) break; }
                catch { /* element not in DOM */ }
            }
            return;
        }

        await Next();
    }

    private bool IsValid()
    {
        if (!sectorSelected) return false;
        if (string.IsNullOrWhiteSpace(BusinessModel.NameOfBusiness)) return false;
        if (BusinessModel.TypeOfOrganization == TypeOfOrganization.None) return false;
        if (BusinessModel.TypeOfOrganization == TypeOfOrganization.Others
            && string.IsNullOrWhiteSpace(BusinessModel.TypeOfOrganizationOther)) return false;
        if (BusinessModel.SizeOfBusiness == SizeOfBusiness.None) return false;
        if (BusinessModel.AverageAnnualIncome == AverageAnnualIncome.None) return false;
        if (string.IsNullOrWhiteSpace(AddressModel.BusinessAddress)) return false;
        if (showPrincipalAddress && string.IsNullOrWhiteSpace(AddressModel.PrincipalAddress)) return false;
        if (BusinessModel.DateOfRegistration == null) return false;
        if (string.IsNullOrWhiteSpace(BusinessModel.BusinessRegNumber)) return false;
        if (BusinessModel.BusinessRegExpiry == null) return false;
        if (string.IsNullOrWhiteSpace(BusinessModel.PlaceOfRegistration)) return false;
        if (string.IsNullOrWhiteSpace(BusinessModel.NatureOfBusiness)) return false;
        if (string.IsNullOrWhiteSpace(BusinessModel.TaxIdentificationNumber)) return false;
        if (string.IsNullOrWhiteSpace(BusinessModel.DTICertNumber)) return false;
        if (BusinessModel.DTICertExpiry == null) return false;
        return true;
    }

    private async Task Next()
    {
        if (!showPrincipalAddress)
            AddressModel.PrincipalAddress = AddressModel.BusinessAddress;

        await BusinessModelChanged.InvokeAsync(BusinessModel);
        await OnNext.InvokeAsync();
    }

    private void SetSector(bool isPrivate)
    {
        BusinessModel.IsPrivate = isPrivate;
        BusinessModel.IsGovernment = !isPrivate;
        sectorSelected = true;
    }

    private static string FormatEnum(string value)
        => System.Text.RegularExpressions.Regex.Replace(
            value, @"(?<=[a-z])(?=[A-Z])|(?<=[A-Z])(?=[A-Z][a-z])", " ");

    private static string GetEnumDescription<TEnum>(TEnum value) where TEnum : Enum
    {
        var field = value.GetType().GetField(value.ToString()!);
        var attr  = field?.GetCustomAttribute<DescriptionAttribute>();
        return attr?.Description ?? FormatEnum(value.ToString()!);
    }
}

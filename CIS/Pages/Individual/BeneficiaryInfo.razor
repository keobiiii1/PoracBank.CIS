@using CIS.Assets.DTO
@using CIS.Assets.Enum

<div class="bn-wrap">

    @* ══════════════════════════════════════
       SECTION 1 — Beneficiary Information
    ══════════════════════════════════════ *@
    <div class="bn-section">
        <div class="bn-section-header">
            <div class="bn-section-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    <circle cx="12" cy="7" r="4" stroke="white" stroke-width="2"/>
                </svg>
            </div>
            <span class="bn-section-title">Beneficiary Information</span>
        </div>

        <div class="bnf-grid bnf-grid-3">
            <div class="bn-field">
                <label class="bn-label">Trust Type <span class="bn-req">*</span></label>
                <div class="bn-select-wrap">
                    <InputSelect @bind-Value="BeneficiaryModel.TrustType" class="@(showErrors && BeneficiaryModel.TrustType == TrustType.None ? "bn-select bn-invalid" : "bn-select")">
                        <option value="@TrustType.None" disabled>Select Trust Type</option>
                        <option value="@TrustType.ITF">In Trust For (ITF)</option>
                        <option value="@TrustType.FAO">For the Account Of (FAO)</option>
                    </InputSelect>
                    <svg class="bn-select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                @if (showErrors && BeneficiaryModel.TrustType == TrustType.None)
                {
                    <span class="bn-field-error">Trust type is required.</span>
                }
            </div>

            <div class="bn-field">
                <label class="bn-label">Beneficiary Name <span class="bn-req">*</span></label>
                <InputText @bind-Value="BeneficiaryModel.BeneficiaryName" class="@(showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.BeneficiaryName) ? "bn-input bn-invalid" : "bn-input")" placeholder="e.g. Maria Dela Cruz" />
                @if (showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.BeneficiaryName))
                {
                    <span class="bn-field-error">Beneficiary name is required.</span>
                }
            </div>

            <div class="bn-field">
                <label class="bn-label">Birthday <span class="bn-req">*</span></label>
                <InputDate @bind-Value="BeneficiaryModel.Birthday" class="@(showErrors && BeneficiaryModel.Birthday == null ? "bn-input bn-invalid" : "bn-input")" TValue="DateOnly?" max="9999-12-31" />
                @if (showErrors && BeneficiaryModel.Birthday == null)
                {
                    <span class="bn-field-error">Birthday is required.</span>
                }
            </div>

            <div class="bn-field">
                <label class="bn-label">Place of Birth <span class="bn-req">*</span></label>
                <InputText @bind-Value="BeneficiaryModel.PlaceOfBirth" class="@(showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.PlaceOfBirth) ? "bn-input bn-invalid" : "bn-input")" placeholder="e.g. Manila, Philippines" />
                @if (showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.PlaceOfBirth))
                {
                    <span class="bn-field-error">Place of birth is required.</span>
                }
            </div>

            <div class="bn-field">
                <label class="bn-label">Nationality <span class="bn-req">*</span></label>
                <InputText @bind-Value="BeneficiaryModel.Nationality" class="@(showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.Nationality) ? "bn-input bn-invalid" : "bn-input")" placeholder="e.g. Filipino" />
                @if (showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.Nationality))
                {
                    <span class="bn-field-error">Nationality is required.</span>
                }
            </div>

            <div class="bn-field">
                <label class="bn-label">Nature of Work <span class="bn-req">*</span></label>
                <InputText @bind-Value="BeneficiaryModel.NatureOfWork" class="@(showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.NatureOfWork) ? "bn-input bn-invalid" : "bn-input")" placeholder="e.g. Employee, Self-employed" />
                @if (showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.NatureOfWork))
                {
                    <span class="bn-field-error">Nature of work is required.</span>
                }
            </div>
        </div>

        <div class="bn-divider"></div>

        @* Address *@
        <div class="bn-subsection-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="2"/>
            </svg>
            Address <span class="bn-req">*</span>
        </div>
        <div class="bn-field">
            <InputTextArea @bind-Value="BeneficiaryModel.Address" class="@(showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.Address) ? "bn-textarea bn-invalid" : "bn-textarea")" rows="2" placeholder="Enter full address" />
            @if (showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.Address))
            {
                <span class="bn-field-error">Address is required.</span>
            }
        </div>

        <div class="bn-divider"></div>

        @* Source of Funds *@
        <div class="bn-subsection-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Source of Funds
        </div>
        <div class="bn-radio-group">
            @foreach (var src in sourceOptions)
            {
                <label class="bn-radio-card @(BeneficiaryModel.SourceOfFunds == src ? "checked" : "")">
                    <input type="radio" name="sourceOfFunds" class="bn-radio-input"
                           checked="@(BeneficiaryModel.SourceOfFunds == src)"
                           @onchange="@(() => SetSourceOfFunds(src))" />
                    <div class="bn-radio-dot"></div>
                    <span>@src</span>
                </label>
            }
        </div>

        @if (showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.SourceOfFunds))
        {
            <span class="bn-field-error mt-1">Source of funds is required.</span>
        }
        @if (BeneficiaryModel.SourceOfFunds == "Others")
        {
            <div class="bn-field mt-2">
                <label class="bn-label">Specify Source <span class="bn-req">*</span></label>
                <InputText @bind-Value="BeneficiaryModel.SourceOfFundsOther" class="@(showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.SourceOfFundsOther) ? "bn-input bn-invalid" : "bn-input")" placeholder="Please specify" />
                @if (showErrors && string.IsNullOrWhiteSpace(BeneficiaryModel.SourceOfFundsOther))
                {
                    <span class="bn-field-error">Please specify the source of funds.</span>
                }
            </div>
        }
    </div>

    @* ══════════════════════════════════════
       FOOTER
    ══════════════════════════════════════ *@
    <div class="bn-footer">
        <button type="button" class="bn-btn-back" @onclick="OnBack">
            <div class="bn-btn-arrow-left">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                    <path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <span>Back</span>
        </button>
        <div class="bn-footer-hint">
            <span class="bn-req">*</span>&nbsp;Required fields must be filled before continuing
        </div>
        <button type="button" class="bn-btn-next" @onclick="Next">
            <span>Continue</span>
            <div class="bn-btn-arrow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                    <path d="M5 12h14M13 6l6 6-6 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
        </button>
    </div>

</div>

<style>
    .bn-wrap {
        display: flex;
        flex-direction: column;
        gap: 8px;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    .bn-section {
        background: #ffffff;
        border: 1px solid #edf0f4;
        border-radius: 18px;
        padding: 22px 24px;
        transition: border-color 0.2s, box-shadow 0.2s;
        position: relative;
        overflow: hidden;
    }

    .bn-section::after {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
        background: linear-gradient(180deg, #00a859, #0056b3);
        opacity: 0;
        transition: opacity 0.25s;
    }

    .bn-section:focus-within { border-color: #c8e6d8; box-shadow: 0 4px 20px rgba(0,168,89,0.07); }
    .bn-section:focus-within::after { opacity: 1; }

    .bn-section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
    }

    .bn-section-icon {
        width: 28px; height: 28px;
        border-radius: 8px;
        background: linear-gradient(135deg, #00a859, #0056b3);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0,168,89,0.25);
    }

    .bn-section-title {
        font-size: 0.72rem;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        flex: 1;
    }

    .bn-subsection-label {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.72rem;
        font-weight: 700;
        color: #475569;
        letter-spacing: 0.4px;
        text-transform: uppercase;
        margin-bottom: 10px;
        margin-top: 4px;
    }

    .bn-subsection-label svg { color: #00a859; flex-shrink: 0; }

    .bnf-grid { display: grid; gap: 16px; }
    .bnf-grid-3 { grid-template-columns: repeat(3, 1fr); }
    .mt-2 { margin-top: 8px; }

    .bn-field { display: flex; flex-direction: column; gap: 6px; }

    .bn-label {
        font-size: 0.71rem;
        font-weight: 700;
        color: #64748b;
        letter-spacing: 0.2px;
        display: flex; align-items: center; gap: 3px;
    }

    .bn-req { color: #ef4444; font-size: 0.8rem; line-height: 1; }

    .bn-input {
        height: 42px;
        padding: 0 14px;
        border: 1.5px solid #e2e8f0;
        border-radius: 11px;
        font-size: 0.86rem;
        color: #0f172a;
        background: #fff;
        outline: none;
        transition: border-color 0.18s, box-shadow 0.18s, background 0.18s;
        width: 100%;
        -webkit-appearance: none;
        appearance: none;
    }

    .bn-input[type="date"] { padding: 0 12px; }
    .bn-input.bn-invalid, .bn-textarea.bn-invalid, .bn-select.bn-invalid {
        border-color: #ef4444 !important;
        box-shadow: 0 0 0 3px rgba(239,68,68,0.08) !important;
    }

    .bn-field-error {
        font-size: 0.7rem;
        color: #dc2626;
        font-weight: 500;
        margin: 0; padding: 0;
        display: block;
    }

    .bn-input:hover { border-color: #94a3b8; }
    .bn-input:focus { border-color: #00a859; box-shadow: 0 0 0 3px rgba(0,168,89,0.12); background: #fafffe; }

    .bn-textarea {
        padding: 10px 14px;
        border: 1.5px solid #e2e8f0;
        border-radius: 11px;
        font-size: 0.86rem;
        color: #0f172a;
        background: #fff;
        outline: none;
        transition: border-color 0.18s, box-shadow 0.18s;
        width: 100%;
        resize: vertical;
        min-height: 70px;
    }

    .bn-textarea:hover { border-color: #94a3b8; }
    .bn-textarea:focus { border-color: #00a859; box-shadow: 0 0 0 3px rgba(0,168,89,0.12); background: #fafffe; }

    .bn-select-wrap { position: relative; }

    .bn-select {
        height: 42px;
        padding: 0 36px 0 14px;
        border: 1.5px solid #e2e8f0;
        border-radius: 11px;
        font-size: 0.86rem;
        color: #0f172a;
        background: #fff;
        outline: none;
        transition: border-color 0.18s, box-shadow 0.18s;
        width: 100%;
        -webkit-appearance: none;
        appearance: none;
        cursor: pointer;
    }

    .bn-select:hover { border-color: #94a3b8; }
    .bn-select:focus { border-color: #00a859; box-shadow: 0 0 0 3px rgba(0,168,89,0.12); background: #fafffe; }

    .bn-select-arrow {
        position: absolute;
        right: 12px; top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }

    .bn-divider { height: 1px; background: #f1f5f9; margin: 16px 0; }

    /* ── Radio group (Source of Funds) ── */
    .bn-radio-group {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .bn-radio-card {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 9px 16px;
        border: 1.5px solid #e2e8f0;
        border-radius: 11px;
        cursor: pointer;
        font-size: 0.86rem;
        color: #0f172a;
        background: #fff;
        transition: border-color 0.18s, box-shadow 0.18s, background 0.18s;
        user-select: none;
    }

    .bn-radio-card:hover { border-color: #94a3b8; }

    .bn-radio-card.checked {
        border-color: #00a859;
        background: #f0fdf8;
        box-shadow: 0 0 0 3px rgba(0,168,89,0.1);
    }

    .bn-radio-input {
        position: absolute;
        opacity: 0; width: 0; height: 0;
        pointer-events: none;
    }

    .bn-radio-dot {
        width: 16px; height: 16px;
        border-radius: 50%;
        border: 2px solid #e2e8f0;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        transition: border-color 0.18s, background 0.18s;
    }

    .bn-radio-card.checked .bn-radio-dot {
        border-color: #00a859;
        background: #00a859;
        box-shadow: inset 0 0 0 3px #fff;
    }

    /* ── Footer ── */
    .bn-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 6px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .bn-footer-hint { font-size: 0.72rem; color: #94a3b8; display: flex; align-items: center; gap: 3px; }

    .bn-btn-next {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 13px 28px;
        background: linear-gradient(90deg, #00a859 0%, #0056b3 100%);
        color: #fff;
        border: none;
        border-radius: 13px;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        transition: filter 0.18s, transform 0.15s, box-shadow 0.18s;
        box-shadow: 0 4px 18px rgba(0,168,89,0.3);
    }

    .bn-btn-next:hover { filter: brightness(1.07); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,168,89,0.38); }
    .bn-btn-next:active { transform: translateY(0); filter: brightness(0.97); }

    .bn-btn-arrow {
        width: 30px; height: 30px;
        background: rgba(255,255,255,0.2);
        border-radius: 9px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .bn-btn-back {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 13px 20px;
        background: #fff;
        color: #475569;
        border: 1.5px solid #e2e8f0;
        border-radius: 13px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: border-color 0.18s, color 0.18s, transform 0.15s;
    }

    .bn-btn-back:hover { border-color: #94a3b8; color: #0f172a; transform: translateY(-1px); }

    .bn-btn-arrow-left {
        width: 28px; height: 28px;
        background: #f1f5f9;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    @@media (max-width: 768px) {
        .bnf-grid-3 { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 480px) {
        .bnf-grid-3 { grid-template-columns: 1fr; }
        .bn-section { padding: 16px; border-radius: 14px; }
        .bn-footer { flex-direction: column; align-items: stretch; }
        .bn-btn-next, .bn-btn-back { justify-content: center; }
    }
</style>

@code {
    [Parameter] public BeneficiaryDTO.PageModel BeneficiaryModel { get; set; } = new();
    [Parameter] public EventCallback<BeneficiaryDTO.PageModel> BeneficiaryModelChanged { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private bool showErrors = false;
    private List<string> sourceOptions = new() { "Salary", "Business", "Inheritance", "Others" };

    private void SetSourceOfFunds(string source)
    {
        BeneficiaryModel.SourceOfFunds = source;
        if (source != "Others")
            BeneficiaryModel.SourceOfFundsOther = null;
    }

    private bool IsValid()
    {
        if (BeneficiaryModel.TrustType == TrustType.None) return false;
        if (string.IsNullOrWhiteSpace(BeneficiaryModel.BeneficiaryName)) return false;
        if (BeneficiaryModel.Birthday == null) return false;
        if (string.IsNullOrWhiteSpace(BeneficiaryModel.PlaceOfBirth)) return false;
        if (string.IsNullOrWhiteSpace(BeneficiaryModel.Nationality)) return false;
        if (string.IsNullOrWhiteSpace(BeneficiaryModel.NatureOfWork)) return false;
        if (string.IsNullOrWhiteSpace(BeneficiaryModel.Address)) return false;
        if (string.IsNullOrWhiteSpace(BeneficiaryModel.SourceOfFunds)) return false;
        if (BeneficiaryModel.SourceOfFunds == "Others" && string.IsNullOrWhiteSpace(BeneficiaryModel.SourceOfFundsOther)) return false;
        return true;
    }

    private async Task Next()
    {
        showErrors = true;
        if (!IsValid()) return;

        await BeneficiaryModelChanged.InvokeAsync(BeneficiaryModel);
        await OnNext.InvokeAsync();
    }
}

@using System.ComponentModel
@using System.Reflection
@using CIS.Assets.Enum
@using CIS.Client.Services
@inject IndividualService IndividualService

<div class="card shadow-sm p-4 mb-4">
    <h5>Step 5: Employment Information</h5>

    <div class="row g-3">
        @* Employment Status *@
        <div class="col-md-6">
            <label class="form-label">Employment Status</label>
            <InputSelect @bind-Value="Model.EmploymentStatus" class="form-select">
                <option value="">-- Select --</option>
                @foreach (EmploymentStatus status in Enum.GetValues<EmploymentStatus>())
                {
                    <option value="@status">@GetEnumDescription(status)</option>
                }
            </InputSelect>
            @if (Model.EmploymentStatus == EmploymentStatus.Others)
            {
                <InputText @bind-Value="Model.EmploymentStatusOther" class="form-control mt-2" placeholder="Please specify status" />
            }
        </div>

        @* Type of Employment *@
        <div class="col-md-6">
            <label class="form-label">Type of Employment</label>
            <InputSelect @bind-Value="Model.TypeOfEmployment" class="form-select">
                <option value="">-- Select --</option>
                @foreach (TypeOfEmployment type in Enum.GetValues<TypeOfEmployment>())
                {
                    <option value="@type">@GetEnumDescription(type)</option>
                }
            </InputSelect>
            @if (Model.TypeOfEmployment == TypeOfEmployment.Others)
            {
                <InputText @bind-Value="Model.TypeOfEmploymentOther" class="form-control mt-2" placeholder="Specify employment type" />
            }
            @if (Model.TypeOfEmployment == TypeOfEmployment.OFW)
            {
                <InputText @bind-Value="Model.OFWCountry" class="form-control mt-2" placeholder="Country of Employment" />
            }
        </div>

        <div class="col-md-6">
            <label class="form-label">Educational Attainment</label>
            <InputText @bind-Value="Model.EducationalAttainment" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Nature of Work</label>
            <InputText @bind-Value="Model.NatureOfWork" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Average Monthly Income</label>
            <InputSelect @bind-Value="Model.AverageMonthlyIncome" class="form-select">
                <option value="">-- Select --</option>
                @foreach (AverageMonthlyIncome amt in Enum.GetValues<AverageMonthlyIncome>())
                {
                    <option value="@amt">@GetEnumDescription(amt)</option>
                }
            </InputSelect>
        </div>

        <div class="col-md-6">
            <label class="form-label">Source of Funds</label>
            <InputSelect @bind-Value="Model.SourceOfFunds" class="form-select">
                <option value="">-- Select --</option>
                @foreach (SourceOfFunds src in Enum.GetValues<SourceOfFunds>())
                {
                    <option value="@src">@GetEnumDescription(src)</option>
                }
            </InputSelect>
            @if (Model.SourceOfFunds == SourceOfFunds.Others)
            {
                <InputText @bind-Value="Model.SourceOfFundsOther" class="form-control mt-2" placeholder="Specify source of funds" />
            }
        </div>
    </div>
</div>

<div class="card shadow-sm p-4 mt-4">
    <h6>Employer / Business Details</h6>
    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label">Name of Employer</label>
            <InputText @bind-Value="Model.NameOfEmployer" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Position / Rank</label>
            <InputText @bind-Value="Model.PositionRank" class="form-control" />
        </div>

        @* Employer Address Breakdown *@
        <div class="col-md-3">
            <label class="form-label">Building No.</label>
            <InputText @bind-Value="Model.EmployerBuildingNo" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Street</label>
            <InputText @bind-Value="Model.EmployerStreet" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Brgy / District</label>
            <InputText @bind-Value="Model.EmployerBrgyDistrict" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">City / Town</label>
            <InputText @bind-Value="Model.EmployerCityTown" class="form-control" />
        </div>

        @* Contact Details *@
        <div class="col-md-6">
            <label class="form-label">Employer Phone No.</label>
            <InputText @bind-Value="Model.EmployerPhoneNumber" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Employer Email</label>
            <InputText @bind-Value="Model.EmployerEmailAddress" class="form-control" />
        </div>
    </div>

    <div class="d-flex justify-content-between mt-5">
        <button type="button" class="btn btn-outline-secondary" @onclick="OnBack">Back</button>
        <button type="button" class="btn btn-primary px-5" @onclick="Next">Next</button>
    </div>
</div>

@code {
    [Parameter] public IndividualEmploymentDTO.PageModel Model { get; set; } = new();
    [Parameter] public long CustomerId { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private async Task Next()
    {
        Model.CustomerID = CustomerId;

        // Clear dependent fields when selection changes
        if (Model.EmploymentStatus != EmploymentStatus.Others) Model.EmploymentStatusOther = null;
        if (Model.TypeOfEmployment != TypeOfEmployment.Others) Model.TypeOfEmploymentOther = null;
        if (Model.TypeOfEmployment != TypeOfEmployment.OFW) Model.OFWCountry = null;
        if (Model.SourceOfFunds != SourceOfFunds.Others) Model.SourceOfFundsOther = null;

        await OnNext.InvokeAsync();
    }

    private string GetEnumDescription<TEnum>(TEnum value) where TEnum : Enum
    {
        var field = value.GetType().GetField(value.ToString());
        var attr = field?.GetCustomAttribute<DescriptionAttribute>();
        return attr?.Description ?? value.ToString();
    }
}
@page "/porac-bank-cis"
@using CIS.Assets.DTO
@using CIS.Assets.Enum
@using CIS.Client.Services
@using System.ComponentModel
@using System.Reflection
@inject IJSRuntime JS
@inject IndividualService IndividualService

<HeadContent>
    <style>
        @@media print {
            /* Hide the entire Blazor app shell — only the cis-page prints */
            body > * { display: none !important; }
            body > app > * { display: none !important; }

            /* Show only the Blazor-rendered article/main that contains our page */
            body .cis-page,
            body article .cis-page,
            body main .cis-page,
            body .content .cis-page,
            body .page .cis-page,
            body .mud-main-content .cis-page { display: block !important; width: 100% !important; }

            /* Un-hide each ancestor wrapper of .cis-page so it renders */
            body > app,
            body > app > div,
            body > app > div > div,
            body article,
            body main,
            body .content,
            body .page,
            body .mud-main-content,
            body .mud-layout,
            body #app { display: block !important; }

            /* Kill any padding/margin on wrappers */
            body, html { margin: 0 !important; padding: 0 !important; }
            body article, body main, body .content, body .page,
            body .mud-main-content { margin: 0 !important; padding: 0 !important; }

            /* Hide nav, sidebar, appbar, header explicitly too */
            nav, aside, header, footer,
            .sidebar, .top-row, .nav-menu, .navbar,
            .mud-drawer, .mud-appbar, .mud-layout-drawer,
            .mud-nav-menu, .mud-overlay,
            .app-bar, .no-print { display: none !important; }
        }
    </style>
</HeadContent>

<div class="cis-page">

    @* ══════════════════════════════════════
       PAGE 1 — INDIVIDUAL INFORMATION
    ══════════════════════════════════════ *@
    <div class="cis-sheet">

        @* ── Header ── *@
        <div class="cis-header">
            <div>
                <div class="cis-title">CUSTOMER INFORMATION SHEET</div>
            </div>
            <div class="cis-bank">
                <div class="cis-bank-name">PoracBank</div>
                <div class="cis-bank-sub">A Rural Bank Since 1968</div>
            </div>
        </div>

        @* ── Meta ── *@
        <div class="cis-meta">
            <div class="cis-meta-left">
                <span class="lbl">CUSTOMER CATEGORY</span>
                <span class="cis-chk">@(Customer.CustomerCategories != null && Customer.CustomerCategories.Contains(CustomerCategory.LoanBorrower) ? "✓" : "")</span><span class="chk-lbl">Borrower</span>
                <span class="cis-chk">@(Customer.CustomerCategories != null && Customer.CustomerCategories.Contains(CustomerCategory.LoanCoMaker) ? "✓" : "")</span><span class="chk-lbl">Loan Co-Maker</span>
                <span class="cis-chk">@(Customer.CustomerCategories != null && Customer.CustomerCategories.Contains(CustomerCategory.Depositor) ? "✓" : "")</span><span class="chk-lbl">Depositor</span>
            </div>
            <div class="cis-meta-right">
                <span class="lbl">CID NO.</span>
                <span class="val-lg">@Customer.CIDNumber</span>
            </div>
        </div>

        <div class="cis-guidelines">
            1. Fill in all blank spaces with the proper information &nbsp;&nbsp; 2. Items with * are required to be filled in. &nbsp;&nbsp; 3. For assistance/ question, please approach any Porac Bank personnel.
        </div>

        @* ── Section I ── *@
        <div class="sec-title">I. INDIVIDUAL INFORMATION</div>

        @* Name + Resident *@
        <div class="cis-row">
            <div class="cis-cell grow-3">
                <span class="lbl">NAME*</span>
                <div class="name-grid">
                    <div><span class="val">@Personal.FirstName</span><div class="sub-lbl">First name</div></div>
                    <div><span class="val">@Personal.MiddleName</span><div class="sub-lbl">Middle Name</div></div>
                    <div><span class="val">@Personal.LastName</span><div class="sub-lbl">Last name</div></div>
                </div>
            </div>
            <div class="cis-cell grow-1 center border-l">
                <span class="lbl">RESIDENT*</span>
                <div class="mt4">
                    <span class="cis-chk">@(Personal.IsResident ? "✓" : "")</span> YES &nbsp;
                    <span class="cis-chk">@(!Personal.IsResident ? "✓" : "")</span> NO
                </div>
            </div>
        </div>

        @* Permanent Address *@
        <div class="cis-row">
            <div class="cis-cell grow-4">
                <span class="lbl">PERMANENT ADDRESS*</span>
                <div class="val">@Address.PermanentAddress</div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">ZIP CODE</span>
                <div class="val">@Address.PermanentZipCode</div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">COUNTRY</span>
                <div class="val">@Address.PermanentCountry</div>
            </div>
        </div>

        @* Present Address *@
        <div class="cis-row">
            <div class="cis-cell grow-4">
                <span class="lbl">PRESENT ADDRESS (If different from permanent address)*</span>
                <div class="val">@Address.PresentAddress</div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">ZIP CODE</span>
                <div class="val">@Address.PresentZipCode</div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">COUNTRY</span>
                <div class="val">@Address.PresentCountry</div>
            </div>
        </div>

        @* Mailing / Citizenship / Foreigners *@
        <div class="cis-row">
            <div class="cis-cell grow-1">
                <span class="lbl">MAILING PREFERENCE*</span>
                <div><span class="cis-chk">@(Address.MailingPreference == MailingPreference.PermanentAddress ? "✓" : "")</span> <small>PERMANENT ADDRESS</small></div>
                <div><span class="cis-chk">@(Address.MailingPreference == MailingPreference.PresentAddress ? "✓" : "")</span> <small>PRESENT ADDRESS</small></div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">CITIZENSHIP*</span>
                <div><span class="cis-chk">@(Personal.Citizenship == Citizenship.Filipino ? "✓" : "")</span> <small>FILIPINO</small></div>
                <div><span class="cis-chk">@(Personal.Citizenship == Citizenship.Others ? "✓" : "")</span> <small>OTHERS @Personal.CitizenshipOther</small></div>
            </div>
            <div class="cis-cell grow-2 border-l bg-gray">
                <span class="lbl">FOR FOREIGNERS ONLY**</span>
                <div class="two-col-row">
                    <span>PASSPORT ID NO. ** <span class="val">@Foreigner.PassportIDNumber</span></span>
                    <span>EXPIRY (mm/dd/yyyy) ** <span class="val">@Foreigner.PassportExpiry?.ToString("MM/dd/yyyy")</span></span>
                </div>
                <div class="mt4">
                    <span class="cis-chk">@(Foreigner.IsACR ? "✓" : "")</span> ACR** &nbsp;
                    <span class="cis-chk">@(Foreigner.IsSIRV ? "✓" : "")</span> SIRV** &nbsp;
                    <span class="cis-chk">@(Foreigner.IsSRRV ? "✓" : "")</span> SRRV**
                </div>
            </div>
        </div>

        @* Country / DOB / Contact *@
        <div class="cis-row">
            <div class="cis-cell grow-1">
                <span class="lbl">COUNTRY OF ORIGIN*</span>
                <div class="val">@Personal.CountryOfOrigin</div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">DATE OF BIRTH (mm/dd/yyyy)*</span>
                <div class="val">@Personal.DateOfBirth?.ToString("MM/dd/yyyy")</div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">PERSONAL CONTACT DETAILS*</span>
                <div class="contact-stack">
                    <span>HOME PHONE NO. <span class="val">@Contact.HomePhoneNumber</span></span>
                    <span>MOBILE PHONE NO. <span class="val">@Contact.MobilePhoneNumber</span></span>
                    <span>EMAIL ADDRESS <span class="val">@Contact.EmailAddress</span></span>
                </div>
            </div>
        </div>

        @* Place of Birth / Gender *@
        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">PLACE OF BIRTH</span>
                <div class="val">@Personal.PlaceOfBirth</div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">GENDER*</span>
                <div class="mt4">
                    <span class="cis-chk">@(Personal.Gender == Gender.Male ? "✓" : "")</span> MALE &nbsp;
                    <span class="cis-chk">@(Personal.Gender == Gender.Female ? "✓" : "")</span> FEMALE
                </div>
            </div>
        </div>

        @* Marital Status / Spouse *@
        <div class="cis-row">
            <div class="cis-cell grow-1">
                <span class="lbl">MARITAL STATUS</span>
                <div class="status-grid">
                    <div><span class="cis-chk">@(Personal.MaritalStatus == MaritalStatus.Single ? "✓" : "")</span> <small>SINGLE</small></div>
                    <div><span class="cis-chk">@(Personal.MaritalStatus == MaritalStatus.Married ? "✓" : "")</span> <small>MARRIED</small></div>
                    <div><span class="cis-chk">@(Personal.MaritalStatus == MaritalStatus.DivorcedAnnulled ? "✓" : "")</span> <small>DIVORCED/ ANNULED</small></div>
                    <div><span class="cis-chk">@(Personal.MaritalStatus == MaritalStatus.Separated ? "✓" : "")</span> <small>SEPARATED</small></div>
                    <div><span class="cis-chk">@(Personal.MaritalStatus == MaritalStatus.Widowed ? "✓" : "")</span> <small>WIDOWED</small></div>
                </div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">SPOUSE'S NAME*</span>
                <div class="name-grid">
                    <div><span class="val">@Family.SpouseLastName</span><div class="sub-lbl">Last name</div></div>
                    <div><span class="val">@Family.SpouseGivenName</span><div class="sub-lbl">Given name</div></div>
                    <div><span class="val">@Family.SpouseMiddleName</span><div class="sub-lbl">Middle Name</div></div>
                </div>
            </div>
        </div>

        @* Mother's Maiden Name *@
        <div class="cis-row">
            <div class="cis-cell grow-3 border-l">
                <span class="lbl">MOTHER'S MAIDEN NAME*</span>
                <div class="name-grid">
                    <div><span class="val">@Family.MotherMaidenLastName</span><div class="sub-lbl">Last name</div></div>
                    <div><span class="val">@Family.MotherMaidenGivenName</span><div class="sub-lbl">Given name</div></div>
                    <div><span class="val">@Family.MotherMaidenMiddleName</span><div class="sub-lbl">Middle Name</div></div>
                </div>
            </div>
        </div>

        @* IDs Presented / Personal Identification *@
        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">IDs PRESENTED*</span>
                <div class="id-row">
                    <span class="cis-chk">@(!string.IsNullOrEmpty(Identification.DriversLicenseIDNo) ? "✓" : "")</span>
                    <small>DRIVER'S LICENSE &nbsp; ID NO. <span class="val">@Identification.DriversLicenseIDNo</span> &nbsp; EXPIRY <span class="val">@Identification.DriversLicenseExpiry?.ToString("MM/dd/yyyy")</span></small>
                </div>
                <div class="id-row">
                    <span class="cis-chk">@(!string.IsNullOrEmpty(Identification.PassportIDNo) ? "✓" : "")</span>
                    <small>PASSPORT &nbsp; ID NO. <span class="val">@Identification.PassportIDNo</span> &nbsp; EXPIRY <span class="val">@Identification.PassportIDExpiry?.ToString("MM/dd/yyyy")</span></small>
                </div>
                <div class="id-row">
                    <span class="cis-chk">@(!string.IsNullOrEmpty(Identification.OtherIDType) ? "✓" : "")</span>
                    <small>OTHERS &nbsp; ID TYPE/ NO. <span class="val">@Identification.OtherIDType / @Identification.OtherIDNumber</span> &nbsp; EXPIRY <span class="val">@Identification.OtherIDExpiry?.ToString("MM/dd/yyyy")</span></small>
                </div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">PERSONAL IDENTIFICATION*</span>
                <div class="id-stack">
                    <div>TIN NO. <span class="val">@Identification.TINNumber</span></div>
                    <div>SSS NO. <span class="val">@Identification.SSSNumber</span></div>
                    <div>GSIS NO. <span class="val">@Identification.GSISNumber</span></div>
                </div>
            </div>
        </div>

        @* Employment Status / Income / Source of Funds *@
        <div class="cis-row">
            <div class="cis-cell grow-1">
                <span class="lbl">EMPLOYMENT STATUS*</span>
                <div><span class="cis-chk">@(Employment.EmploymentStatus == EmploymentStatus.Employed ? "✓" : "")</span> <small>EMPLOYED</small></div>
                <div><span class="cis-chk">@(Employment.EmploymentStatus == EmploymentStatus.SelfEmployed ? "✓" : "")</span> <small>SELF-EMPLOYED</small></div>
                <div><span class="cis-chk">@(Employment.EmploymentStatus == EmploymentStatus.Unemployed ? "✓" : "")</span> <small>UNEMPLOYED</small></div>
                <div><span class="cis-chk">@(Employment.EmploymentStatus == EmploymentStatus.Others ? "✓" : "")</span> <small>OTHERS @Employment.EmploymentStatusOther</small></div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">EDUCATIONAL ATTAINMENT</span>
                <div class="val">@Employment.EducationalAttainment</div>
                <div class="mt6">
                    <span class="lbl">NATURE OF WORK*</span>
                    <div class="val">@Employment.NatureOfWork</div>
                </div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">TYPE OF EMPLOYMENT*</span>
                <div><span class="cis-chk">@(Employment.TypeOfEmployment == TypeOfEmployment.Government ? "✓" : "")</span> <small>GOVERNMENT</small></div>
                <div><span class="cis-chk">@(Employment.TypeOfEmployment == TypeOfEmployment.Private ? "✓" : "")</span> <small>PRIVATE</small></div>
                <div><span class="cis-chk">@(Employment.TypeOfEmployment == TypeOfEmployment.OFW ? "✓" : "")</span> <small>OFW @(!string.IsNullOrEmpty(Employment.OFWCountry) ? $"— {Employment.OFWCountry}" : "")</small></div>
                <div><span class="cis-chk">@(Employment.TypeOfEmployment == TypeOfEmployment.Others ? "✓" : "")</span> <small>OTHERS @Employment.TypeOfEmploymentOther</small></div>
            </div>
        </div>

        @* Monthly Income / Source of Funds *@
        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">AVERAGE MONTHLY INCOME*</span>
                <div class="income-grid">
                    <span><span class="cis-chk">@(Employment.AverageMonthlyIncome == AverageMonthlyIncome.UnderP10000 ? "✓" : "")</span> <small>UNDER P10,000.00</small></span>
                    <span><span class="cis-chk">@(Employment.AverageMonthlyIncome == AverageMonthlyIncome.P10001ToP20000 ? "✓" : "")</span> <small>P10,001.00 -P20,000.00</small></span>
                    <span><span class="cis-chk">@(Employment.AverageMonthlyIncome == AverageMonthlyIncome.P20001ToP50000 ? "✓" : "")</span> <small>P20,001.00-P50,000.00</small></span>
                    <span><span class="cis-chk">@(Employment.AverageMonthlyIncome == AverageMonthlyIncome.P50001ToP100000 ? "✓" : "")</span> <small>P50,001.00-P100,000.00</small></span>
                    <span><span class="cis-chk">@(Employment.AverageMonthlyIncome == AverageMonthlyIncome.P100001ToP200000 ? "✓" : "")</span> <small>P100,001.00-P200,000.00</small></span>
                    <span><span class="cis-chk">@(Employment.AverageMonthlyIncome == AverageMonthlyIncome.AboveP200001 ? "✓" : "")</span> <small>ABOVE P200,001.00</small></span>
                </div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">SOURCE OF FUNDS*</span>
                <div><span class="cis-chk">@(Employment.SourceOfFunds == SourceOfFunds.Salary ? "✓" : "")</span> <small>SALARY</small></div>
                <div><span class="cis-chk">@(Employment.SourceOfFunds == SourceOfFunds.Pension ? "✓" : "")</span> <small>PENSION</small></div>
                <div><span class="cis-chk">@(Employment.SourceOfFunds == SourceOfFunds.Business ? "✓" : "")</span> <small>BUSINESS</small></div>
                <div><span class="cis-chk">@(Employment.SourceOfFunds == SourceOfFunds.RegularRemittance ? "✓" : "")</span> <small>REGULAR REMITTANCE</small></div>
                <div><span class="cis-chk">@(Employment.SourceOfFunds == SourceOfFunds.Others ? "✓" : "")</span> <small>OTHERS (PLEASE SPECIFY) @Employment.SourceOfFundsOther</small></div>
            </div>
        </div>

        @* Employer *@
        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">NAME OF EMPLOYER</span>
                <div class="val">@Employment.NameOfEmployer</div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">EMPLOYER'S ADDRESS*</span>
                <div class="employer-addr">
                    <span><span class="val">@Employment.EmployerBuildingNo</span><br/><div class="sub-lbl">Building No.</div></span>
                    <span><span class="val">@Employment.EmployerStreet</span><br/><div class="sub-lbl">Street</div></span>
                    <span><span class="val">@Employment.EmployerBrgyDistrict</span><br/><div class="sub-lbl">Brgy / District</div></span>
                    <span><span class="val">@Employment.EmployerCityTown</span><br/><div class="sub-lbl">City/ Town</div></span>
                </div>
            </div>
        </div>

        @* Employer Contact / Position *@
        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">CONTACT DETAILS OF EMPLOYER*</span>
                <div class="contact-stack">
                    <span>PHONE NO. <span class="val">@Employment.EmployerPhoneNumber</span></span>
                    <span>E-MAIL ADDRESS <span class="val">@Employment.EmployerEmailAddress</span></span>
                </div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">POSITION/ RANK</span>
                <div class="val">@Employment.PositionRank</div>
            </div>
        </div>

        @* Purpose / Products *@
        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">PURPOSE OF THE ACCOUNT*</span>
                <div><span class="cis-chk">@(AccPurpose.PurposeOfAccount == PurposeOfAccount.PersonalSavings ? "✓" : "")</span> <small>PERSONAL SAVINGS</small></div>
                <div><span class="cis-chk">@(AccPurpose.PurposeOfAccount == PurposeOfAccount.LoanPurposes ? "✓" : "")</span> <small>FOR LOAN PURPOSES</small></div>
                <div><span class="cis-chk">@(AccPurpose.PurposeOfAccount == PurposeOfAccount.BusinessPurposes ? "✓" : "")</span> <small>FOR BUSINESS PURPOSES</small></div>
                <div><span class="cis-chk">@(AccPurpose.PurposeOfAccount == PurposeOfAccount.BusinessOperations ? "✓" : "")</span> <small>BUSINESS OPERATIONS</small></div>
                <div><span class="cis-chk">@(AccPurpose.PurposeOfAccount == PurposeOfAccount.Payroll ? "✓" : "")</span> <small>PAYROLL</small></div>
                <div><span class="cis-chk">@(AccPurpose.PurposeOfAccount == PurposeOfAccount.Investment ? "✓" : "")</span> <small>INVESTMENT</small></div>
                <div><span class="cis-chk">@(AccPurpose.PurposeOfAccount == PurposeOfAccount.Others ? "✓" : "")</span> <small>OTHERS @AccPurpose.PurposeOfAccountOther</small></div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">PRODUCTS TO BE AVAILED*</span>
                @{
                    // DB stores comma-separated display values e.g. "Savings,Current,TD,Loan,Sale Of ROPA,Others"
                    var acpProducts = (AccPurpose.ProductsAvailed ?? "").Split(',').Select(x => x.Trim()).ToHashSet(StringComparer.OrdinalIgnoreCase);
                }
                <div class="products-grid">
                    <span><span class="cis-chk">@(acpProducts.Contains("Savings") ? "✓" : "")</span> <small>SAVINGS</small></span>
                    <span><span class="cis-chk">@(acpProducts.Contains("TD") || acpProducts.Contains("TimeDeposit") ? "✓" : "")</span> <small>TIME DEPOSIT</small></span>
                    <span><span class="cis-chk">@(acpProducts.Contains("Sale Of ROPA") || acpProducts.Contains("SaleOfRopa") ? "✓" : "")</span> <small>SALE OF ROPA</small></span>
                    <span><span class="cis-chk">@(acpProducts.Contains("Current") || acpProducts.Contains("Checking") ? "✓" : "")</span> <small>CURRENT</small></span>
                    <span><span class="cis-chk">@(acpProducts.Contains("Loan") ? "✓" : "")</span> <small>LOAN</small></span>
                    <span><span class="cis-chk">@(acpProducts.Contains("Others") ? "✓" : "")</span> <small>OTHERS @AccPurpose.ProductsAvailedOther</small></span>
                </div>
            </div>
        </div>

        @* Business Interests Table *@
        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">BUSINESS INTEREST (PLEASE USE ANOTHER SHEET IF NECESSARY)*</span>
                <table class="inline-table">
                    <thead>
                        <tr><th>NAME</th><th>% OF OWNERSHIP</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var biz in Personal.BusinessInterests)
                        {
                            <tr><td class="val">@biz.BusinessName</td><td class="val">@biz.OwnershipPercentage%</td></tr>
                        }
                        @for (int i = Personal.BusinessInterests.Count; i < 3; i++) { <tr><td>&nbsp;</td><td></td></tr> }
                    </tbody>
                </table>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">FOR PAST/ PRESENT GOVERNMENT OFFICIALS*</span>
                <table class="inline-table">
                    <thead>
                        <tr><th>HIGHEST POSITION OCCUPIED</th><th>PERIOD COVERED</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var pep in Personal.GovOfficialPositions)
                        {
                            <tr><td class="val">@pep.Position</td><td class="val">@pep.Period</td></tr>
                        }
                        @if (!Personal.GovOfficialPositions.Any() && (Personal.IsGovOfficial || !string.IsNullOrWhiteSpace(Personal.GovPosition)))
                        {
                            <tr><td class="val">@Personal.GovPosition</td><td class="val">@Personal.GovPeriod</td></tr>
                        }
                        @{
                            int pepFilled = Personal.GovOfficialPositions.Any()
                                ? Personal.GovOfficialPositions.Count
                                : (Personal.IsGovOfficial || !string.IsNullOrWhiteSpace(Personal.GovPosition) ? 1 : 0);
                        }
                        @for (int i = pepFilled; i < 3; i++) { <tr><td>&nbsp;</td><td></td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        @* Gov Relatives Table *@
        <div class="lbl-standalone">RELATIONSHIP TO GOVERNMENT OFFICIAL (WITHIN THE 1ST DEGREE OF CONSAGUINITY AND AFFINITY)*</div>
        <table class="full-table">
            <thead>
                <tr><th>NAME</th><th>RELATIONSHIP</th><th>HIGHEST POSITION OCCUPIED</th><th>PERIOD COVERED</th></tr>
            </thead>
            <tbody>
                @foreach (var rel in Personal.GovRelatives)
                {
                    <tr>
                        <td class="val">@rel.Name</td>
                        <td class="val">@rel.Relationship</td>
                        <td class="val">@rel.Position</td>
                        <td class="val">@rel.PeriodCovered</td>
                    </tr>
                }
                @for (int i = Personal.GovRelatives.Count; i < 3; i++) { <tr><td>&nbsp;</td><td></td><td></td><td></td></tr> }
            </tbody>
        </table>

    </div>@* end page 1 *@

    @* ══════════════════════════════════════
       PAGE 2 — BUSINESS INFORMATION
    ══════════════════════════════════════ *@
    <div class="cis-sheet page-break">

        @* ── Page 2 Header ── *@
        <div class="cis-header">
            <div></div>
            <div class="cis-bank">
                <div class="cis-bank-name">PoracBank</div>
                <div class="cis-bank-sub">A Rural Bank Since 1968</div>
            </div>
        </div>

        @* ── Section II: Business Information ── *@
        <div class="sec-title">II. BUSINESS INFORMATION</div>

        @* Sector / Name *@
        <div class="cis-row">
            <div class="cis-cell grow-1">
                <span class="lbl">SECTOR</span>
                <div><span class="cis-chk">@(BusinessInfo.IsGovernment ? "✓" : "")</span> <small>GOVERNMENT</small></div>
                <div><span class="cis-chk">@(BusinessInfo.IsPrivate ? "✓" : "")</span> <small>PRIVATE</small></div>
            </div>
            <div class="cis-cell grow-3 border-l">
                <span class="lbl">NAME OF BUSINESS*</span>
                <div class="val">@BusinessInfo.NameOfBusiness</div>
            </div>
        </div>

        @* Type of Org / Business Address *@
        <div class="cis-row">
            <div class="cis-cell grow-1">
                <span class="lbl">TYPE OF ORGANIZATION*</span>
                <div><span class="cis-chk">@(BusinessInfo.TypeOfOrganization == TypeOfOrganization.SoleProprietorship ? "✓" : "")</span> <small>SOLE PROPRIETORSHIP</small></div>
                <div><span class="cis-chk">@(BusinessInfo.TypeOfOrganization == TypeOfOrganization.Partnership ? "✓" : "")</span> <small>PARTNERSHIP</small></div>
                <div><span class="cis-chk">@(BusinessInfo.TypeOfOrganization == TypeOfOrganization.Corporation ? "✓" : "")</span> <small>CORPORATION</small></div>
                <div><span class="cis-chk">@(BusinessInfo.TypeOfOrganization == TypeOfOrganization.Cooperative ? "✓" : "")</span> <small>COOPERATIVE</small></div>
                <div><span class="cis-chk">@(BusinessInfo.TypeOfOrganization == TypeOfOrganization.Association ? "✓" : "")</span> <small>ASSOCIATION</small></div>
                <div><span class="cis-chk">@(BusinessInfo.TypeOfOrganization == TypeOfOrganization.Others ? "✓" : "")</span> <small>OTHERS @BusinessInfo.TypeOfOrganizationOther</small></div>
            </div>
            <div class="cis-cell grow-3 border-l">
                <span class="lbl">BUSINESS ADDRESS*</span>
                <div class="val">@Address.BusinessAddress</div>
                <div class="mt8">
                    <span class="lbl">PRINCIPAL ADDRESS (If different from business address)*</span>
                    <div class="val">@Address.PrincipalAddress</div>
                </div>
            </div>
        </div>

        @* Reg Details *@
        <div class="cis-row">
            <div class="cis-cell grow-1">
                <span class="lbl">DATE OF REGISTRATION (mm/dd/yyyy)*</span>
                <div class="val">@BusinessInfo.DateOfRegistration?.ToString("MM/dd/yyyy")</div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">BUSINESS REGISTRATION NUMBER/ EXPIRY*</span>
                <div class="val">@BusinessInfo.BusinessRegNumber &nbsp;/ &nbsp;@BusinessInfo.BusinessRegExpiry?.ToString("MM/dd/yyyy")</div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">PLACE OF REGISTRATION/ ORIGIN*</span>
                <div class="val">@BusinessInfo.PlaceOfRegistration</div>
            </div>
        </div>

        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">NATURE OF BUSINESS*</span>
                <div class="val">@BusinessInfo.NatureOfBusiness</div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">TAX IDENTIFICATION NUMBER*</span>
                <div class="val">@BusinessInfo.TaxIdentificationNumber</div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">DTI CERT. REGISTRATION NO. / EXPIRY*</span>
                <div class="val">@BusinessInfo.DTICertNumber &nbsp;/ &nbsp;@BusinessInfo.DTICertExpiry?.ToString("MM/dd/yyyy")</div>
            </div>
        </div>

        @* Purpose / Products / Contact *@
        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">PURPOSE OF THE ACCOUNT*</span>
                <div><span class="cis-chk">@(AccountContact.AccountPurpose == PurposeOfAccount.PersonalSavings ? "✓" : "")</span> <small>PERSONAL SAVINGS</small></div>
                <div><span class="cis-chk">@(AccountContact.AccountPurpose == PurposeOfAccount.LoanPurposes ? "✓" : "")</span> <small>FOR LOAN PURPOSES</small></div>
                <div><span class="cis-chk">@(AccountContact.AccountPurpose == PurposeOfAccount.BusinessPurposes ? "✓" : "")</span> <small>FOR BUSINESS PURPOSES</small></div>
                <div><span class="cis-chk">@(AccountContact.AccountPurpose == PurposeOfAccount.BusinessOperations ? "✓" : "")</span> <small>BUSINESS OPERATIONS</small></div>
                <div><span class="cis-chk">@(AccountContact.AccountPurpose == PurposeOfAccount.Payroll ? "✓" : "")</span> <small>PAYROLL</small></div>
                <div><span class="cis-chk">@(AccountContact.AccountPurpose == PurposeOfAccount.Investment ? "✓" : "")</span> <small>INVESTMENT</small></div>
                <div><span class="cis-chk">@(AccountContact.AccountPurpose == PurposeOfAccount.Others ? "✓" : "")</span> <small>OTHERS @AccountContact.AccountPurposeOther</small></div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">PRODUCT TO BE AVAILED*</span>
                @{
                    var acctProducts = (AccountContact.ProductsAvailed ?? "").Split(',').Select(x => x.Trim()).ToHashSet(StringComparer.OrdinalIgnoreCase);
                }
                <div class="products-grid">
                    <span><span class="cis-chk">@(acctProducts.Contains("Savings") ? "✓" : "")</span> <small>SAVINGS</small></span>
                    <span><span class="cis-chk">@(acctProducts.Contains("TD") || acctProducts.Contains("TimeDeposit") ? "✓" : "")</span> <small>TD</small></span>
                    <span><span class="cis-chk">@(acctProducts.Contains("Sale Of ROPA") || acctProducts.Contains("SaleOfRopa") ? "✓" : "")</span> <small>SALE OF ROPA</small></span>
                    <span><span class="cis-chk">@(acctProducts.Contains("Current") || acctProducts.Contains("Checking") ? "✓" : "")</span> <small>CURRENT</small></span>
                    <span><span class="cis-chk">@(acctProducts.Contains("Loan") ? "✓" : "")</span> <small>LOAN</small></span>
                </div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">CONTACT INFORMATION*</span>
                <div class="contact-stack">
                    <span>PHONE NUMBER <span class="val">@AccountContact.OfficePhoneNo</span></span>
                    <span>E-MAIL ADDRESS <span class="val">@AccountContact.EmailAddress</span></span>
                    <span>CONTACT PERSON <span class="val">@AccountContact.ContactPerson</span></span>
                </div>
            </div>
        </div>

        @* Income / Size *@
        <div class="cis-row">
            <div class="cis-cell grow-3">
                <span class="lbl">AVERAGE ANNUAL INCOME*</span>
                <div class="income-grid">
                    <span><span class="cis-chk">@(BusinessInfo.AverageAnnualIncome == AverageAnnualIncome.BelowP100000 ? "✓" : "")</span> <small>BELOW P100,000.00</small></span>
                    <span><span class="cis-chk">@(BusinessInfo.AverageAnnualIncome == AverageAnnualIncome.P500001ToP1M ? "✓" : "")</span> <small>P500,001.00 -P1M</small></span>
                    <span><span class="cis-chk">@(BusinessInfo.AverageAnnualIncome == AverageAnnualIncome.P100001ToP500000 ? "✓" : "")</span> <small>P100,001.00 -P500,000.00</small></span>
                    <span><span class="cis-chk">@(BusinessInfo.AverageAnnualIncome == AverageAnnualIncome.MoreThanP1M ? "✓" : "")</span> <small>MORE THAN P1M</small></span>
                </div>
            </div>
            <div class="cis-cell grow-3 border-l">
                <span class="lbl">SIZE OF BUSINESS*</span>
                <div class="income-grid">
                    <span><span class="cis-chk">@(BusinessInfo.SizeOfBusiness == SizeOfBusiness.Micro ? "✓" : "")</span> <small>Micro (assets of up to P3M)</small></span>
                    <span><span class="cis-chk">@(BusinessInfo.SizeOfBusiness == SizeOfBusiness.Medium ? "✓" : "")</span> <small>Medium (assets of P15,000,001.00 to P100M)</small></span>
                    <span><span class="cis-chk">@(BusinessInfo.SizeOfBusiness == SizeOfBusiness.Small ? "✓" : "")</span> <small>Small (assets of P3,000,001.00 -P15M)</small></span>
                    <span><span class="cis-chk">@(BusinessInfo.SizeOfBusiness == SizeOfBusiness.Large ? "✓" : "")</span> <small>Large (assets of more than P100M)</small></span>
                </div>
            </div>
        </div>

        @* Section III: Beneficiary *@
        <div class="sec-title">III. FOR INDIVIDUAL AND BUSINESS ACCOUNT WITH BENEFICIARY</div>

        <div class="cis-row">
            <div class="cis-cell grow-1">
                <span class="lbl">TRUST TYPE</span>
                <div><span class="cis-chk">@(Beneficiary.TrustType == TrustType.ITF ? "✓" : "")</span> <small>IN TRUST FOR ACCOUNT</small></div>
                <div><span class="cis-chk">@(Beneficiary.TrustType == TrustType.FAO ? "✓" : "")</span> <small>FOR THE ACCOUNT OF</small></div>
            </div>
            <div class="cis-cell grow-3 border-l">
                <span class="lbl">NAME*</span>
                <div class="val">@Beneficiary.BeneficiaryName</div>
            </div>
        </div>

        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">SOURCE OF FUNDS*</span>
                <div class="products-grid">
                    <span><span class="cis-chk">@(Beneficiary.SourceOfFunds == "Salary" ? "✓" : "")</span> <small>SALARY</small></span>
                    <span><span class="cis-chk">@(Beneficiary.SourceOfFunds == "Business" ? "✓" : "")</span> <small>BUSINESS</small></span>
                    <span><span class="cis-chk">@(Beneficiary.SourceOfFunds == "Pension" ? "✓" : "")</span> <small>PENSION</small></span>
                    <span><span class="cis-chk">@(Beneficiary.SourceOfFunds == "RegularRemittance" ? "✓" : "")</span> <small>REGULAR REMITTANCE</small></span>
                    <span><span class="cis-chk">@(Beneficiary.SourceOfFunds == "Others" ? "✓" : "")</span> <small>OTHERS (Please specify)* @Beneficiary.SourceOfFundsOther</small></span>
                </div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">BIRTHDAY (MM/DD/YYYY)*</span>
                <div class="val">@Beneficiary.Birthday?.ToString("MM/dd/yyyy")</div>
            </div>
            <div class="cis-cell grow-1 border-l">
                <span class="lbl">PLACE OF BIRTH*</span>
                <div class="val">@Beneficiary.PlaceOfBirth</div>
            </div>
        </div>

        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">NATIONALITY*</span>
                <div class="val">@Beneficiary.Nationality</div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">ADDRESS*</span>
                <div class="val">@Beneficiary.Address</div>
            </div>
        </div>

        <div class="cis-row">
            <div class="cis-cell grow-1">
                <span class="lbl">NATURE OF WORK*</span>
                <div class="val">@Beneficiary.NatureOfWork</div>
            </div>
        </div>

        @* Client Acknowledgement *@
        <div class="sec-title">CLIENT'S ACKNOWLEDGEMENT</div>
        <div class="ack-text">
            By signing this form, I/We certify that all information provided herein is true and correct to the best of my knowledge. I/We further agree:<br/>
            i.&nbsp; To allow Porac Bank to verify the above information and inform Porac Bank of any changes in the information provided in the form;<br/>
            ii.&nbsp; That all deposit products and credit facilities that I/We have availed, or shall, in the future, avail from Porac Bank shall be governed by the terms and conditions set forth by Porac Bank as well as the rules and regulations of the Bangko Sentral ng Pilipinas (BSP) and such other laws, rules and regulations relative to said products and facilities.<br/>
            iii.&nbsp; To grant Porac Bank access to all information relating to my/our present and future accounts and to disclose such data and papers pertaining to my/our accounts as may be required by government regulatory authorities for purposes of compliance with relevant laws and regulations issued by appropriate regulatory authorities and agencies of the government.
        </div>
        <div class="cis-row sig-row">
            <div class="cis-cell grow-2 center">
                <div class="sig-wrapper">
                    @if (!string.IsNullOrEmpty(Acknowledgement.SignatureData))
                    {
                        <img src="@Acknowledgement.SignatureData" class="sig-img" alt="Signature" />
                    }
                    else { <div class="sig-spacer"></div> }
                    <div class="val">@Acknowledgement.PrintedName</div>
                </div>
                <div class="sub-lbl">PRINTED NAME AND SIGNATURE OF DEPOSITOR</div>
            </div>
            <div class="cis-cell grow-2 center border-l">
                <div class="sig-wrapper">
                    @if (!string.IsNullOrEmpty(Acknowledgement.SignatureData))
                    {
                        <img src="@Acknowledgement.SignatureData" class="sig-img" alt="Signature" />
                    }
                    else { <div class="sig-spacer"></div> }
                    <div class="val">@Acknowledgement.PrintedName</div>
                </div>
                <div class="sub-lbl">PRINTED NAME AND SIGNATURE OF DEPOSITOR</div>
            </div>
            <div class="cis-cell grow-1 center border-l">
                <div class="sig-wrapper">
                    <div class="sig-spacer"></div>
                    <div class="val">@Acknowledgement.DateSigned?.ToString("MM/dd/yyyy")</div>
                </div>
                <div class="sub-lbl">DATE</div>
            </div>
        </div>

        @* For Bank Use Only *@
        <div class="sec-title black-bg">FOR BANK USE ONLY</div>

        @* Screening *@
        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">CUSTOMER WAS CHECKED AGAINST: *</span>
                <div><span class="cis-chk">@(BankReview.ScreeningList.Contains("NEGATIVE LIST") ? "✓" : "")</span> <small>NEGATIVE LIST (OFAC/ UN SANCTION LIST)</small></div>
                <div><span class="cis-chk">@(BankReview.ScreeningList.Contains("PEPLIST") ? "✓" : "")</span> <small>PEPLIST</small></div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <span class="lbl">CUSTOMER IS A PORAC BANK EMPLOYEE*</span>
                <div>
                    <span class="cis-chk">@(BankReview.IsEmployee ? "✓" : "")</span> <small>EMPLOYEE</small> &nbsp;
                    <span class="cis-chk">@(BankReview.IsDosri ? "✓" : "")</span> <small>DOSRI</small> &nbsp;
                    <span class="cis-chk">@(BankReview.IsRpt ? "✓" : "")</span> <small>RPT</small> &nbsp;
                    <small>POSITION* <span class="val">@BankReview.Position</span></small>
                </div>
            </div>
        </div>

        @* Relative *@
        <div class="cis-row">
            <div class="cis-cell grow-1">
                <div><span class="cis-chk">@(BankReview.IsRelative ? "✓" : "")</span> <small>CUSTOMER IS A RELATIVE (UP TO 2ND DEGREE OF AFFINITY AND CONSAGUINITY) OF A PORAC BANK EMPLOYEE</small></div>
            </div>
        </div>
        @if (BankReview.IsRelative)
        {
            <div class="cis-row">
                <div class="cis-cell grow-2">
                    <span class="lbl">NAME OF EMPLOYEE*</span>
                    <div class="val">@BankReview.RelativeEmployeeName</div>
                </div>
                <div class="cis-cell grow-2 border-l">
                    <span class="lbl">POSITION*</span>
                    <div class="val">@BankReview.RelativePosition</div>
                </div>
                <div class="cis-cell grow-2 border-l">
                    <span class="lbl">RELATIONSHIP*</span>
                    <div class="val">@BankReview.RelativeRelationship</div>
                </div>
            </div>
        }

        @* Nature of Work / Business *@
        <div class="cis-row">
            <div class="cis-cell grow-2">
                <span class="lbl">NATURE OF WORK/ BUSINESS*</span>
                @{
                    var workLabels = new Dictionary<string, string>
                    {
                        ["AGRICULTURE"] = "Agriculture / Animal Farming", ["MONEY_CHANGER"] = "Money Changer / FX Dealer",
                        ["BANKING"] = "Banking / Financial Services",      ["ONLINE_BIZ"] = "Online Business",
                        ["BPO"] = "BPO / KPO",                             ["PROFESSIONAL"] = "Professional Practice",
                        ["BROKERAGE"] = "Brokerage",                       ["QUARRYING"] = "Quarrying / Trucking / Mining",
                        ["CANTEEN"] = "Canteen / Eatery / Resto / Bar",    ["REAL_ESTATE"] = "Real Estate Activities",
                        ["CASINO"] = "Casino / Dealer",                    ["RENTAL"] = "Rental",
                        ["DRUGS"] = "Drugs / Pharmaceuticals",             ["REMITTANCE"] = "Remittance Agent",
                        ["EDUCATION"] = "Education",                       ["RESORTS"] = "Resorts / Hotel / Accommodation",
                        ["GOVERNMENT"] = "Government Service",             ["STUDENT"] = "Student",
                        ["INFORMAL"] = "Informal Lending",                 ["TRANSPORT"] = "Transportation",
                        ["IMPORT"] = "Import / Export",                    ["WHOLESALE"] = "Wholesale / Retail Trade",
                        ["MANUFACTURING"] = "Manufacturing",               ["UNEMPLOYED"] = "Unemployed",
                        ["MARKET_VENDOR"] = "Market Vendor",               ["MEDICAL"] = "Medical Services",
                    };
                }
                <div class="nature-grid">
                    @foreach (var nw in BankReview.WorkList)
                    {
                        <span><span class="cis-chk">✓</span> <small>@(workLabels.TryGetValue(nw, out var wlbl) ? wlbl : nw)</small></span>
                    }
                    @if (BankReview.SelectedWork == "OTHERS" && !string.IsNullOrEmpty(BankReview.NatureOfWorkBusinessOther))
                    {
                        <span><span class="cis-chk">✓</span> <small>Others: @BankReview.NatureOfWorkBusinessOther</small></span>
                    }
                </div>
            </div>
            <div class="cis-cell grow-2 border-l">
                <div><span class="cis-chk">@(BankReview.IsOwnedByPEP ? "✓" : "")</span> <small>CUSTOMER IS AN ENTITY OWNED AND CONTROLLED BY A POLITICALLY EXPOSED PERSON</small></div>
                <div class="mt8"><span class="cis-chk">@(BankReview.IsEntityOwnedByEmployee ? "✓" : "")</span> <small>CUSTOMER IS AN ENTITY OWNED AND CONTROLLED BY A PORAC BANK EMPLOYEE*</small></div>
            </div>
        </div>

        @* Documents Presented *@
        <div class="cis-row">
            <div class="cis-cell grow-1">
                <span class="lbl">DOCUMENTS PRESENTED*</span>
                @{
                    var docLabels = new Dictionary<string, string>
                    {
                        ["A"] = "A. FOR SOLE PROPRIETORS: Certified True Copy of Certificate of Business Name Registration issued by the Department of Trade and Industry",
                        ["B"] = "B. FOR PARTNERS AND CORPORATIONS: Certified True Copy of Certificate of Business Name Registration issued by the Securities and Exchange Commission or Insurance Commission",
                        ["C"] = "C. FOR MONEY CHANGERS, FOREIGN EXCHANGE DEALERS AND REMITTANCE AGENTS: Certified True Copy of Certificate of Business Name Registration issued by the Bangko Sentral ng Pilipinas",
                        ["D"] = "D. FOR ENTITIES REGISTERED OUTSIDE THE PHILIPPINES: Similar documents and/or information stated above authenticated by the Philippine Consulate where said entities are registered",
                    };
                    var addlDocLabels = new Dictionary<string, string>
                    {
                        ["ARTICLES"]  = "Certified True Copy of Articles of Incorporation / Association",
                        ["BYLAWS"]    = "Certified True Copy of By Laws",
                        ["BOARD_RES"] = "Board of Partner's Resolution duly certified by Corporate / Partner's Secretary authorizing a representative to sign on behalf of the entity",
                        ["GIS"]       = "Latest General Information Sheet",
                    };
                }
                <div class="doc-list">
                    @foreach (var doc in BankReview.DocsList)
                    {
                        <div><span class="cis-chk">✓</span> <small>@(docLabels.TryGetValue(doc, out var lbl) ? lbl : doc)</small></div>
                    }
                    @foreach (var doc in BankReview.AdditionalDocsList)
                    {
                        <div><span class="cis-chk">✓</span> <small>@(addlDocLabels.TryGetValue(doc, out var lbl2) ? lbl2 : doc)</small></div>
                    }
                    @if (!string.IsNullOrEmpty(BankReview.DocumentsOther))
                    {
                        <div><span class="cis-chk">✓</span> <small>OTHERS (Please specify): @BankReview.DocumentsOther</small></div>
                    }
                </div>
            </div>
        </div>

        @* Signature / Verified / Approved / Remarks *@
        <div class="cis-row bank-sig-row">
            <div class="cis-cell grow-1 center">
                <div class="bank-sig-content">
                    @if (!string.IsNullOrEmpty(BankReview.SignatureAuthenticated))
                    {
                        <img src="@BankReview.SignatureAuthenticated" class="sig-img" alt="Auth Signature" />
                    }
                </div>
                <div class="bank-sig-bottom">SIGNATURE AUTHENTICATED</div>
            </div>
            <div class="cis-cell grow-1 center border-l">
                <div class="bank-sig-content">
                    <div class="bank-val">@BankReview.VerifiedBy</div>
                </div>
                <div class="bank-sig-bottom">VERIFIED BY</div>
            </div>
            <div class="cis-cell grow-1 center border-l">
                <div class="bank-sig-content">
                    <div class="bank-val">@BankReview.ApprovedBy</div>
                </div>
                <div class="bank-sig-bottom">APPROVED BY</div>
            </div>
            <div class="cis-cell grow-2 border-l remarks-cell">
                <span class="lbl">REMARKS (IF ANY)</span>
                <div class="val" style="margin-top:3px;">@BankReview.Remarks</div>
            </div>
        </div>

    </div>@* end page 2 *@

</div>@* end cis-page *@

@* ── Print Button (hidden on print) ── *@
<div class="no-print print-bar">
    <button class="btn-print" onclick="window.print()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2M6 14h12v8H6z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Print Official Form
    </button>
</div>

<style>
    * { box-sizing: border-box; }

    body { margin: 0; background: #e8ecf0; }

    .cis-page {
        font-family: Arial, sans-serif;
        font-size: 7.5pt;
        color: #000;
    }

    .cis-sheet {
        width: 210mm;
        margin: 0 auto 6mm;
        padding: 8mm 9mm;
        background: #fff;
        box-shadow: 0 2px 16px rgba(0,0,0,0.12);
    }

    /* ── Header ── */
    .cis-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        border-bottom: 2.5px solid #000;
        padding-bottom: 4px;
        margin-bottom: 4px;
    }
    .cis-title { font-size: 13pt; font-weight: 900; line-height: 1.1; }
    .cis-bank-name { font-size: 18pt; font-weight: 900; text-align: right; }
    .cis-bank-sub  { font-size: 7pt; font-style: italic; text-align: right; }


    /* ── Meta ── */
    .cis-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 3px 0;
        border-bottom: 1px solid #000;
        margin-bottom: 2px;
    }
    .cis-meta-left, .cis-meta-mid { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
    .cis-meta-right { text-align: right; }

    .cis-guidelines {
        font-size: 6pt;
        font-style: italic;
        color: #444;
        margin-bottom: 3px;
        border-bottom: 1px solid #ccc;
        padding-bottom: 2px;
    }

    /* ── Section titles ── */
    .sec-title {
        background: #333;
        color: #fff;
        padding: 2px 6px;
        font-weight: bold;
        font-size: 8pt;
        text-transform: uppercase;
        margin-top: 3px;
        text-align: center;
    }
    .black-bg { background: #000; }

    /* ── Rows & Cells ── */
    .cis-row {
        display: flex;

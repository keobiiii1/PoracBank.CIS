@code {
    [SupplyParameterFromQuery] public long CustomerId { get; set; }

    // Flat props used throughout the template — populated from IndividualRegistrationRequest
    public CustomerDTO.PageModel             Customer       { get; set; } = new();
    public IndividualInfoDTO.PageModel       Personal       { get; set; } = new();
    public AddressDTO.PageModel              Address        { get; set; } = new();
    public ContactDTO.PageModel              Contact        { get; set; } = new();
    public IndividualIdentificationDTO.PageModel Identification { get; set; } = new();
    public IndividualEmploymentDTO.PageModel Employment     { get; set; } = new();
    public IndividualFamilyDTO.PageModel     Family         { get; set; } = new();
    public IndividualForeignerDTO.PageModel  Foreigner      { get; set; } = new();
    public AccountPurposeDTO.PageModel       AccPurpose     { get; set; } = new();
    public BusinessInfoDTO.PageModel         BusinessInfo   { get; set; } = new();
    public BusinessInfoDTO.PageModel         AccountContact { get; set; } = new();
    public BeneficiaryDTO.PageModel          Beneficiary    { get; set; } = new();
    public ClientAcknowledgementDTO.PageModel Acknowledgement { get; set; } = new();
    public BankReviewDTO.PageModel           BankReview     { get; set; } = new();

    private long _loadedId;

    protected override async Task OnParametersSetAsync()
    {
        if (CustomerId > 0 && CustomerId != _loadedId)
        {
            _loadedId = CustomerId;

            var data = await IndividualService.GetRegistrationDetailsAsync(CustomerId);
            if (data == null) return;

            // ── Personal & meta ──────────────────────────────────────────
            Personal = data.Individual ?? new();
            Customer.CIDNumber          = Personal.CIDNumber;
            Customer.CustomerCategories = Personal.CustomerCategories;

            // ── Supporting tables ────────────────────────────────────────
            Address        = data.Address        ?? new();
            Identification = data.Identification ?? new();
            Employment     = data.Employment     ?? new();
            Family         = data.Family         ?? new();
            Contact        = data.Contact        ?? new();
            Foreigner      = data.Foreigner      ?? new();

            // ── Account purpose (individual) ─────────────────────────────
            AccPurpose     = data.AccountPurpose ?? new();

            // ── Business info ────────────────────────────────────────────
            BusinessInfo   = data.Business       ?? new();

            // ── AccountContact — comes from the business-contact step ────
            // The repository fills this from AccountPurpose + Contact tables.
            AccountContact = data.AccountContact ?? new();

            // ── Beneficiary, Ack, BankReview ─────────────────────────────
            Beneficiary     = data.Beneficiary    ?? new();
            Acknowledgement = data.Acknowledgement ?? new();
            BankReview      = data.BankReview     ?? new();
        }
    }
}

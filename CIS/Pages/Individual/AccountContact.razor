@using CIS.Assets.DTO
@using CIS.Assets.Enum
@using System.ComponentModel
@using System.Reflection
@using System.Linq

<div class="ac-wrap">

    @* ══════════════════════════════════════
       SECTION 1 — Account Purpose & Products
    ══════════════════════════════════════ *@
    <div class="ac-section">
        <div class="ac-section-header">
            <div class="ac-section-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <span class="ac-section-title">Account Purpose &amp; Products</span>
        </div>

        <div class="acf-grid acf-grid-2">
            <div class="ac-field">
                <label class="ac-label">Purpose of Account <span class="ac-req">*</span></label>
                <div class="ac-select-wrap">
                    <InputSelect @bind-Value="BusinessModel.AccountPurpose" class="@(showErrors && BusinessModel.AccountPurpose == PurposeOfAccount.None ? "ac-select ac-invalid" : "ac-select")">
                        <option value="@PurposeOfAccount.None" disabled>Select Purpose of Account</option>
                        @foreach (var val in GetBusinessPurposes())
                        {
                            <option value="@val">@GetDescription(val)</option>
                        }
                    </InputSelect>
                    <svg class="ac-select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                @if (showErrors && BusinessModel.AccountPurpose == PurposeOfAccount.None)
                {
                    <span class="ac-field-error">Purpose of account is required.</span>
                }
                @if (BusinessModel.AccountPurpose == PurposeOfAccount.Others)
                {
                    <InputText @bind-Value="BusinessModel.AccountPurposeOther" class="ac-input mt-2" placeholder="Please specify" />
                    @if (showErrors && string.IsNullOrWhiteSpace(BusinessModel.AccountPurposeOther))
                    {
                        <span class="ac-field-error">Please specify the purpose.</span>
                    }
                }
            </div>

        </div>

        <div class="ac-divider"></div>

        @* Products to be Availed *@
        <div class="ac-subsection-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                <rect x="3" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2"/>
                <rect x="14" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2"/>
                <rect x="3" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2"/>
                <rect x="14" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2"/>
            </svg>
            Products to be Availed <span class="ac-req">*</span>
        </div>
        <div class="ac-checkbox-group">
            @foreach (var product in productOptions)
            {
                <label class="ac-checkbox-card @(selectedProducts.Contains(product) ? "checked" : "")">
                    <input type="checkbox" class="ac-checkbox-input" id="prod_@product"
                           checked="@selectedProducts.Contains(product)"
                           @onchange="(e) => ToggleProduct(product, e)" />
                    <div class="ac-checkbox-tick">
                        <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                            <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <span>@product</span>
                </label>
            }
        </div>
        @if (showErrors && selectedProducts.Count == 0)
        {
            <span class="ac-field-error mt-1">At least one product must be selected.</span>
        }

        @if (selectedProducts.Contains("Others"))
        {
            <div class="ac-field mt-2">
                <label class="ac-label">Specify Other Products <span class="ac-req">*</span></label>
                <InputText @bind-Value="BusinessModel.ProductsAvailedOther" class="@(showErrors && string.IsNullOrWhiteSpace(BusinessModel.ProductsAvailedOther) ? "ac-input ac-invalid" : "ac-input")" placeholder="Please specify" />
                @if (showErrors && string.IsNullOrWhiteSpace(BusinessModel.ProductsAvailedOther))
                {
                    <span class="ac-field-error">Please specify the product.</span>
                }
            </div>
        }
    </div>

    @* ══════════════════════════════════════
       SECTION 2 — Contact Information
    ══════════════════════════════════════ *@
    <div class="ac-section">
        <div class="ac-section-header">
            <div class="ac-section-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.0 1.18 2 2 0 012 .0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <span class="ac-section-title">Contact Information</span>
        </div>

        <div class="acf-grid acf-grid-3">
            <div class="ac-field">
                <label class="ac-label">Office Phone No.</label>
                <InputText @bind-Value="BusinessModel.OfficePhoneNo" class="ac-input" placeholder="e.g. 02-1234567" />
            </div>
            <div class="ac-field">
                <label class="ac-label">Email Address <span class="ac-req">*</span></label>
                <InputText @bind-Value="BusinessModel.EmailAddress" class="@(showErrors && !IsValidEmail(BusinessModel.EmailAddress) ? "ac-input ac-invalid" : "ac-input")" placeholder="e.g. info@company.com" />
                @if (showErrors && string.IsNullOrWhiteSpace(BusinessModel.EmailAddress))
                {
                    <span class="ac-field-error">Email address is required.</span>
                }
                else if (showErrors && !string.IsNullOrWhiteSpace(BusinessModel.EmailAddress) && !IsValidEmail(BusinessModel.EmailAddress))
                {
                    <span class="ac-field-error">Please enter a valid email address.</span>
                }
            </div>
            <div class="ac-field">
                <label class="ac-label">Contact Person</label>
                <InputText @bind-Value="BusinessModel.ContactPerson" class="ac-input" placeholder="e.g. Juan Dela Cruz" />
            </div>
        </div>
    </div>

    @* ══════════════════════════════════════
       FOOTER
    ══════════════════════════════════════ *@
    <div class="ac-footer">
        <button type="button" class="ac-btn-back" @onclick="OnBack">
            <div class="ac-btn-arrow-left">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                    <path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <span>Back</span>
        </button>
        <div class="ac-footer-hint">
            <span class="ac-req">*</span>&nbsp;Required fields must be filled before continuing
        </div>
        <button type="button" class="ac-btn-next" @onclick="TryNext">
            <span>Continue</span>
            <div class="ac-btn-arrow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                    <path d="M5 12h14M13 6l6 6-6 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
        </button>
    </div>

</div>

<style>
    .ac-wrap {
        display: flex;
        flex-direction: column;
        gap: 8px;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    .ac-section {
        background: #ffffff;
        border: 1px solid #edf0f4;
        border-radius: 18px;
        padding: 22px 24px;
        transition: border-color 0.2s, box-shadow 0.2s;
        position: relative;
        overflow: hidden;
    }

    .ac-section::after {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
        background: linear-gradient(180deg, #00a859, #0056b3);
        opacity: 0;
        transition: opacity 0.25s;
    }

    .ac-section:focus-within { border-color: #c8e6d8; box-shadow: 0 4px 20px rgba(0,168,89,0.07); }
    .ac-section:focus-within::after { opacity: 1; }

    .ac-section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
    }

    .ac-section-icon {
        width: 28px; height: 28px;
        border-radius: 8px;
        background: linear-gradient(135deg, #00a859, #0056b3);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0,168,89,0.25);
    }

    .ac-section-title {
        font-size: 0.72rem;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        flex: 1;
    }

    .ac-subsection-label {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.72rem;
        font-weight: 700;
        color: #475569;
        letter-spacing: 0.4px;
        text-transform: uppercase;
        margin-bottom: 12px;
        margin-top: 4px;
    }

    .ac-subsection-label svg { color: #00a859; flex-shrink: 0; }

    .acf-grid { display: grid; gap: 16px; }
    .acf-grid-2 { grid-template-columns: repeat(2, 1fr); }
    .acf-grid-3 { grid-template-columns: repeat(3, 1fr); }
    .mt-1 { margin-top: 4px; }
    .mt-2 { margin-top: 8px; }

    .ac-field { display: flex; flex-direction: column; gap: 6px; }

    .ac-label {
        font-size: 0.71rem;
        font-weight: 700;
        color: #64748b;
        letter-spacing: 0.2px;
        display: flex; align-items: center; gap: 3px;
    }

    .ac-req { color: #ef4444; font-size: 0.8rem; line-height: 1; }

    .ac-input {
        height: 42px;
        padding: 0 14px;
        border: 1.5px solid #e2e8f0;
        border-radius: 11px;
        font-size: 0.86rem;
        color: #0f172a;
        background: #fff;
        outline: none;
        transition: border-color 0.18s, box-shadow 0.18s, background 0.18s;
        width: 100%;
        -webkit-appearance: none;
        appearance: none;
    }

    .ac-input:hover { border-color: #94a3b8; }
    .ac-input:focus { border-color: #00a859; box-shadow: 0 0 0 3px rgba(0,168,89,0.12); background: #fafffe; }
    .ac-input.ac-invalid { border-color: #ef4444 !important; box-shadow: 0 0 0 3px rgba(239,68,68,0.08) !important; }

    .ac-select-wrap { position: relative; }

    .ac-select {
        height: 42px;
        padding: 0 36px 0 14px;
        border: 1.5px solid #e2e8f0;
        border-radius: 11px;
        font-size: 0.86rem;
        color: #0f172a;
        background: #fff;
        outline: none;
        transition: border-color 0.18s, box-shadow 0.18s;
        width: 100%;
        -webkit-appearance: none;
        appearance: none;
        cursor: pointer;
    }

    .ac-select:hover { border-color: #94a3b8; }
    .ac-select:focus { border-color: #00a859; box-shadow: 0 0 0 3px rgba(0,168,89,0.12); background: #fafffe; }
    .ac-select.ac-invalid { border-color: #ef4444 !important; box-shadow: 0 0 0 3px rgba(239,68,68,0.08) !important; }

    .ac-select-arrow {
        position: absolute;
        right: 12px; top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }

    .ac-field-error {
        font-size: 0.7rem;
        color: #dc2626;
        font-weight: 500;
        margin: 0; padding: 0;
        display: block;
    }

    .ac-divider { height: 1px; background: #f1f5f9; margin: 16px 0; }

    /* ── Checkbox cards ── */
    .ac-checkbox-group {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .ac-checkbox-card {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 9px 16px;
        border: 1.5px solid #e2e8f0;
        border-radius: 11px;
        cursor: pointer;
        font-size: 0.86rem;
        color: #0f172a;
        background: #fff;
        transition: border-color 0.18s, box-shadow 0.18s, background 0.18s;
        user-select: none;
    }

    .ac-checkbox-card:hover { border-color: #94a3b8; }

    .ac-checkbox-card.checked {
        border-color: #00a859;
        background: #f0fdf8;
        box-shadow: 0 0 0 3px rgba(0,168,89,0.1);
    }

    .ac-checkbox-input {
        position: absolute;
        opacity: 0;
        width: 0; height: 0;
        pointer-events: none;
    }

    .ac-checkbox-tick {
        width: 17px; height: 17px;
        border-radius: 5px;
        border: 2px solid #e2e8f0;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        transition: border-color 0.18s, background 0.18s;
    }

    .ac-checkbox-card.checked .ac-checkbox-tick {
        border-color: #00a859;
        background: #00a859;
    }

    .ac-checkbox-card.checked .ac-checkbox-tick svg { display: block; }
    .ac-checkbox-card:not(.checked) .ac-checkbox-tick svg { display: none; }

    /* ── Footer ── */
    .ac-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 6px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .ac-footer-hint { font-size: 0.72rem; color: #94a3b8; display: flex; align-items: center; gap: 3px; }

    .ac-btn-next {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 13px 28px;
        background: linear-gradient(90deg, #00a859 0%, #0056b3 100%);
        color: #fff;
        border: none;
        border-radius: 13px;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        transition: filter 0.18s, transform 0.15s, box-shadow 0.18s;
        box-shadow: 0 4px 18px rgba(0,168,89,0.3);
    }

    .ac-btn-next:hover { filter: brightness(1.07); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,168,89,0.38); }
    .ac-btn-next:active { transform: translateY(0); filter: brightness(0.97); }

    .ac-btn-arrow {
        width: 30px; height: 30px;
        background: rgba(255,255,255,0.2);
        border-radius: 9px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .ac-btn-back {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 13px 20px;
        background: #fff;
        color: #475569;
        border: 1.5px solid #e2e8f0;
        border-radius: 13px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: border-color 0.18s, color 0.18s, transform 0.15s;
    }

    .ac-btn-back:hover { border-color: #94a3b8; color: #0f172a; transform: translateY(-1px); }

    .ac-btn-arrow-left {
        width: 28px; height: 28px;
        background: #f1f5f9;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    @@media (max-width: 768px) {
        .acf-grid-3 { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 480px) {
        .acf-grid-2, .acf-grid-3 { grid-template-columns: 1fr; }
        .ac-section { padding: 16px; border-radius: 14px; }
        .ac-footer { flex-direction: column; align-items: stretch; }
        .ac-btn-next, .ac-btn-back { justify-content: center; }
    }
</style>

@code {
    [Parameter] public BusinessInfoDTO.PageModel BusinessModel { get; set; } = new();
    [Parameter] public EventCallback<BusinessInfoDTO.PageModel> BusinessModelChanged { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private bool showErrors = false;
    private List<string> productOptions = new() { "Savings", "Current", "TD", "Loan", "Sale Of ROPA", "Others" };
    private List<string> selectedProducts = new();

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(BusinessModel.ProductsAvailed))
            selectedProducts = BusinessModel.ProductsAvailed.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
    }

    private List<PurposeOfAccount> GetBusinessPurposes()
    {
        return Enum.GetValues<PurposeOfAccount>()
            .Where(val =>
            {
                if (val == PurposeOfAccount.None) return false;
                var field = val.GetType().GetField(val.ToString()!);
                var cat = field?.GetCustomAttribute<CategoryAttribute>();
                return cat?.Category == "Business" || cat?.Category == "Both";
            })
            .ToList();
    }

    private string GetDescription(PurposeOfAccount val)
    {
        var field = val.GetType().GetField(val.ToString());
        var attr = (DescriptionAttribute?)Attribute.GetCustomAttribute(field!, typeof(DescriptionAttribute));
        return attr?.Description ?? FormatEnum(val.ToString());
    }

    private static string GetEnumDescription<TEnum>(TEnum value) where TEnum : Enum
    {
        var field = value.GetType().GetField(value.ToString()!);
        var attr = field?.GetCustomAttribute<DescriptionAttribute>();
        return attr?.Description ?? FormatEnum(value.ToString()!);
    }

    private static string FormatEnum(string value)
        => System.Text.RegularExpressions.Regex.Replace(
            value, @"(?<=[a-z])(?=[A-Z])|(?<=[A-Z])(?=[A-Z][a-z])", " ");

    private void ToggleProduct(string product, ChangeEventArgs e)
    {
        var isChecked = (bool)e.Value!;
        if (isChecked) { if (!selectedProducts.Contains(product)) selectedProducts.Add(product); }
        else { selectedProducts.Remove(product); }
        BusinessModel.ProductsAvailed = string.Join(",", selectedProducts);
    }

    private bool IsValid()
    {
        if (BusinessModel.AccountPurpose == PurposeOfAccount.None) return false;
        if (BusinessModel.AccountPurpose == PurposeOfAccount.Others && string.IsNullOrWhiteSpace(BusinessModel.AccountPurposeOther)) return false;
        if (selectedProducts.Count == 0) return false;
        if (selectedProducts.Contains("Others") && string.IsNullOrWhiteSpace(BusinessModel.ProductsAvailedOther)) return false;
        if (string.IsNullOrWhiteSpace(BusinessModel.EmailAddress)) return false;
        if (!IsValidEmail(BusinessModel.EmailAddress)) return false;
        return true;
    }

    private static bool IsValidEmail(string? email)
    {
        if (string.IsNullOrWhiteSpace(email)) return false;
        try { var addr = new System.Net.Mail.MailAddress(email); return addr.Address == email.Trim(); }
        catch { return false; }
    }

    private async Task TryNext()
    {
        showErrors = true;
        if (!IsValid()) return;

        BusinessModel.ProductsAvailed = string.Join(",", selectedProducts);
        if (!selectedProducts.Contains("Others"))
            BusinessModel.ProductsAvailedOther = null;

        await BusinessModelChanged.InvokeAsync(BusinessModel);
        await OnNext.InvokeAsync();
    }
}

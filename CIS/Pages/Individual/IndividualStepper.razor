@page "/cis/individual"
@namespace CIS.Client.Pages.Individual

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Individual Account Registration</h2>
        <span class="badge bg-primary">Step @CurrentStep of 7</span>
    </div>

    <div class="progress mb-4" style="height: 10px;">
        <div class="progress-bar" style="width: @(CurrentStep * 14.28)%"></div>
    </div>

    @if (CurrentStep == 1)
    {
        <BasicInformation @bind-Customer="customerModel" OnNext="HandleNext" />
    }
    else if (CurrentStep == 2)
    {
        <PersonalInformation @bind-Model="personalModel" OnNext="HandleNext" OnBack="PrevStep" />
    }
    @* --- Step 3: Contact Information --- *@
    @if (CurrentStep == 3)
    {
        <ContactInformation CustomerId="customerModel.CustomerID"
                            AddressModel="addressModel"
                            InfoModel="individualInfoModel"
                            OnNext="HandleNext"
                            OnBack="PrevStep" />
    }
    @* --- NEW Step 4: Identification --- *@
    else if (CurrentStep == 4)
    {
        <IdentificationInformation IdModel="identificationModel"
                                   CustomerId="customerModel.CustomerID"
                                   OnNext="HandleNext"
                                   OnBack="PrevStep" />
    }
    @* --- Step 5: Employment (Shifted from 4 to 5) --- *@
    else if (CurrentStep == 5)
    {
        <EmploymentInformation Model="employmentModel"
                               CustomerId="customerModel.CustomerID"
                               OnNext="HandleNext"
                               OnBack="PrevStep" />
    }
    @* --- Step 6: Family (Shifted from 5 to 6) --- *@
    else if (CurrentStep == 6)
    {
        <AccountBusiness InfoModel="personalModel"
                         CustomerId="customerModel.CustomerID"
                         OnNext="HandleNext"
                         OnBack="PrevStep" />
    }
    @* --- Step 7: Bank Review (Shifted from 6 to 7) --- *@
    else if (CurrentStep == 7)
    {
        <BankReview Customer="customerModel"
                    Personal="personalModel"
                    Address="addressModel"
                    Identification="identificationModel"
                    Employment="employmentModel"
                    OnBack="PrevStep"
                    OnSubmit="HandleSubmit" />
    }
</div>

@code {
    private int CurrentStep = 1;

    private CustomerDTO.PageModel customerModel = new();
    private IndividualInfoDTO.PageModel personalModel = new();
    private AddressDTO.PageModel addressModel = new();
    private IndividualInfoDTO.PageModel individualInfoModel = new();
    private ContactDTO.PageModel contactModel = new();
    private IndividualIdentificationDTO.PageModel identificationModel = new();
    private IndividualEmploymentDTO.PageModel employmentModel = new();
    private IndividualFamilyDTO.PageModel familyModel = new();
    private BankReviewDTO.PageModel reviewModel = new();

    private void HandleNext()
    {
        // Ensure the ID is passed to every model as we progress
        personalModel.CustomerID = customerModel.CustomerID;
        addressModel.EntityID = customerModel.CustomerID;
        contactModel.EntityID = customerModel.CustomerID;
        identificationModel.CustomerID = customerModel.CustomerID;
        employmentModel.CustomerID = customerModel.CustomerID;
        familyModel.CustomerID = customerModel.CustomerID;
        reviewModel.CustomerID = customerModel.CustomerID;

        CurrentStep++;
        StateHasChanged(); // Force Blazor to refresh the UI
    }

    private async Task HandleSubmit()
    {
        CurrentStep = 8;
        StateHasChanged();
    }

    private void PrevStep() => CurrentStep--;
}
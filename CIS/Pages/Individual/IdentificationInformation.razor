                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @if (govIdError != null)
            {
                <div class="ii-field-error mt-2">@govIdError</div>
            }
        </div>

        @* ══════════════════════════════════════
           SECTION 3 — IDs Presented
        ══════════════════════════════════════ *@
        <div class="ii-section" id="field-IDsPresented">
            <div class="ii-section-header">
                <div class="ii-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M9 11l3 3L22 4" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" stroke="white" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </div>
                <span class="ii-section-title">IDs Presented</span>
                <span class="ii-section-sub">Select, fill in details, then upload photos</span>
            </div>

            @* ── Driver's License ── *@
            <label class="ii-id-toggle @(ShowDL ? "active" : "")">
                <div class="ii-id-check @(ShowDL ? "checked" : "")">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                        <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <span class="ii-id-name">Driver's License</span>
                <input type="checkbox" @bind="ShowDL" class="ii-hidden-check" />
            </label>
            @if (ShowDL)
            {
                <div class="ii-id-fields">
                    <div class="ii-grid ii-grid-2">
                        <div class="ii-field">
                            <label class="ii-label">License No. <span class="ii-req">*</span></label>
                            <InputText @bind-Value="IdModel.DriversLicenseIDNo" class="ii-input" placeholder="e.g. N01-23-456789" />
                            <ValidationMessage For="@(() => IdModel.DriversLicenseIDNo)" class="ii-field-error" />
                        </div>
                        <div class="ii-field">
                            <label class="ii-label">Expiry Date <span class="ii-req">*</span></label>
                            <InputDate @bind-Value="IdModel.DriversLicenseExpiry" class="ii-input" min="1900-01-01" max="2999-12-31" />
                            <ValidationMessage For="@(() => IdModel.DriversLicenseExpiry)" class="ii-field-error" />
                        </div>
                    </div>
                    <div class="ii-id-card-photos">
                        <div class="ii-id-card-photos-label">ID Photos <span class="ii-req">*</span></div>
                        <div class="ii-kyc-grid">
                            <div class="ii-kyc-card @(dlFrontPreview != null ? "ii-kyc-done" : "")">
                                <div class="ii-kyc-preview">
                                    @if (dlFrontPreview != null) { <img src="@dlFrontPreview" class="ii-kyc-img" alt="DL Front" /><div class="ii-kyc-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                                            <button type="button" class="ii-kyc-delete" @onclick="ClearDlFront" title="Remove photo">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                                        </button> }
                                    else { <svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="ii-kyc-placeholder-icon"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 10h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> }
                                </div>
                                <div class="ii-kyc-label">Front <span class="ii-req">*</span></div>
                                <div class="ii-kyc-actions">
                                    <label class="ii-kyc-btn">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="2"/></svg>
                                        @(dlFrontPreview != null ? "Retake" : "Camera")
                                        <InputFile accept="image/*" capture="environment" class="ii-hidden-input" OnChange="CaptureDlFront" />
                                    </label>
                                    <label class="ii-kyc-btn ii-kyc-btn-upload">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polyline points="17 8 12 3 7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="3" x2="12" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                        Upload
                                        <InputFile accept="image/*" class="ii-hidden-input" OnChange="CaptureDlFront" />
                                    </label>
                                </div>
                            </div>
                            <div class="ii-kyc-card @(dlBackPreview != null ? "ii-kyc-done" : "")">
                                <div class="ii-kyc-preview">
                                    @if (dlBackPreview != null) { <img src="@dlBackPreview" class="ii-kyc-img" alt="DL Back" /><div class="ii-kyc-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                                            <button type="button" class="ii-kyc-delete" @onclick="ClearDlBack" title="Remove photo">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                                        </button> }
                                    else { <svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="ii-kyc-placeholder-icon"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 10h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> }
                                </div>
                                <div class="ii-kyc-label">Back</div>
                                <div class="ii-kyc-actions">
                                    <label class="ii-kyc-btn">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="2"/></svg>
                                        @(dlBackPreview != null ? "Retake" : "Camera")
                                        <InputFile accept="image/*" capture="environment" class="ii-hidden-input" OnChange="CaptureDlBack" />
                                    </label>
                                    <label class="ii-kyc-btn ii-kyc-btn-upload">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polyline points="17 8 12 3 7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="3" x2="12" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                        Upload
                                        <InputFile accept="image/*" class="ii-hidden-input" OnChange="CaptureDlBack" />
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="ii-divider"></div>

            @* ── Passport ── *@
            <label class="ii-id-toggle @(ShowPassport ? "active" : "")">
                <div class="ii-id-check @(ShowPassport ? "checked" : "")">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                        <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <span class="ii-id-name">Passport</span>
                <input type="checkbox" @bind="ShowPassport" class="ii-hidden-check" />
            </label>
            @if (ShowPassport)
            {
                <div class="ii-id-fields">
                    <div class="ii-grid ii-grid-2">
                        <div class="ii-field">
                            <label class="ii-label">Passport No. <span class="ii-req">*</span></label>
                            <InputText @bind-Value="IdModel.PassportIDNo" class="ii-input" placeholder="e.g. A12345678" />
                            <ValidationMessage For="@(() => IdModel.PassportIDNo)" class="ii-field-error" />
                        </div>
                        <div class="ii-field">
                            <label class="ii-label">Expiry Date <span class="ii-req">*</span></label>
                            <InputDate @bind-Value="IdModel.PassportIDExpiry" class="ii-input" min="1900-01-01" max="2999-12-31" />
                            <ValidationMessage For="@(() => IdModel.PassportIDExpiry)" class="ii-field-error" />
                        </div>
                    </div>
                    <div class="ii-id-card-photos">
                        <div class="ii-id-card-photos-label">ID Photos <span class="ii-req">*</span></div>
                        <div class="ii-kyc-grid">
                            <div class="ii-kyc-card @(passportFrontPreview != null ? "ii-kyc-done" : "")">
                                <div class="ii-kyc-preview">
                                    @if (passportFrontPreview != null) { <img src="@passportFrontPreview" class="ii-kyc-img" alt="Passport Front" /><div class="ii-kyc-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                                            <button type="button" class="ii-kyc-delete" @onclick="ClearPassportFront" title="Remove photo">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                                        </button> }
                                    else { <svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="ii-kyc-placeholder-icon"><rect x="5" y="2" width="14" height="20" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/></svg> }
                                </div>
                                <div class="ii-kyc-label">Photo Page <span class="ii-req">*</span></div>
                                <div class="ii-kyc-actions">
                                    <label class="ii-kyc-btn">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="2"/></svg>
                                        @(passportFrontPreview != null ? "Retake" : "Camera")
                                        <InputFile accept="image/*" capture="environment" class="ii-hidden-input" OnChange="CapturePassportFront" />
                                    </label>
                                    <label class="ii-kyc-btn ii-kyc-btn-upload">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polyline points="17 8 12 3 7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="3" x2="12" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                        Upload
                                        <InputFile accept="image/*" class="ii-hidden-input" OnChange="CapturePassportFront" />
                                    </label>
                                </div>
                            </div>
                            <div class="ii-kyc-card @(passportBackPreview != null ? "ii-kyc-done" : "")">
                                <div class="ii-kyc-preview">
                                    @if (passportBackPreview != null) { <img src="@passportBackPreview" class="ii-kyc-img" alt="Passport Back" /><div class="ii-kyc-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                                            <button type="button" class="ii-kyc-delete" @onclick="ClearPassportBack" title="Remove photo">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                                        </button> }
                                    else { <svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="ii-kyc-placeholder-icon"><rect x="5" y="2" width="14" height="20" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/></svg> }
                                </div>
                                <div class="ii-kyc-label">Last Page</div>
                                <div class="ii-kyc-actions">
                                    <label class="ii-kyc-btn">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="2"/></svg>
                                        @(passportBackPreview != null ? "Retake" : "Camera")
                                        <InputFile accept="image/*" capture="environment" class="ii-hidden-input" OnChange="CapturePassportBack" />
                                    </label>
                                    <label class="ii-kyc-btn ii-kyc-btn-upload">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polyline points="17 8 12 3 7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="3" x2="12" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                        Upload
                                        <InputFile accept="image/*" class="ii-hidden-input" OnChange="CapturePassportBack" />
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="ii-divider"></div>

            @* ── Other ID ── *@
            <label class="ii-id-toggle @(ShowOthers ? "active" : "")">
                <div class="ii-id-check @(ShowOthers ? "checked" : "")">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                        <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <span class="ii-id-name">Other ID</span>
                <input type="checkbox" @bind="ShowOthers" class="ii-hidden-check" />
            </label>
            @if (ShowOthers)
            {
                <div class="ii-id-fields">
                    <div class="ii-grid ii-grid-3">
                        <div class="ii-field">
                            <label class="ii-label">ID Type <span class="ii-req">*</span></label>
                            <InputText @bind-Value="IdModel.OtherIDType" class="ii-input" placeholder="e.g. Postal ID" />
                            <ValidationMessage For="@(() => IdModel.OtherIDType)" class="ii-field-error" />
                        </div>
                        <div class="ii-field">
                            <label class="ii-label">ID Number <span class="ii-req">*</span></label>
                            <InputText @bind-Value="IdModel.OtherIDNumber" class="ii-input" placeholder="ID number" />
                            <ValidationMessage For="@(() => IdModel.OtherIDNumber)" class="ii-field-error" />
                        </div>
                        <div class="ii-field">
                            <label class="ii-label">Expiry Date</label>
                            <InputDate @bind-Value="IdModel.OtherIDExpiry" class="ii-input" min="1900-01-01" max="2999-12-31" />
                        </div>
                    </div>
                    <div class="ii-id-card-photos">
                        <div class="ii-id-card-photos-label">ID Photos <span class="ii-req">*</span></div>
                        <div class="ii-kyc-grid">
                            <div class="ii-kyc-card @(otherFrontPreview != null ? "ii-kyc-done" : "")">
                                <div class="ii-kyc-preview">
                                    @if (otherFrontPreview != null) { <img src="@otherFrontPreview" class="ii-kyc-img" alt="Other ID Front" /><div class="ii-kyc-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                                            <button type="button" class="ii-kyc-delete" @onclick="ClearOtherFront" title="Remove photo">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                                        </button> }
                                    else { <svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="ii-kyc-placeholder-icon"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 10h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> }
                                </div>
                                <div class="ii-kyc-label">Front <span class="ii-req">*</span></div>
                                <div class="ii-kyc-actions">
                                    <label class="ii-kyc-btn">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="2"/></svg>
                                        @(otherFrontPreview != null ? "Retake" : "Camera")
                                        <InputFile accept="image/*" capture="environment" class="ii-hidden-input" OnChange="CaptureOtherFront" />
                                    </label>
                                    <label class="ii-kyc-btn ii-kyc-btn-upload">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polyline points="17 8 12 3 7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="3" x2="12" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                        Upload
                                        <InputFile accept="image/*" class="ii-hidden-input" OnChange="CaptureOtherFront" />
                                    </label>
                                </div>
                            </div>
                            <div class="ii-kyc-card @(otherBackPreview != null ? "ii-kyc-done" : "")">
                                <div class="ii-kyc-preview">
                                    @if (otherBackPreview != null) { <img src="@otherBackPreview" class="ii-kyc-img" alt="Other ID Back" /><div class="ii-kyc-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                                            <button type="button" class="ii-kyc-delete" @onclick="ClearOtherBack" title="Remove photo">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                                        </button> }
                                    else { <svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="ii-kyc-placeholder-icon"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 10h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> }
                                </div>
                                <div class="ii-kyc-label">Back</div>
                                <div class="ii-kyc-actions">
                                    <label class="ii-kyc-btn">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="2"/></svg>
                                        @(otherBackPreview != null ? "Retake" : "Camera")
                                        <InputFile accept="image/*" capture="environment" class="ii-hidden-input" OnChange="CaptureOtherBack" />
                                    </label>
                                    <label class="ii-kyc-btn ii-kyc-btn-upload">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polyline points="17 8 12 3 7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="3" x2="12" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                        Upload
                                        <InputFile accept="image/*" class="ii-hidden-input" OnChange="CaptureOtherBack" />
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* errors / upload status *@
        @if (kycError != null)
        {
            <div class="ii-field-error mt-2">@kycError</div>
        }


        @* ══════════════════════════════════════
           FOOTER
        ══════════════════════════════════════ *@
        <div class="ii-footer">
            <button type="button" class="ii-btn-back" @onclick="OnBack">
                <div class="ii-btn-arrow-left">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <span>Back</span>
            </button>
            <div class="ii-footer-hint">
                <span class="ii-req">*</span>&nbsp;Required fields must be filled before continuing
            </div>
            <button type="submit" class="ii-btn-next" @onclick="async () => await TriggerValidation()">
                <span>Continue</span>
                <div class="ii-btn-arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M5 12h14M13 6l6 6-6 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
            </button>
        </div>

    </div>
</EditForm>

<style>
    .ii-wrap {
        display: flex;
        flex-direction: column;
        gap: 8px;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    /* ── Section card ── */
    .ii-section {
        background: #ffffff;
        border: 1px solid #edf0f4;
        border-radius: 18px;
        padding: 22px 24px;
        transition: border-color 0.2s, box-shadow 0.2s;
        position: relative;
        overflow: hidden;
    }

    .ii-section::after {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
        background: linear-gradient(180deg, #00a859, #0056b3);
        opacity: 0;
        transition: opacity 0.25s;
    }

    .ii-section:focus-within {
        border-color: #c8e6d8;
        box-shadow: 0 4px 20px rgba(0,168,89,0.07);
    }

    .ii-section:focus-within::after { opacity: 1; }

    /* ── Section header ── */
    .ii-section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
    }

    .ii-section-icon {
        width: 28px; height: 28px;
        border-radius: 8px;
        background: linear-gradient(135deg, #00a859, #0056b3);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0,168,89,0.25);
    }

    .ii-section-title {
        font-size: 0.72rem;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: 0.8px;

<script>
    window.scrollToFirstError = function (id) {
        var el = document.getElementById(id);
        if (!el) return false;
        var err = el.querySelector('.ii-field-error');
        if (!err || !err.textContent.trim()) return false;
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return true;
    };
</script>

@code {
    // ── Parameters ────────────────────────────────────────────────
    [Parameter] public IndividualIdentificationDTO.PageModel IdModel { get; set; } = new();
    [Parameter] public long CustomerId { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    // ── State ──────────────────────────────────────────────────────
    private EditForm? editForm;
    private ValidationMessageStore? messageStore;
    private bool ShowDL, ShowPassport, ShowOthers;
    private string? govIdError;

    // KYC image state — per ID type
    private string? selfiePreview;
    private string? dlFrontPreview;
    private string? dlBackPreview;
    private string? passportFrontPreview;
    private string? passportBackPreview;
    private string? otherFrontPreview;
    private string? otherBackPreview;
    private string? kycError;

    private IBrowserFile? selfieFile;
    private IBrowserFile? dlFrontFile;
    private IBrowserFile? dlBackFile;
    private IBrowserFile? passportFrontFile;
    private IBrowserFile? passportBackFile;
    private IBrowserFile? otherFrontFile;
    private IBrowserFile? otherBackFile;

    // Gov ID KYC files
    private string? tinFrontPreview,  tinBackPreview;
    private string? sssFrontPreview,  sssBackPreview;
    private string? gsisFrontPreview, gsisBackPreview;
    private IBrowserFile? tinFrontFile,  tinBackFile;
    private IBrowserFile? sssFrontFile,  sssBackFile;
    private IBrowserFile? gsisFrontFile, gsisBackFile;

    // ── Lifecycle ──────────────────────────────────────────────────
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        var ctx = editForm?.EditContext;
        if (ctx == null) return;

        messageStore = new ValidationMessageStore(ctx);
        ctx.OnFieldChanged += (_, _) =>
        {
            ValidateConditionalFields();
            ctx.NotifyValidationStateChanged();
        };
    }

    // ── Validation ─────────────────────────────────────────────────
    private static readonly string[] ScrollTargets =
    [
        "field-GovIDs", "field-IDsPresented"
    ];

    private async Task TriggerValidation()
    {
        var ctx = editForm?.EditContext;
        if (ctx == null) return;

        ctx.Validate();
        ValidateConditionalFields();
        ctx.NotifyValidationStateChanged();

        if (!ctx.GetValidationMessages().Any()) return;
        foreach (var id in ScrollTargets)
        {
            try { if (await JS.InvokeAsync<bool>("scrollToFirstError", id)) break; }
            catch { /* element not in DOM */ }
        }
    }

    private void ValidateConditionalFields()
    {
        var store = messageStore;
        var ctx   = editForm?.EditContext;
        if (store == null || ctx == null) return;

        store.Clear();
        govIdError = null;

        // At least one government ID required
        bool hasGovId = !string.IsNullOrWhiteSpace(IdModel.TINNumber)
                     || !string.IsNullOrWhiteSpace(IdModel.SSSNumber)
                     || !string.IsNullOrWhiteSpace(IdModel.GSISNumber);

        if (!hasGovId)
        {
            govIdError = "At least one government ID (TIN, SSS, or GSIS) is required.";
        }
        else
        {
            // TIN: 999-999-999 or 999-999-999-999
            if (!string.IsNullOrWhiteSpace(IdModel.TINNumber) &&
                !System.Text.RegularExpressions.Regex.IsMatch(
                    IdModel.TINNumber.Trim(), @"^\d{3}-\d{3}-\d{3}(-\d{3})?$"))
                store.Add(() => IdModel.TINNumber, "Invalid TIN format. Use 123-456-789 or 123-456-789-000.");

            // SSS: 99-9999999-9
            if (!string.IsNullOrWhiteSpace(IdModel.SSSNumber) &&
                !System.Text.RegularExpressions.Regex.IsMatch(
                    IdModel.SSSNumber.Trim(), @"^\d{2}-\d{7}-\d{1}$"))
                store.Add(() => IdModel.SSSNumber, "Invalid SSS format. Use 34-1234567-8.");

            // GSIS: 11 digits
            if (!string.IsNullOrWhiteSpace(IdModel.GSISNumber) &&
                !System.Text.RegularExpressions.Regex.IsMatch(
                    IdModel.GSISNumber.Trim(), @"^\d{11}$"))
                store.Add(() => IdModel.GSISNumber, "Invalid GSIS format. Must be 11 digits.");
        }

        // Driver's License fields required when checked
        if (ShowDL)
        {
            if (string.IsNullOrWhiteSpace(IdModel.DriversLicenseIDNo))
                store.Add(() => IdModel.DriversLicenseIDNo, "License number is required.");
            if (IdModel.DriversLicenseExpiry == null)
                store.Add(() => IdModel.DriversLicenseExpiry, "License expiry date is required.");
        }

        // Passport fields required when checked
        if (ShowPassport)
        {
            if (string.IsNullOrWhiteSpace(IdModel.PassportIDNo))
                store.Add(() => IdModel.PassportIDNo, "Passport number is required.");
            if (IdModel.PassportIDExpiry == null)
                store.Add(() => IdModel.PassportIDExpiry, "Passport expiry date is required.");
            else if (IdModel.PassportIDExpiry <= DateOnly.FromDateTime(DateTime.Today))
                store.Add(() => IdModel.PassportIDExpiry, "Passport must not be expired.");
        }

        // Other ID fields required when checked
        if (ShowOthers)
        {
            if (string.IsNullOrWhiteSpace(IdModel.OtherIDType))
                store.Add(() => IdModel.OtherIDType, "ID type is required.");
            if (string.IsNullOrWhiteSpace(IdModel.OtherIDNumber))
                store.Add(() => IdModel.OtherIDNumber, "ID number is required.");
        }
    }

    // ── Auto-formatters ───────────────────────────────────────────
    private static string StripNonDigits(string? val)
        => System.Text.RegularExpressions.Regex.Replace(val ?? "", @"[^\d]", "");

    private void FormatTIN(ChangeEventArgs e)
    {
        // Max 12 digits → 123-456-789-000
        var d = StripNonDigits(e.Value?.ToString());
        if (d.Length > 12) d = d[..12];
        IdModel.TINNumber = d.Length switch
        {
            <= 3 => d,
            <= 6 => $"{d[..3]}-{d[3..]}",
            <= 9 => $"{d[..3]}-{d[3..6]}-{d[6..]}",
            _    => $"{d[..3]}-{d[3..6]}-{d[6..9]}-{d[9..]}"
        };
    }

    private void FormatSSS(ChangeEventArgs e)
    {
        // Max 10 digits → 34-1234567-8
        var d = StripNonDigits(e.Value?.ToString());
        if (d.Length > 10) d = d[..10];
        IdModel.SSSNumber = d.Length switch
        {
            <= 2 => d,
            <= 9 => $"{d[..2]}-{d[2..]}",
            _    => $"{d[..2]}-{d[2..9]}-{d[9..]}"
        };
    }

    private void FormatGSIS(ChangeEventArgs e)
    {
        // Max 11 digits only
        var d = StripNonDigits(e.Value?.ToString());
        if (d.Length > 11) d = d[..11];
        IdModel.GSISNumber = d;
    }

    // ── KYC Handlers ──────────────────────────────────────────────
    private async Task<string?> ReadImageDataUrl(IBrowserFile file)
    {
        if (file.Size > 5 * 1024 * 1024) { kycError = "Image must be under 5MB."; return null; }
        kycError = null;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
        return $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
    }

    private async Task CaptureTinFront(InputFileChangeEventArgs e)
    {
        var file = e.File;
        tinFrontPreview = await ReadImageDataUrl(file); tinFrontFile = file;
    }
    private async Task CaptureTinBack(InputFileChangeEventArgs e)
    {
        var file = e.File;
        tinBackPreview = await ReadImageDataUrl(file); tinBackFile = file;
    }
    private async Task CaptureSssFront(InputFileChangeEventArgs e)
    {
        var file = e.File;
        sssFrontPreview = await ReadImageDataUrl(file); sssFrontFile = file;
    }
    private async Task CaptureSssBack(InputFileChangeEventArgs e)
    {
        var file = e.File;
        sssBackPreview = await ReadImageDataUrl(file); sssBackFile = file;
    }
    private async Task CaptureGsisFront(InputFileChangeEventArgs e)
    {
        var file = e.File;
        gsisFrontPreview = await ReadImageDataUrl(file); gsisFrontFile = file;
    }
    private async Task CaptureGsisBack(InputFileChangeEventArgs e)
    {
        var file = e.File;
        gsisBackPreview = await ReadImageDataUrl(file); gsisBackFile = file;
    }
    private async Task CaptureSelfie(InputFileChangeEventArgs e)
    {

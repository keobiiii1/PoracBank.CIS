@using CIS.Client.Services
@using CIS.Assets.DTO
@using Microsoft.AspNetCore.Components.Forms
@inject IndividualService IndividualService
@inject IJSRuntime JS

<EditForm Model="IdModel" OnValidSubmit="Next" @ref="editForm">
    <DataAnnotationsValidator />

    <div class="ii-wrap">

        @* ══════════════════════════════════════
           SECTION 1 — Selfie
        ══════════════════════════════════════ *@
        <div class="ii-section">
            <div class="ii-section-header">
                <div class="ii-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="12" cy="13" r="4" stroke="white" stroke-width="2"/>
                    </svg>
                </div>
                <span class="ii-section-title">Selfie</span>
                <span class="ii-section-sub">Required for identity verification</span>
            </div>
            <div class="ii-kyc-grid">
                <div class="ii-kyc-card @(selfiePreview != null ? "ii-kyc-done" : "")">
                    <div class="ii-kyc-preview">
                        @if (selfiePreview != null)
                        {
                            <img src="@selfiePreview" class="ii-kyc-img" alt="Selfie preview" />
                            <div class="ii-kyc-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                            <button type="button" class="ii-kyc-delete" @onclick="ClearSelfie" title="Remove photo">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                            </button>
                        }
                        else
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" class="ii-kyc-placeholder-icon">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/>
                            </svg>
                        }
                    </div>
                    <div class="ii-kyc-label">Face Photo <span class="ii-req">*</span></div>
                    <div class="ii-kyc-hint">Clear, well-lit photo of your face</div>
                    <div class="ii-kyc-actions">
                        <label class="ii-kyc-btn">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="2"/></svg>
                            @(selfiePreview != null ? "Retake" : "Camera")
                            <InputFile accept="image/*" capture="user" class="ii-hidden-input" OnChange="CaptureSelfie" />
                        </label>
                        <label class="ii-kyc-btn ii-kyc-btn-upload">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polyline points="17 8 12 3 7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="3" x2="12" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            Upload
                            <InputFile accept="image/*" class="ii-hidden-input" OnChange="CaptureSelfie" />
                        </label>
                    </div>
                </div>
            </div>
        </div>

        @* ══════════════════════════════════════
           SECTION 2 — Government IDs
        ══════════════════════════════════════ *@
        <div class="ii-section" id="field-GovIDs">
            <div class="ii-section-header">
                <div class="ii-section-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <rect x="2" y="5" width="20" height="14" rx="2" stroke="white" stroke-width="2" />
                        <path d="M2 10h20" stroke="white" stroke-width="2" stroke-linecap="round" />
                        <path d="M6 15h4M6 17h2" stroke="white" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                </div>
                <span class="ii-section-title">Government IDs</span>
                <span class="ii-section-sub">At least one required — fill in number then upload photos</span>
            </div>

            @* ── TIN ── *@
            <div class="ii-id-card">
                <div class="ii-id-card-header">
                    <div class="ii-id-card-icon">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/><path d="M2 10h20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    </div>
                    <span class="ii-id-card-name">TIN No.</span>
                    <span class="ii-id-card-sub">(Tax Identification Number)</span>
                </div>
                <div class="ii-id-card-body">
                    <div class="ii-id-card-field">
                        <input type="text" class="ii-input" placeholder="e.g. 123-456-789-000" value="@IdModel.TINNumber" @oninput="FormatTIN" maxlength="15" />
                        <ValidationMessage For="@(() => IdModel.TINNumber)" class="ii-field-error" />
                    </div>
                    @if (!string.IsNullOrWhiteSpace(IdModel.TINNumber))
                    {
                        <div class="ii-id-card-photos">
                            <div class="ii-id-card-photos-label">ID Photos <span class="ii-req">*</span></div>
                            <div class="ii-kyc-grid">
                                <div class="ii-kyc-card @(tinFrontPreview != null ? "ii-kyc-done" : "")">
                                    <div class="ii-kyc-preview">
                                        @if (tinFrontPreview != null) { <img src="@tinFrontPreview" class="ii-kyc-img" alt="TIN Front" /><div class="ii-kyc-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                                            <button type="button" class="ii-kyc-delete" @onclick="ClearTinFront" title="Remove photo">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                                        </button> }
                                        else { <svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="ii-kyc-placeholder-icon"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 10h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> }
                                    </div>
                                    <div class="ii-kyc-label">Front <span class="ii-req">*</span></div>
                                    <div class="ii-kyc-actions">
                                        <label class="ii-kyc-btn">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="2"/></svg>
                                            @(tinFrontPreview != null ? "Retake" : "Camera")
                                            <InputFile accept="image/*" capture="environment" class="ii-hidden-input" OnChange="CaptureTinFront" />
                                        </label>
                                        <label class="ii-kyc-btn ii-kyc-btn-upload">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polyline points="17 8 12 3 7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="3" x2="12" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                            Upload
                                            <InputFile accept="image/*" class="ii-hidden-input" OnChange="CaptureTinFront" />
                                        </label>
                                    </div>
                                </div>
                                <div class="ii-kyc-card @(tinBackPreview != null ? "ii-kyc-done" : "")">
                                    <div class="ii-kyc-preview">
                                        @if (tinBackPreview != null) { <img src="@tinBackPreview" class="ii-kyc-img" alt="TIN Back" /><div class="ii-kyc-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                                            <button type="button" class="ii-kyc-delete" @onclick="ClearTinBack" title="Remove photo">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                                        </button> }
                                        else { <svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="ii-kyc-placeholder-icon"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 10h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> }
                                    </div>
                                    <div class="ii-kyc-label">Back <span class="ii-req">*</span></div>
                                    <div class="ii-kyc-actions">
                                        <label class="ii-kyc-btn">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="2"/></svg>
                                            @(tinBackPreview != null ? "Retake" : "Camera")
                                            <InputFile accept="image/*" capture="environment" class="ii-hidden-input" OnChange="CaptureTinBack" />
                                        </label>
                                        <label class="ii-kyc-btn ii-kyc-btn-upload">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polyline points="17 8 12 3 7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="3" x2="12" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                            Upload
                                            <InputFile accept="image/*" class="ii-hidden-input" OnChange="CaptureTinBack" />
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="ii-divider"></div>

            @* ── SSS ── *@
            <div class="ii-id-card">
                <div class="ii-id-card-header">
                    <div class="ii-id-card-icon">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/><path d="M2 10h20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    </div>
                    <span class="ii-id-card-name">SSS No.</span>
                    <span class="ii-id-card-sub">(Social Security System)</span>
                </div>

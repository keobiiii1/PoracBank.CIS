    // ── Clear (delete) handlers ────────────────────────────────────
    private void ClearSelfie()        { selfiePreview        = null; selfieFile        = null; }
    private void ClearTinFront()      { tinFrontPreview      = null; tinFrontFile      = null; }
    private void ClearTinBack()       { tinBackPreview       = null; tinBackFile       = null; }
    private void ClearSssFront()      { sssFrontPreview      = null; sssFrontFile      = null; }
    private void ClearSssBack()       { sssBackPreview       = null; sssBackFile       = null; }
    private void ClearGsisFront()     { gsisFrontPreview     = null; gsisFrontFile     = null; }
    private void ClearGsisBack()      { gsisBackPreview      = null; gsisBackFile      = null; }
    private void ClearDlFront()       { dlFrontPreview       = null; dlFrontFile       = null; }
    private void ClearDlBack()        { dlBackPreview        = null; dlBackFile        = null; }
    private void ClearPassportFront() { passportFrontPreview = null; passportFrontFile = null; }
    private void ClearPassportBack()  { passportBackPreview  = null; passportBackFile  = null; }
    private void ClearOtherFront()    { otherFrontPreview    = null; otherFrontFile    = null; }
    private void ClearOtherBack()     { otherBackPreview     = null; otherBackFile     = null; }

    // Images are stored as data URLs directly in the DTO.
    // The API repository reads them via IndividualIdentificationDTO.ParseDataUrl()
    // and saves the bytes + content type into the DB binary columns.
    private void SaveKYCImagesToModel()
    {
        // Data URLs are already set during capture via ReadImageDataUrl()
        // Just map preview strings → DTO fields here
        IdModel.SelfieDataUrl               = selfiePreview;
        IdModel.TINFrontDataUrl             = tinFrontPreview;
        IdModel.TINBackDataUrl              = tinBackPreview;
        IdModel.SSSFrontDataUrl             = sssFrontPreview;
        IdModel.SSSBackDataUrl              = sssBackPreview;
        IdModel.GSISFrontDataUrl            = gsisFrontPreview;
        IdModel.GSISBackDataUrl             = gsisBackPreview;
        IdModel.DriversLicenseFrontDataUrl  = dlFrontPreview;
        IdModel.DriversLicenseBackDataUrl   = dlBackPreview;
        IdModel.PassportFrontDataUrl        = passportFrontPreview;
        IdModel.PassportBackDataUrl         = passportBackPreview;
        IdModel.OtherIDFrontDataUrl         = otherFrontPreview;
        IdModel.OtherIDBackDataUrl          = otherBackPreview;
    }

    // ── Submit ─────────────────────────────────────────────────────
    private async Task Next()
    {
        // Validate KYC images
        kycError = null;
        var missingPhotos = new List<string>();
        if (selfieFile == null) missingPhotos.Add("Selfie");
        if (!string.IsNullOrWhiteSpace(IdModel.TINNumber)  && tinFrontFile  == null) missingPhotos.Add("TIN Front");
        if (!string.IsNullOrWhiteSpace(IdModel.TINNumber)  && tinBackFile   == null) missingPhotos.Add("TIN Back");
        if (!string.IsNullOrWhiteSpace(IdModel.SSSNumber)  && sssFrontFile  == null) missingPhotos.Add("SSS Front");
        if (!string.IsNullOrWhiteSpace(IdModel.SSSNumber)  && sssBackFile   == null) missingPhotos.Add("SSS Back");
        if (!string.IsNullOrWhiteSpace(IdModel.GSISNumber) && gsisFrontFile == null) missingPhotos.Add("GSIS Front");
        if (!string.IsNullOrWhiteSpace(IdModel.GSISNumber) && gsisBackFile  == null) missingPhotos.Add("GSIS Back");
        if (ShowDL      && dlFrontFile       == null) missingPhotos.Add("Driver's License Front");
        if (ShowPassport && passportFrontFile == null) missingPhotos.Add("Passport Front");
        if (ShowOthers   && otherFrontFile    == null) missingPhotos.Add("Other ID Front");

        if (missingPhotos.Count > 0)
        {
            kycError = $"Required Photos Missing: {string.Join(", ", missingPhotos)}.";
            return;
        }

        SaveKYCImagesToModel();

        IdModel.CustomerID = CustomerId;

        // Clear fields for unchecked ID types
        if (!ShowDL)
            (IdModel.DriversLicenseIDNo, IdModel.DriversLicenseExpiry) = (null, null);
        if (!ShowPassport)
            (IdModel.PassportIDNo, IdModel.PassportIDExpiry) = (null, null);
        if (!ShowOthers)
            (IdModel.OtherIDType, IdModel.OtherIDNumber, IdModel.OtherIDExpiry) = (null, null, null);

        await OnNext.InvokeAsync();
    }
}

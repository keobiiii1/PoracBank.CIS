                                            <button type="button" class="ii-kyc-delete" @onclick="ClearSssFront" title="Remove photo">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                                        </button> }
                                        else { <svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="ii-kyc-placeholder-icon"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 10h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> }
                                    </div>
                                    <div class="ii-kyc-label">Front <span class="ii-req">*</span></div>
                                    <div class="ii-kyc-actions">
                                        <label class="ii-kyc-btn">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="2"/></svg>
                                            @(sssFrontPreview != null ? "Retake" : "Camera")
                                            <InputFile accept="image/*" capture="environment" class="ii-hidden-input" OnChange="CaptureSssFront" />
                                        </label>
                                        <label class="ii-kyc-btn ii-kyc-btn-upload">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polyline points="17 8 12 3 7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="3" x2="12" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                            Upload
                                            <InputFile accept="image/*" class="ii-hidden-input" OnChange="CaptureSssFront" />
                                        </label>
                                    </div>
                                </div>
                                <div class="ii-kyc-card @(sssBackPreview != null ? "ii-kyc-done" : "")">
                                    <div class="ii-kyc-preview">
                                        @if (sssBackPreview != null) { <img src="@sssBackPreview" class="ii-kyc-img" alt="SSS Back" /><div class="ii-kyc-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                                            <button type="button" class="ii-kyc-delete" @onclick="ClearSssBack" title="Remove photo">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                                        </button> }
                                        else { <svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="ii-kyc-placeholder-icon"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 10h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> }
                                    </div>
                                    <div class="ii-kyc-label">Back <span class="ii-req">*</span></div>
                                    <div class="ii-kyc-actions">
                                        <label class="ii-kyc-btn">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="2"/></svg>
                                            @(sssBackPreview != null ? "Retake" : "Camera")
                                            <InputFile accept="image/*" capture="environment" class="ii-hidden-input" OnChange="CaptureSssBack" />
                                        </label>
                                        <label class="ii-kyc-btn ii-kyc-btn-upload">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polyline points="17 8 12 3 7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="3" x2="12" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                            Upload
                                            <InputFile accept="image/*" class="ii-hidden-input" OnChange="CaptureSssBack" />
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="ii-divider"></div>

            @* ── GSIS ── *@
            <div class="ii-id-card">
                <div class="ii-id-card-header">
                    <div class="ii-id-card-icon">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/><path d="M2 10h20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    </div>
                    <span class="ii-id-card-name">GSIS No.</span>
                    <span class="ii-id-card-sub">(Government Service Insurance System)</span>
                </div>
                <div class="ii-id-card-body">
                    <div class="ii-id-card-field">
                        <input type="text" class="ii-input" placeholder="e.g. 00012345678" value="@IdModel.GSISNumber" @oninput="FormatGSIS" maxlength="11" />
                        <ValidationMessage For="@(() => IdModel.GSISNumber)" class="ii-field-error" />
                    </div>
                    @if (!string.IsNullOrWhiteSpace(IdModel.GSISNumber))
                    {
                        <div class="ii-id-card-photos">
                            <div class="ii-id-card-photos-label">ID Photos <span class="ii-req">*</span></div>
                            <div class="ii-kyc-grid">
                                <div class="ii-kyc-card @(gsisFrontPreview != null ? "ii-kyc-done" : "")">
                                    <div class="ii-kyc-preview">
                                        @if (gsisFrontPreview != null) { <img src="@gsisFrontPreview" class="ii-kyc-img" alt="GSIS Front" /><div class="ii-kyc-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
